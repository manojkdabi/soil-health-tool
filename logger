function testTrackA() {
  Logger.log('=== TEST 3: Track A Statistical API (SHPI) ===');
  try {
    var token = getToken_();
    Logger.log('Token OK');

    var bbox    = [74.5, 18.8, 75.2, 19.3];
    var payload = {
      input: {
        bounds: {
          bbox: bbox,
          properties: { crs: 'http://www.opengis.net/def/crs/OGC/1.3/CRS84' }
        },
        data: [{
          dataFilter: { timeRange: { from: '2021-01-01T00:00:00Z', to: '2023-12-31T23:59:59Z' } },
          type: 'sentinel-2-l2a'
        }]
      },
      aggregation: {
        timeRange:           { from: '2021-01-01T00:00:00Z', to: '2023-12-31T23:59:59Z' },
        aggregationInterval: { of: 'P3M' },
        evalscript:          EVALSCRIPT_STATS_A,
        resx:                0.01,
        resy:                0.01
      },
      calculations: {
        shpi: {
          histograms: { default: { nBins: 100, lowEdge: -0.5, highEdge: 1.5 } }
        }
      }
    };

    var resp = UrlFetchApp.fetch('https://sh.dataspace.copernicus.eu/api/v1/statistics', {
      method:             'post',
      contentType:        'application/json',
      payload:            JSON.stringify(payload),
      headers:            { Authorization: 'Bearer ' + token },
      muteHttpExceptions: true
    });

    var code = resp.getResponseCode();
    Logger.log('HTTP status: ' + code);

    if (code !== 200) {
      Logger.log('ERROR: ' + resp.getContentText().substring(0, 500));
      return;
    }

    var body = JSON.parse(resp.getContentText());
    Logger.log('Top-level keys: ' + Object.keys(body).join(', '));
    Logger.log('data[] length: ' + (body.data ? body.data.length : 'missing'));

    if (!body.data || body.data.length === 0) {
      Logger.log('EMPTY - no periods returned');
      Logger.log('Full response: ' + resp.getContentText().substring(0, 500));
      return;
    }

    Logger.log('REAL DATA received - ' + body.data.length + ' periods');
    var allBins = [];
    body.data.forEach(function(period, pi) {
      try {
        var interval = period.interval;
        var outputs  = period.outputs;
        Logger.log('Period ' + pi + ': ' + JSON.stringify(interval));
        Logger.log('  Output keys: ' + Object.keys(outputs).join(', '));
        var out   = outputs['shpi'] || outputs[Object.keys(outputs)[0]];
        Logger.log('  Band keys: ' + Object.keys(out).join(', '));
        var bands = out.bands || out;
        var band  = bands['B0'] || bands[Object.keys(bands)[0]];
        Logger.log('  Stat keys: ' + Object.keys(band).join(', '));
        if (band.histogram && band.histogram.bins) {
          var bins = band.histogram.bins;
          var valid = bins.filter(function(b) { return b.count > 0; });
          Logger.log('  Histogram: ' + bins.length + ' bins, ' + valid.length + ' non-empty');
          valid.forEach(function(b) {
            if (b.mean === undefined) b.mean = (b.lowEdge + b.highEdge) / 2;
            Logger.log('    mean=' + b.mean.toFixed(4) + ' count=' + b.count);
            allBins.push(b);
          });
        } else {
          Logger.log('  No histogram. Band content: ' + JSON.stringify(band).substring(0,200));
        }
      } catch(pe) {
        Logger.log('Period ' + pi + ' error: ' + pe.message);
      }
    });
    Logger.log('Total valid bins: ' + allBins.length);
    if (allBins.length >= 5) {
      Logger.log('STATUS: SHPI data ready for zone computation');
    } else {
      Logger.log('STATUS: Insufficient bins - will use synthetic fallback');
    }

  } catch(e) {
    Logger.log('EXCEPTION: ' + e.message);
  }
}

