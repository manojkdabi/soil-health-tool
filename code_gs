// Default SHPI quantile-boundary thresholds (used as fallback before real histogram analysis)
var DEFAULT_SHPI_THRESHOLDS = [0.20, 0.35, 0.50, 0.65];

// ── Evalscript: Track A — Soil Health Proxy Index ────────────
// resx/resy = 0.01 degrees (~1.1km) — within Sentinel Hub limit
// dataMask output required by Statistical API
var EVALSCRIPT_STATS_A =
  '//VERSION=3\n' +
  'function setup() {\n' +
  '  return {\n' +
  '    input: [{ bands: ["B02","B03","B04","B08","B11","B12","SCL"] }],\n' +
  '    output: [\n' +
 '      { id: "shpi",     bands: 1, sampleType: "FLOAT32" },\n' +
  '      { id: "dataMask", bands: 1, sampleType: "UINT8"   }\n' +
  '    ],\n' +
  '    mosaicking: "ORBIT"\n' +
  '  };\n' +
  '}\n' +
  'function preProcessScenes(c) {\n' +
  '  c.scenes.orbits = c.scenes.orbits.filter(function(o) {\n' +
  '    var m = new Date(o.dateFrom).getMonth() + 1;\n' +
  '    return m === 11 || m === 12 || m === 1 || m === 2;\n' +
  '  });\n' +
  '  return c;\n' +
  '}\n' +
  'function evaluatePixel(samples) {\n' +
  '  var v = samples.filter(function(s) {\n' +
  '    return s.SCL !== 3 && s.SCL !== 8 && s.SCL !== 9 && s.SCL !== 10;\n' +
  '  });\n' +
  '  if (v.length === 0) return { shpi: [0], dataMask: [0] };\n' +
  '  function med(a, k) {\n' +
  '    var x = a.map(function(s) { return s[k]; }).sort(function(a,b) { return a-b; });\n' +
  '    var m = Math.floor(x.length / 2);\n' +
  '    return x.length % 2 ? x[m] : (x[m-1] + x[m]) / 2;\n' +
  '  }\n' +
  '  var b2  = med(v,"B02"), b3  = med(v,"B03"), b4  = med(v,"B04");\n' +
  '  var b8  = med(v,"B08"), b11 = med(v,"B11"), b12 = med(v,"B12");\n' +
  '  var lswi = (b8 - b11) / (b8 + b11 + 0.0001);\n' +
  '  if (lswi >= 0) return { shpi: [0], dataMask: [0] };\n' +
  '  var bsi  = ((b11+b4)-(b8+b2)) / ((b11+b4)+(b8+b2)+0.0001);\n' +
  '  var bi   = Math.sqrt((b4*b4 + b3*b3 + b2*b2) / 3.0);\n' +
  '  var ri   = (b4*b4) / (b2*b3 + 0.0001);\n' +
  '  var clay = b11 / (b12 + 0.0001);\n' +
  '  var carb = b11 / (b8  + 0.0001);\n' +
  '  var hue  = Math.atan((b3-b4) / (b3+b4+0.0001));\n' +
  '  var bsiN  = Math.max(0, Math.min(1, (bsi + 0.5)));\n' +
  '  var biN   = Math.max(0, Math.min(1, bi   / 0.3));\n' +
  '  var riN   = Math.max(0, Math.min(1, ri   / 5.0));\n' +
  '  var clayN = Math.max(0, Math.min(1, (clay - 0.8) / 0.6));\n' +
  '  var carbN = Math.max(0, Math.min(1, (carb - 0.5) / 1.5));\n' +
  '  var hueN  = Math.max(0, Math.min(1, (hue  + 0.5)));\n' +
  '  var shpi  = (1-biN)*0.25 + (1-bsiN)*0.20 + clayN*0.20 + riN*0.15 + carbN*0.10 + hueN*0.10;\n' +
  '  return { shpi: [shpi], dataMask: [1] };\n' +
  '}';

// ── Evalscript: Track B — NDVI (crop season) ─────────────────
var EVALSCRIPT_STATS_B =
  '//VERSION=3\n' +
  'function setup() {\n' +
  '  return {\n' +
  '    input: [{ bands: ["B04","B08","SCL"] }],\n' +
  '    output: [\n' +
  '      { id: "ndvi",     bands: 1, sampleType: "FLOAT32" },\n' +
  '      { id: "dataMask", bands: 1, sampleType: "UINT8"   }\n' +
  '    ],\n' +
  '    mosaicking: "ORBIT"\n' +
  '  };\n' +
  '}\n' +
  'function preProcessScenes(c) {\n' +
  '  c.scenes.orbits = c.scenes.orbits.filter(function(o) {\n' +
  '    var m = new Date(o.dateFrom).getMonth() + 1;\n' +
  '    return m >= 6 && m <= 10;\n' +
  '  });\n' +
  '  return c;\n' +
  '}\n' +
  'function evaluatePixel(samples) {\n' +
  '  var v = samples.filter(function(s) {\n' +
  '    return s.SCL !== 3 && s.SCL !== 8 && s.SCL !== 9 && s.SCL !== 10;\n' +
  '  });\n' +
  '  if (v.length === 0) return { ndvi: [0], dataMask: [0] };\n' +
  '  function med(a, k) {\n' +
  '    var x = a.map(function(s) { return s[k]; }).sort(function(a,b) { return a-b; });\n' +
  '    var m = Math.floor(x.length / 2);\n' +
  '    return x.length % 2 ? x[m] : (x[m-1] + x[m]) / 2;\n' +
  '  }\n' +
  '  var b4 = med(v,"B04"), b8 = med(v,"B08");\n' +
  '  var ndvi = Math.max(0.0, (b8-b4) / (b8+b4+0.0001));\n' +
  '  return { ndvi: [ndvi], dataMask: [1] };\n' +
  '}';

