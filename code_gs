const SH_CLIENT_ID = '..............'
const SH_CLIENT_SECRET = '...................'
var SH_TOKEN_URL      = 'https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token';
var SH_PROCESS_URL    = 'https://sh.dataspace.copernicus.eu/api/v1/process';
var SH_STATISTICS_URL = 'https://sh.dataspace.copernicus.eu/api/v1/statistics';

// Default SHPI quantile-boundary thresholds (used as fallback before real histogram analysis)
var DEFAULT_SHPI_THRESHOLDS = [0.20, 0.35, 0.50, 0.65];

function buildCombinedEvalscript_() {
  // Evalscript V3 — 4-band RGBA UINT8 output
  // R = SHPI×254 (soil health, from bare-soil obs)
  // G = CPI×254  (crop productivity, from crop obs)
  // B = bare-soil observation count (0–254)
  // A = crop observation count (0–254)
  // B=0 AND A=0 → invalid/nodata pixel
  return '//VERSION=3\n' +
    'function setup(){\n' +
    '  return{\n' +
    '    input:[{bands:["B02","B03","B04","B05","B08","B11","B12","SCL"]}],\n' +
    '    output:{bands:4,sampleType:"UINT8"},\n' +
    '    mosaicking:"ORBIT"\n' +
    '  };\n' +
    '}\n' +
    'function evaluatePixel(samples){\n' +
    '  // Compute median of a named band across a sample array\n' +
    '  function med(a,k){\n' +
    '    var x=a.map(function(s){return s[k];}).sort(function(a,b){return a-b;});\n' +
    '    var m=Math.floor(x.length/2);\n' +
    '    return x.length%2?x[m]:(x[m-1]+x[m])/2;\n' +
    '  }\n' +
    '  // Safe division: returns 0 when denominator is zero\n' +
    '  function div(a,b){return b===0?0:a/b;}\n' +
    '  // Soft clamp to [0,1]\n' +
    '  function c01(v){return v<0?0:v>1?1:v;}\n' +
    '\n' +
    '  // Separate bare-soil and crop observations per spec masks\n' +
    '  var bareS=[], cropS=[];\n' +
    '  for(var i=0;i<samples.length;i++){\n' +
    '    var s=samples[i];\n' +
    '    if(s.SCL===3||s.SCL===8||s.SCL===9||s.SCL===10) continue;\n' +
    '    var ndvi=div(s.B08-s.B04,s.B08+s.B04);\n' +
    '    var ndmi=div(s.B08-s.B11,s.B08+s.B11);\n' +
    '    var nirv=Math.max(0,ndvi)*s.B08;\n' +
    '    if(ndvi<0.2&&ndmi<0.05&&nirv<0.05) bareS.push(s);\n' +
    '    if(ndvi>0.35&&nirv>0.1) cropS.push(s);\n' +
    '  }\n' +
    '\n' +
    '  // No valid observations: return nodata (all zeros)\n' +
    '  if(!bareS.length&&!cropS.length) return[0,0,0,0];\n' +
    '\n' +
    '  // ── SHPI from bare-soil observations ─────────────────────\n' +
    '  var shpiBand=0;\n' +
    '  if(bareS.length>0){\n' +
    '    var b2=med(bareS,"B02"),b3=med(bareS,"B03"),b4=med(bareS,"B04");\n' +
    '    var b8=med(bareS,"B08"),b11=med(bareS,"B11"),b12=med(bareS,"B12");\n' +
    '    // Sub-indices: SAB, ClaySI, RI2, SMI\n' +
    '    var sab=(b2+b3+b4)/3.0;\n' +
    '    var claySI=div(b11-b12,b11+b12);\n' +
    '    var ri2=div(b4-b2,b4+b2);\n' +
    '    var smi=div(b8-b11,b8+b11);\n' +
    '    // Normalize each sub-index to [0,1] with field-calibrated soft clamps\n' +
    '    var sabN   =c01((sab   -0.03)/0.17);\n' +
    '    var claySIN=c01((claySI+0.10)/0.20);\n' +
    '    var ri2N   =c01((ri2   +0.05)/0.20);\n' +
    '    var smiN   =c01((smi   +0.20)/0.50);\n' +
    '    // SHPI: lower albedo = healthier; higher clay/redness/moisture = healthier\n' +
    '    var shpi=(1-sabN)*0.35+claySIN*0.30+ri2N*0.20+smiN*0.15;\n' +
    '    shpiBand=Math.round(c01(shpi)*254);\n' +
    '  }\n' +
    '\n' +
    '  // ── CPI from crop observations ────────────────────────────\n' +
    '  var cpiBand=0;\n' +
    '  if(cropS.length>0){\n' +
    '    var b4c=med(cropS,"B04"),b5c=med(cropS,"B05"),b8c=med(cropS,"B08"),b11c=med(cropS,"B11");\n' +
    '    var ndviC=div(b8c-b4c,b8c+b4c);\n' +
    '    // Sub-indices: EVI2, NDRE, NIRv, NDMI\n' +
    '    var evi2=2.5*div(b8c-b4c,b8c+2.4*b4c+1);\n' +
    '    var ndre=div(b8c-b5c,b8c+b5c);\n' +
    '    var nirv=Math.max(0,ndviC)*b8c;\n' +
    '    var ndmi=div(b8c-b11c,b8c+b11c);\n' +
    '    // Normalize each sub-index to [0,1] with field-calibrated soft clamps\n' +
    '    var e2N =c01(evi2/0.80);\n' +
    '    var drN =c01(ndre/0.60);\n' +
    '    var nvN =c01(nirv/0.40);\n' +
    '    var dmN =c01((ndmi+0.10)/0.60);\n' +
    '    // CPI: weighted composite of four crop-health spectral indices\n' +
    '    var cpi=e2N*0.35+drN*0.30+nvN*0.20+dmN*0.15;\n' +
    '    cpiBand=Math.round(c01(cpi)*254);\n' +
    '  }\n' +
    '\n' +
    '  // Observation counts capped at 254 (255 reserved for future nodata flags)\n' +
    '  var soilCnt=Math.min(254,bareS.length);\n' +
    '  var cropCnt=Math.min(254,cropS.length);\n' +
    '  return[shpiBand,cpiBand,soilCnt,cropCnt];\n' +
    '}';
}

function fetchCombinedRaster_(bbox, yearStart, yearEnd, token) {
  try {
    var from = yearStart + '-01-01T00:00:00Z';
    var to   = yearEnd   + '-12-31T23:59:59Z';
    var lngSpan = bbox[2] - bbox[0];
    var latSpan = bbox[3] - bbox[1];
    var W, H;
    if (lngSpan >= latSpan) {
      W = 512; H = Math.max(1, Math.round(512 * latSpan / lngSpan));
    } else {
      H = 512; W = Math.max(1, Math.round(512 * lngSpan / latSpan));
    }
    var payload = {
      input: {
        bounds: { bbox: bbox, properties: { crs: 'http://www.opengis.net/def/crs/OGC/1.3/CRS84' } },
        data: [{ dataFilter: { timeRange: { from: from, to: to } }, type: 'sentinel-2-l2a' }]
      },
      output: {
        width: W, height: H,
        responses: [{ identifier: 'default', format: { type: 'image/png' } }]
      },
      evalscript: buildCombinedEvalscript_()
    };
    var resp = UrlFetchApp.fetch(SH_PROCESS_URL, {
      method: 'post', contentType: 'application/json',
      headers: { Authorization: 'Bearer ' + token },
      payload: JSON.stringify(payload), muteHttpExceptions: true
    });
    Logger.log('Combined raster status: ' + resp.getResponseCode());
    if (resp.getResponseCode() !== 200) {
      Logger.log('Combined raster error: ' + resp.getContentText().substring(0, 400));
      return null;
    }
    return Utilities.base64Encode(resp.getContent());
  } catch(e) {
    Logger.log('Combined raster error: ' + e.message);
    return null;
  }
}

