}

// ── OAuth token ───────────────────────────────────────────────
function getToken_() {
  var resp = UrlFetchApp.fetch(SH_TOKEN_URL, {
    method: 'post',
    payload: {
      grant_type:    'client_credentials',
      client_id:     SH_CLIENT_ID,
      client_secret: SH_CLIENT_SECRET
    },
    muteHttpExceptions: true
  });
  if (resp.getResponseCode() !== 200) {
    throw new Error('Token request failed (' + resp.getResponseCode() + '): ' + resp.getContentText().substring(0, 200));
  }
  var data;
  try {
    data = JSON.parse(resp.getContentText());
  } catch (e) {
    throw new Error('Token response is not valid JSON: ' + e.message);
  }
  if (!data.access_token) throw new Error('Token error: no access_token in response');
  return data.access_token;
}

// ── BBox from GeoJSON ─────────────────────────────────────────
function getBbox_(geometry) {
  var coords = [];
  if (geometry.type === 'Polygon') {
    coords = geometry.coordinates[0];
  } else if (geometry.type === 'MultiPolygon') {
    geometry.coordinates.forEach(function(poly) {
      poly[0].forEach(function(c) { coords.push(c); });
    });
  } else {
    throw new Error('Unsupported geometry type: ' + geometry.type);
  }
  if (!coords || coords.length === 0) {
    throw new Error('Geometry has no coordinates');
  }
  var lons = coords.map(function(c) { return c[0]; });
  var lats = coords.map(function(c) { return c[1]; });
  return [
    Math.min.apply(null, lons), Math.min.apply(null, lats),
    Math.max.apply(null, lons), Math.max.apply(null, lats)
  ];
}

// ── Main: called from HTML client ────────────────────────────
function runAnalysis(params) {
  try {
    var geojson    = params.geojson;
    var yearStart  = params.yearStart;
    var yearEnd    = params.yearEnd;
    var resolution = params.resolution;

    Logger.log('runAnalysis: ' + yearStart + '-' + yearEnd + ' at ' + resolution + 'm');

    var token = getToken_();
    var bbox  = getBbox_(geojson);
    Logger.log('BBox: ' + JSON.stringify(bbox));

    Logger.log('Fetching combined raster...');
    var rasterB64 = fetchCombinedRaster_(bbox, yearStart, yearEnd, token);

    if (!rasterB64) {
      return { success: false, error: 'Combined raster fetch failed — check Sentinel Hub credentials and ROI size' };
    }

    Logger.log('Combined raster OK — returning to frontend for pixel decoding');

    return {
      success:        true,
      bbox:           bbox,
      raster_png_b64: rasterB64,
      meta: {
        resolution_m: resolution,
        year_range:   yearStart + '-' + yearEnd,
        bbox:         bbox,
        width:        null,
        height:       null
      }
    };

  } catch(e) {
    Logger.log('runAnalysis error: ' + e.message);
    return { success: false, error: e.message };
  }
}

// ── Time-series evalscript (Statistics API) ───────────────────
// Returns 5 float bands per pixel per scene: EVI2, NDRE, NIRv, NDMI, NDVI.
// Cloud / shadow pixels (SCL 3/8/9/10) return NaN so the Statistics API
// excludes them from the per-interval mean.
function buildTsEvalscript_() {
  return '//VERSION=3\n' +
    'function setup(){\n' +
    '  return{input:[{bands:["B04","B05","B08","B11","SCL"],units:"REFLECTANCE"}],\n' +
    '         output:[{id:"data",bands:5,sampleType:"FLOAT32"}]};\n' +
    '}\n' +
    'function evaluatePixel(s){\n' +
    '  if(s.SCL===3||s.SCL===8||s.SCL===9||s.SCL===10)\n' +
    '    return{data:[NaN,NaN,NaN,NaN,NaN]};\n' +
    '  var d=s.B08-s.B04,s2=s.B08+s.B04+1e-9;\n' +
    '  var ndvi=d/s2;\n' +
    '  var evi2=2.5*d/(s.B08+2.4*s.B04+1);\n' +
    '  var ndre=(s.B08-s.B05)/(s.B08+s.B05+1e-9);\n' +
    '  var nirv=ndvi>0?ndvi*s.B08:0;\n' +
    '  var ndmi=(s.B08-s.B11)/(s.B08+s.B11+1e-9);\n' +
    '  return{data:[evi2,ndre,nirv,ndmi,ndvi]};\n' +
    '}';
}

// ── Fetch ROI time series via Statistics API ──────────────────
// Returns an array of { date, evi2, ndre, nirv, ndmi, ndvi, n }
// objects (one per 14-day interval that has valid observations).
function fetchROITimeSeries_(geojson, yearStart, yearEnd, token) {
  try {
    var from = yearStart + '-01-01T00:00:00Z';
    var to   = yearEnd   + '-12-31T23:59:59Z';
    var payload = {
      input: {
        bounds: {
          geometry: geojson,
          properties: { crs: 'http://www.opengis.net/def/crs/OGC/1.3/CRS84' }
        },
        data: [{
          dataFilter: { timeRange: { from: from, to: to } },
          type: 'sentinel-2-l2a'
        }]
      },
      aggregation: {
        timeRange: { from: from, to: to },
        aggregationInterval: { of: 'P14D' },
        evalscript: buildTsEvalscript_(),
        resx: 20,
        resy: 20
      },
      calculations: { data: {} }
    };
    var resp = UrlFetchApp.fetch(SH_STATISTICS_URL, {
      method: 'post', contentType: 'application/json',
      headers: { Authorization: 'Bearer ' + token },
      payload: JSON.stringify(payload), muteHttpExceptions: true
    });
    var statusCode = resp.getResponseCode();
    Logger.log('TimeSeries status: ' + statusCode);
    if (statusCode !== 200) {
      var body = resp.getContentText().substring(0, 500);
      Logger.log('TimeSeries error body: ' + body);
      throw new Error('HTTP ' + statusCode + ' — ' + body);
    }
    var result = JSON.parse(resp.getContentText());
    var series = [];
    if (result.data) {
      result.data.forEach(function(interval) {
        if (!interval.outputs || !interval.outputs.data) return;
        var bands = interval.outputs.data.bands;
        // noDataCount includes cloud-masked pixels; skip fully-clouded intervals
        var sampleCount  = (bands.B0.stats.sampleCount || 0);
        var noDataCount  = (bands.B0.stats.noDataCount || 0);
        var n  = sampleCount - noDataCount;
        if (n <= 0) return;
        function safeVal(stat) {
          var v = stat.mean;
          return (v == null || isNaN(v)) ? null : Math.round(v * 1000) / 1000;
        }
        series.push({
          date: interval.interval.from.substring(0, 10),
          evi2: safeVal(bands.B0.stats),
          ndre: safeVal(bands.B1.stats),
          nirv: safeVal(bands.B2.stats),
          ndmi: safeVal(bands.B3.stats),
          ndvi: safeVal(bands.B4.stats),
          n: n
        });
      });
    }
    return series;
  } catch(e) {
    Logger.log('fetchROITimeSeries_ error: ' + e.message);
    return null;
  }
}

// ── Public: fetch time series (called from HTML client) ───────
function getTimeSeries(params) {
  try {
    var token  = getToken_();
    var series = fetchROITimeSeries_(params.geojson, params.yearStart, params.yearEnd, token);
    if (series === null) return { success: false, error: 'Statistics API fetch failed — check GAS execution logs for HTTP status details.' };
    if (series.length === 0) return { success: false, error: 'No valid observations found (all intervals were cloud-covered or outside the ROI).' };
    return { success: true, series: series };
  } catch(e) {
    Logger.log('getTimeSeries error: ' + e.message);
    return { success: false, error: 'Statistics API error: ' + e.message };
  }
}

// ── Save result to Google Sheet ───────────────────────────────
function saveToSheet(data) {
  try {
    var ss    = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('POC Results') || ss.insertSheet('POC Results');
    if (sheet.getLastRow() === 0) {
      sheet.appendRow([
        'Timestamp','Year Range','Resolution (m)','Data Source',
        'Z1 CPI','Z2 CPI','Z3 CPI','Z4 CPI','Z5 CPI',
        'Pearson r','R2','Confirmed','CPI Ratio'
      ]);
    }
    var v = data.validation;
    var z = data.zone_stats;
    sheet.appendRow([
      new Date().toISOString(),
      data.meta.year_range,
      data.meta.resolution_m,
      v.data_source || 'unknown',
      z[0].mean_cpi, z[1].mean_cpi, z[2].mean_cpi, z[3].mean_cpi, z[4].mean_cpi,
      v.pearson_r, v.r_squared,
      v.confirmed ? 'YES' : 'NO',
      v.cpi_ratio
    ]);
    return { success: true };
  } catch(e) {
    return { success: false, error: e.message };
  }
}
