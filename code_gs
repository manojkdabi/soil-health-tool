const SH_CLIENT_ID = '..............'
const SH_CLIENT_SECRET = '...................'
var SH_TOKEN_URL     = 'https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token';
var SH_STATS_URL     = 'https://sh.dataspace.copernicus.eu/api/v1/statistics';
var SH_PROCESS_URL   = 'https://sh.dataspace.copernicus.eu/api/v1/process';

// Default SHPI quantile-boundary thresholds (used as fallback before real histogram analysis)
var DEFAULT_SHPI_THRESHOLDS = [0.20, 0.35, 0.50, 0.65];

// ── Evalscript builders: inject user-specified months ─────────
// rabiMonths / kharifMonths are Arrays of integers, e.g. [12,1,2,3]

function buildEvalscriptA_(rabiMonths) {
  var monthList = '[' + rabiMonths.join(',') + ']';
  return '//VERSION=3\n' +
    'function setup() {\n' +
    '  return {\n' +
    '    input: [{ bands: ["B02","B03","B04","B08","B11","B12","SCL"] }],\n' +
    '    output: [\n' +
    '      { id: "shpi",     bands: 1, sampleType: "FLOAT32" },\n' +
    '      { id: "dataMask", bands: 1, sampleType: "UINT8"   }\n' +
    '    ],\n' +
    '    mosaicking: "ORBIT"\n' +
    '  };\n' +
    '}\n' +
    'function preProcessScenes(c) {\n' +
    '  var rabi = ' + monthList + ';\n' +
    '  c.scenes.orbits = c.scenes.orbits.filter(function(o) {\n' +
    '    var m = new Date(o.dateFrom).getMonth() + 1;\n' +
    '    return rabi.indexOf(m) !== -1;\n' +
    '  });\n' +
    '  return c;\n' +
    '}\n' +
    'function evaluatePixel(samples) {\n' +
    '  var v = samples.filter(function(s) {\n' +
    '    return s.SCL !== 3 && s.SCL !== 8 && s.SCL !== 9 && s.SCL !== 10;\n' +
    '  });\n' +
    '  if (v.length === 0) return { shpi: [0], dataMask: [0] };\n' +
    '  function med(a, k) {\n' +
    '    var x = a.map(function(s) { return s[k]; }).sort(function(a,b) { return a-b; });\n' +
    '    var m = Math.floor(x.length / 2);\n' +
    '    return x.length % 2 ? x[m] : (x[m-1] + x[m]) / 2;\n' +
    '  }\n' +
    '  var b2  = med(v,"B02"), b3  = med(v,"B03"), b4  = med(v,"B04");\n' +
    '  var b8  = med(v,"B08"), b11 = med(v,"B11"), b12 = med(v,"B12");\n' +
    '  var lswi = (b8 - b11) / (b8 + b11 + 0.0001);\n' +
    '  if (lswi >= 0) return { shpi: [0], dataMask: [0] };\n' +
    '  var bsi  = ((b11+b4)-(b8+b2)) / ((b11+b4)+(b8+b2)+0.0001);\n' +
    '  var bi   = Math.sqrt((b4*b4 + b3*b3 + b2*b2) / 3.0);\n' +
    '  var ri   = (b4*b4) / (b2*b3 + 0.0001);\n' +
    '  var clay = b11 / (b12 + 0.0001);\n' +
    '  var carb = b11 / (b8  + 0.0001);\n' +
    '  var hue  = Math.atan((b3-b4) / (b3+b4+0.0001));\n' +
    '  var bsiN  = Math.max(0, Math.min(1, (bsi + 0.5)));\n' +
    '  var biN   = Math.max(0, Math.min(1, bi   / 0.3));\n' +
    '  var riN   = Math.max(0, Math.min(1, ri   / 5.0));\n' +
    '  var clayN = Math.max(0, Math.min(1, (clay - 0.8) / 0.6));\n' +
    '  var carbN = Math.max(0, Math.min(1, (carb - 0.5) / 1.5));\n' +
    '  var hueN  = Math.max(0, Math.min(1, (hue  + 0.5)));\n' +
    '  var shpi  = (1-biN)*0.25 + (1-bsiN)*0.20 + clayN*0.20 + riN*0.15 + carbN*0.10 + hueN*0.10;\n' +
    '  return { shpi: [shpi], dataMask: [1] };\n' +
    '}';
}

// buildEvalscriptB_: multi-temporal evalscript that computes NDVI per SHPI zone.
// For each pixel it:
//   1. Mediates Rabi-season samples → computes full SHPI value (same formula as Track A)
//   2. Assigns the pixel to one of 5 SHPI zones using the thresholds from Track A
//   3. Mediates Kharif-season samples → computes NDVI
//   4. Outputs NDVI in the zone-specific band; sets -2.0 (below histogram range) in other bands
// The Statistical API then gives mean NDVI per SHPI zone — a genuine cross-variable correlation.
// rabiMonths / kharifMonths: Arrays of month integers, e.g. [11,12,1,2]
// shpiThresholds: 4-element Array of SHPI boundary values, e.g. [0.20, 0.35, 0.50, 0.65]
function buildEvalscriptB_(rabiMonths, kharifMonths, shpiThresholds) {
  var rabiList   = '[' + rabiMonths.join(',') + ']';
  var kharifList = '[' + kharifMonths.join(',') + ']';
  var T = (shpiThresholds || DEFAULT_SHPI_THRESHOLDS).slice();
  var threshList = '[' + T.map(function(t) { return t.toFixed(6); }).join(',') + ']';
  var NO_DATA = '-2.0'; // sentinel below histogram lowEdge (-0.5); goes to underflow bin
  return '//VERSION=3\n' +
    'function setup() {\n' +
    '  return {\n' +
    '    input: [{ bands: ["B02","B03","B04","B08","B11","B12","SCL"] }],\n' +
    '    output: [\n' +
    '      { id: "cpi_z1", bands: 1, sampleType: "FLOAT32" },\n' +
    '      { id: "cpi_z2", bands: 1, sampleType: "FLOAT32" },\n' +
    '      { id: "cpi_z3", bands: 1, sampleType: "FLOAT32" },\n' +
    '      { id: "cpi_z4", bands: 1, sampleType: "FLOAT32" },\n' +
    '      { id: "cpi_z5", bands: 1, sampleType: "FLOAT32" },\n' +
    '      { id: "dataMask", bands: 1, sampleType: "UINT8" }\n' +
    '    ],\n' +
    '    mosaicking: "ORBIT"\n' +
    '  };\n' +
    '}\n' +
    'function preProcessScenes(c) {\n' +
    '  var rabi   = ' + rabiList + ';\n' +
    '  var kharif = ' + kharifList + ';\n' +
    '  c.scenes.orbits = c.scenes.orbits.filter(function(o) {\n' +
    '    var m = new Date(o.dateFrom).getMonth() + 1;\n' +
    '    return rabi.indexOf(m) !== -1 || kharif.indexOf(m) !== -1;\n' +
    '  });\n' +
    '  return c;\n' +
    '}\n' +
    'function evaluatePixel(samples, scenes) {\n' +
    '  var rabi   = ' + rabiList + ';\n' +
    '  var kharif = ' + kharifList + ';\n' +
    '  var T      = ' + threshList + ';\n' +
    '  var ND     = ' + NO_DATA + ';\n' +
    '  var noDataResult = { cpi_z1:[ND],cpi_z2:[ND],cpi_z3:[ND],cpi_z4:[ND],cpi_z5:[ND], dataMask:[0] };\n' +
    '  var clean  = function(s) {\n' +
    '    return s.SCL !== 3 && s.SCL !== 8 && s.SCL !== 9 && s.SCL !== 10;\n' +
    '  };\n' +
    '  var rabiS = [], kharS = [];\n' +
    '  samples.forEach(function(s, i) {\n' +
    '    var m = new Date(scenes.orbits[i].dateFrom).getMonth() + 1;\n' +
    '    if (clean(s)) {\n' +
    '      if (rabi.indexOf(m)   !== -1) rabiS.push(s);\n' +
    '      if (kharif.indexOf(m) !== -1) kharS.push(s);\n' +
    '    }\n' +
    '  });\n' +
    '  if (!rabiS.length || !kharS.length) return noDataResult;\n' +
    '  function med(a, k) {\n' +
    '    var x = a.map(function(s){return s[k];}).sort(function(a,b){return a-b;});\n' +
    '    var mid = Math.floor(x.length/2);\n' +
    '    return x.length%2 ? x[mid] : (x[mid-1]+x[mid])/2;\n' +
    '  }\n' +
    '  var b2=med(rabiS,"B02"),b3=med(rabiS,"B03"),b4r=med(rabiS,"B04"),\n' +
    '      b8r=med(rabiS,"B08"),b11=med(rabiS,"B11"),b12=med(rabiS,"B12");\n' +
    '  var lswi = (b8r - b11) / (b8r + b11 + 0.0001);\n' +
    '  // Skip vegetated pixels: only bare-soil pixels (lswi < 0) have meaningful SHPI\n' +
    '  if (lswi >= 0) return noDataResult;\n' +
    '  var bsi  = ((b11+b4r)-(b8r+b2)) / ((b11+b4r)+(b8r+b2)+0.0001);\n' +
    '  var bi   = Math.sqrt((b4r*b4r + b3*b3 + b2*b2) / 3.0);\n' +
    '  var ri   = (b4r*b4r) / (b2*b3 + 0.0001);\n' +
    '  var clay = b11 / (b12 + 0.0001);\n' +
    '  var carb = b11 / (b8r + 0.0001);\n' +
    '  var hue  = Math.atan((b3-b4r) / (b3+b4r+0.0001));\n' +
    '  var bsiN  = Math.max(0,Math.min(1,(bsi + 0.5)));\n' +
    '  var biN   = Math.max(0,Math.min(1,bi   / 0.3));\n' +
    '  var riN   = Math.max(0,Math.min(1,ri   / 5.0));\n' +
    '  var clayN = Math.max(0,Math.min(1,(clay - 0.8) / 0.6));\n' +
    '  var carbN = Math.max(0,Math.min(1,(carb - 0.5) / 1.5));\n' +
    '  var hueN  = Math.max(0,Math.min(1,(hue  + 0.5)));\n' +
    '  var shpi  = (1-biN)*0.25 + (1-bsiN)*0.20 + clayN*0.20 + riN*0.15 + carbN*0.10 + hueN*0.10;\n' +
    '  var zone  = shpi<T[0]?1:shpi<T[1]?2:shpi<T[2]?3:shpi<T[3]?4:5;\n' +
    '  var b4k = med(kharS,"B04"), b8k = med(kharS,"B08");\n' +
    '  var ndvi = Math.max(0,Math.min(1,(b8k-b4k)/(b8k+b4k+0.0001)));\n' +
    '  var res = { cpi_z1:[ND],cpi_z2:[ND],cpi_z3:[ND],cpi_z4:[ND],cpi_z5:[ND], dataMask:[1] };\n' +
    '  res["cpi_z"+zone] = [ndvi];\n' +
    '  return res;\n' +
    '}';
}

