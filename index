// Write a minimal Shapefile ZIP (.shp + .shx + .dbf + .prj) and trigger download
function downloadShapefile_() {
  if (!roi) { alert('Draw or upload an ROI first.'); return }

  var rings = roi.type === 'MultiPolygon'
    ? roi.coordinates.map(function (p) { return p[0] })
    : [roi.coordinates[0]]

  var bb = geomBbox_(roi)
  var minX = bb[0], minY = bb[1], maxX = bb[2], maxY = bb[3]

  var numParts  = rings.length
  var numPoints = rings.reduce(function (s, r) { return s + r.length }, 0)

  // SHP record content size (bytes)
  var contentBytes = 4 + 32 + 4 + 4 + numParts * 4 + numPoints * 16
  var contentWords = contentBytes / 2
  var fileLenWords = (100 + 8 + contentBytes) / 2

  // ── SHP ──────────────────────────────────────────────────────
  var shpBuf = new ArrayBuffer(100 + 8 + contentBytes)
  var s = new DataView(shpBuf)
  s.setInt32(0, 9994, false)                       // file code
  s.setInt32(24, fileLenWords, false)              // file length (16-bit words, big-endian)
  s.setInt32(28, 1000, true)                       // version
  s.setInt32(32, 5, true)                          // shape type: Polygon
  s.setFloat64(36, minX, true); s.setFloat64(44, minY, true)
  s.setFloat64(52, maxX, true); s.setFloat64(60, maxY, true)
  s.setInt32(100, 1, false)                        // record number
  s.setInt32(104, contentWords, false)             // content length
  var o = 108
  s.setInt32(o, 5, true); o += 4                   // shape type
  s.setFloat64(o, minX, true); o += 8; s.setFloat64(o, minY, true); o += 8
  s.setFloat64(o, maxX, true); o += 8; s.setFloat64(o, maxY, true); o += 8
  s.setInt32(o, numParts, true);  o += 4
  s.setInt32(o, numPoints, true); o += 4
  var ptOff = 0
  rings.forEach(function (r) { s.setInt32(o, ptOff, true); o += 4; ptOff += r.length })
  rings.forEach(function (r) { r.forEach(function (pt) {
    s.setFloat64(o, pt[0], true); o += 8
    s.setFloat64(o, pt[1], true); o += 8
  }) })

  // ── SHX ──────────────────────────────────────────────────────
  var shxBuf = new ArrayBuffer(108)
  var x = new DataView(shxBuf)
  x.setInt32(0, 9994, false); x.setInt32(24, 54, false)
  x.setInt32(28, 1000, true); x.setInt32(32, 5, true)
  x.setFloat64(36, minX, true); x.setFloat64(44, minY, true)
  x.setFloat64(52, maxX, true); x.setFloat64(60, maxY, true)
  x.setInt32(100, 50, false)          // record offset in 16-bit words
  x.setInt32(104, contentWords, false)

  // ── PRJ (WGS84) ───────────────────────────────────────────────
  var prj = 'GEOGCS["GCS_WGS_1984",DATUM["D_WGS_1984",SPHEROID["WGS_1984",6378137.0,298.257223563]],PRIMEM["Greenwich",0.0],UNIT["Degree",0.0174532925199433]]'

  // ── DBF (1 record, field "ID"=1) ──────────────────────────────
  var dbfBuf = new ArrayBuffer(65 + 11)   // header(32) + field(32) + term(1) + record(11)
  var d = new DataView(dbfBuf)
  var db = new Uint8Array(dbfBuf)
  d.setUint8(0, 3)   // dBASE III+ without memo file
  d.setUint8(1, 26)  // last update year (2026 → 26)
  d.setUint8(2, 3)   // last update month
  d.setUint8(3, 28)  // last update day
  d.setInt32(4, 1, true)    // number of records
  d.setInt16(8, 65, true)   // header size in bytes (32 + 1×32 + 1 terminator)
  d.setInt16(10, 11, true)  // record size in bytes (1 deletion flag + 10-char ID)
  // Field descriptor for field "ID" (numeric, 10 chars wide)
  db[32] = 73; db[33] = 68  // field name bytes: 'I' = 73, 'D' = 68
  db[43] = 78               // field type: 'N' = 78 (numeric)
  db[48] = 10               // field length: 10 characters
  db[64] = 0x0D             // header terminator (carriage return)
  db[65] = 0x20             // deletion flag: 0x20 = not deleted
  db[66] = 49               // ID value: '1' = ASCII 49
  for (var i = 67; i < 76; i++) db[i] = 32  // right-pad with spaces (ASCII 32)

  // ── ZIP ───────────────────────────────────────────────────────
  var fn = getRoiFilename_()
  var zip = new JSZip()
  zip.file(fn + '.shp', shpBuf)
  zip.file(fn + '.shx', shxBuf)
  zip.file(fn + '.dbf', dbfBuf)
  zip.file(fn + '.prj', prj)
  zip.generateAsync({ type: 'blob' }).then(function (blob) {
    var a = document.createElement('a')
    a.href = URL.createObjectURL(blob)
    a.download = fn + '.zip'
    a.click()
  })
}

