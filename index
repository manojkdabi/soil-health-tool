function buildFsZoneAreaTable_(zoneStat) {
  var tbl        = document.getElementById('results-fs-table')
  var totalHa    = roi ? computeAreaHa_(roi) : 0
  var totalPx    = zoneStat.reduce(function(s, z) { return s + (z.pixel_count || 0) }, 0)
  // Fewer than this many bare-soil pixels makes area estimation unreliable; use equal 20% split instead
  var MIN_PX_FOR_AREA = 5
  var useEqual   = totalPx < MIN_PX_FOR_AREA

  var html = '<tr><th style="padding:4px 6px">Zone</th>' +
             '<th style="padding:4px 6px;text-align:right">Area (ha)</th>' +
             '<th style="padding:4px 6px;text-align:right">% of ROI</th></tr>'

  zoneStat.forEach(function(z, i) {
    var pct = useEqual ? 20 : (totalPx > 0 ? z.pixel_count / totalPx * 100 : 20)
    var ha  = totalHa * pct / 100
    html += '<tr>' +
      '<td style="padding:4px 6px">' +
        '<span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:' + ZONE_COLORS[i] + ';margin-right:5px;vertical-align:middle"></span>' +
        z.label + '</td>' +
      '<td style="padding:4px 6px;text-align:right;color:#F5A623">' + Math.round(ha) + '</td>' +
      '<td style="padding:4px 6px;text-align:right;color:#9FE1CB">' + pct.toFixed(1) + '%</td>' +
      '</tr>'
  })

  tbl.innerHTML = html
}

