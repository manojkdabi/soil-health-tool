function openChartFs_(id) {
  var src = _getChartInstance(id)
  if (!src) return
  var overlay = document.getElementById('chartFs-' + id)
  if (!overlay) return
  // Sync tab state for cmpScatterChart
  if (id === 'cmpScatterChart') {
    var isZones = cmpScatterMode === 'zones'
    document.getElementById('cmpTabZones-fs').classList.toggle('active', isZones)
    document.getElementById('cmpTabSummary-fs').classList.toggle('active', !isZones)
    var lbl = document.getElementById('cmpScatterLabel')
    var lblFs = document.getElementById('cmpScatterLabel-fs')
    if (lblFs && lbl) lblFs.textContent = lbl.textContent
  }
  if (id === 'shpiCpiScatter') {
    var eq = document.getElementById('scatterEq')
    var eqFs = document.getElementById('scatterEq-fs')
    if (eqFs && eq) eqFs.textContent = eq.textContent
  }
  // Destroy previous FS instance for this chart
  if (chartFsInstances[id]) { chartFsInstances[id].destroy(); chartFsInstances[id] = null }
  // Show overlay first so the canvas has a valid size when Chart.js measures it
  overlay.classList.add('open')
  var canvas = document.getElementById(id + '-fs')
  if (!canvas) return
  // Build enlarged scale options (each axis gets its own shallow copy)
  var srcScales = src.config.options && src.config.options.scales || {}
  var fsScales = {}
  Object.keys(srcScales).forEach(function(k) {
    var ax = srcScales[k]
    fsScales[k] = Object.assign({}, ax, {
      ticks: Object.assign({}, ax.ticks, { font: Object.assign({}, (ax.ticks && ax.ticks.font) || {}, { size: 13 }) }),
      title: ax.title ? Object.assign({}, ax.title, { font: Object.assign({}, (ax.title && ax.title.font) || {}, { size: 13 }) }) : ax.title
    })
  })
  var srcPlugins = (src.config.options && src.config.options.plugins) || {}
  var fsPlugins = Object.assign({}, srcPlugins)
  if (fsPlugins.legend) {
    fsPlugins.legend = Object.assign({}, fsPlugins.legend, {
      labels: Object.assign({}, fsPlugins.legend.labels, { font: Object.assign({}, (fsPlugins.legend.labels && fsPlugins.legend.labels.font) || {}, { size: 12 }) })
    })
  }
  var fsOptions = Object.assign({}, src.config.options, {
    responsive: true,
    maintainAspectRatio: false,
    scales: Object.keys(fsScales).length ? fsScales : srcScales,
    plugins: fsPlugins
  })
  // Use requestAnimationFrame so the overlay is painted and canvas dimensions are set before Chart.js renders
  requestAnimationFrame(function() {
    chartFsInstances[id] = new Chart(canvas.getContext('2d'), {
      type: src.config.type,
      data: src.config.data,
      options: fsOptions
    })
  })
}

function closeChartFs_(id) {
  var overlay = document.getElementById('chartFs-' + id)
  if (overlay) overlay.classList.remove('open')
  if (chartFsInstances[id]) { chartFsInstances[id].destroy(); chartFsInstances[id] = null }
}

