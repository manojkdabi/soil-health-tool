    renderCompareView_()
  } else {
    section.classList.remove('show')
  }
}

function renderCompareView_() {
  var rois  = loadROIsWithResults_()
  if (rois.length < 2) return
  var cache = loadResultsCache_()
  renderCmpScatterChart_(rois, cache)
}

function setScatterViewMode_(mode) {
