        bounds,
        { opacity: opacityFs }
      ).addTo(resultsMapFs)
    } else {
      renderIdwHeatmap_(resultsMapFs, data.zone_stats, minLng, minLat, maxLng, maxLat)
    }

    L.geoJSON(roi, {
      style: { color: '#F5A623', weight: 2, fillOpacity: 0, dashArray: '4 3' }
    }).addTo(resultsMapFs)

    resultsMapFs.fitBounds(bounds, { padding: [20, 20] })

    // Build zone area table
    buildFsZoneAreaTable_(data.zone_stats)
  }
  // Initialise the swipe/curtain handle
  initSwipeHandle_()
}

// ── Swipe curtain for fullscreen zone map ─────────────────────
function initSwipeHandle_() {
  var container = document.getElementById('results-fs-container')
  var mapEl     = document.getElementById('results-fs-map')
  var handle    = document.getElementById('fs-swipe-handle')
  if (!handle) return
  if (!resultsRasterLayerFs) { handle.style.display = 'none'; return }

  // Position handle at 50% width initially
  var w = mapEl.offsetWidth || window.innerWidth
  handle.style.left = (w / 2) + 'px'
  handle.style.display = 'block'
  updateSwipeClip_(w / 2)

  // Remove any previous listeners by replacing the handle with a clone
  var newHandle = handle.cloneNode(true)
  handle.parentNode.replaceChild(newHandle, handle)
  handle = newHandle

  var dragging = false
  function onDragStart(e) { dragging = true; e.preventDefault(); e.stopPropagation() }
  function onDragMove(e) {
    if (!dragging) return
    var rect = mapEl.getBoundingClientRect()
    var clientX = e.touches ? e.touches[0].clientX : e.clientX
    var x = Math.max(0, Math.min(clientX - rect.left, rect.width))
    handle.style.left = x + 'px'
    updateSwipeClip_(x)
    if (e.touches) e.preventDefault()
  }
  function onDragEnd() { dragging = false }

  handle.addEventListener('mousedown', onDragStart)
  container.addEventListener('mousemove', onDragMove)
  container.addEventListener('mouseup', onDragEnd)
  container.addEventListener('mouseleave', onDragEnd)
  handle.addEventListener('touchstart', onDragStart, { passive: false })
  container.addEventListener('touchmove', onDragMove, { passive: false })
  container.addEventListener('touchend', onDragEnd)
}

function updateSwipeClip_(xPos) {
  if (!resultsRasterLayerFs) return
  var img = resultsRasterLayerFs._image
  if (!img) return
  var mapEl = document.getElementById('results-fs-map')
  var w = mapEl ? mapEl.offsetWidth || window.innerWidth : window.innerWidth
  // Clip right-side percentage = (map width - handle x) / map width
  // so the raster is fully visible left of the handle and hidden right of it
  var pct = ((w - xPos) / w * 100).toFixed(2)
  img.style.clipPath = 'inset(0 ' + pct + '% 0 0)'
}

// ── Switch the fullscreen map overlay between Zones / SHPI / CPI ──────────────
function switchFsLayer_(layerName) {
  if (!resultsMapFs || !lastResult || !roi) return
  currentFsLayer = layerName

  var data   = lastResult
  var bb     = geomBbox_(roi)
  var bounds = [[bb[1], bb[0]], [bb[3], bb[2]]]

  // Pick the correct base64 PNG
  var b64
  if      (layerName === 'shpi') b64 = data.shpi_png_b64
  else if (layerName === 'cpi')  b64 = data.cpi_png_b64
  else                           b64 = data.raster_png_b64

  // Remove old overlay
  if (resultsRasterLayerFs) {
    resultsMapFs.removeLayer(resultsRasterLayerFs)
    resultsRasterLayerFs = null
  }

  if (b64) {
    var opacityFs = (document.getElementById('rasterOpacityFs').value || 80) / 100
    resultsRasterLayerFs = L.imageOverlay(
      'data:image/png;base64,' + b64,
      bounds,
      { opacity: opacityFs }
    ).addTo(resultsMapFs)
  }

  // Toggle panel sections
  document.getElementById('fs-panel-zones').style.display = layerName === 'zones' ? '' : 'none'
  document.getElementById('fs-panel-shpi').style.display  = layerName === 'shpi'  ? '' : 'none'
  document.getElementById('fs-panel-cpi').style.display   = layerName === 'cpi'   ? '' : 'none'

  // Re-initialise swipe handle for the new layer
  initSwipeHandle_()
}

function buildFsZoneAreaTable_(zoneStat) {
  var tbl        = document.getElementById('results-fs-table')
  var totalHa    = roi ? computeAreaHa_(roi) : 0
  var totalPx    = zoneStat.reduce(function(s, z) { return s + (z.pixel_count || 0) }, 0)
  // Fewer than this many bare-soil pixels makes area estimation unreliable; use equal 20% split instead
  var MIN_PX_FOR_AREA = 5
  var useEqual   = totalPx < MIN_PX_FOR_AREA

  var html = '<tr><th style="padding:4px 6px">Zone</th>' +
             '<th style="padding:4px 6px;text-align:right">Area (ha)</th>' +
             '<th style="padding:4px 6px;text-align:right">% of ROI</th></tr>'

  zoneStat.forEach(function(z, i) {
    var pct = useEqual ? 20 : (totalPx > 0 ? z.pixel_count / totalPx * 100 : 20)
    var ha  = totalHa * pct / 100
    html += '<tr>' +
      '<td style="padding:4px 6px">' +
        '<span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:' + ZONE_COLORS[i] + ';margin-right:5px;vertical-align:middle"></span>' +
        z.label + '</td>' +
      '<td style="padding:4px 6px;text-align:right;color:#F5A623">' + Math.round(ha) + '</td>' +
      '<td style="padding:4px 6px;text-align:right;color:#9FE1CB">' + pct.toFixed(1) + '%</td>' +
      '</tr>'
  })

  tbl.innerHTML = html
}

