// ── D1: Soil TS — fetch from Process API (biweekly loop) ──────
function fetchSoilTimeSeries_() {
  if (!roi) { alert('Draw or upload an ROI first.'); return }
  const yearStart = parseInt(document.getElementById('yearStart').value, 10)
  const yearEnd   = parseInt(document.getElementById('yearEnd').value, 10)
  if (isNaN(yearStart) || isNaN(yearEnd)) { alert('Set a valid year range first.'); return }
  const btn = document.getElementById('soilFetchBtn')
  btn.disabled    = true
  btn.textContent = '⏳ Fetching...'
  document.getElementById('soilChartLabel').textContent = ''
  google.script.run
    .withSuccessHandler(async function(data) {
      btn.disabled    = false
      btn.textContent = '📡 Fetch Soil Series'
      if (!data.success) {
        document.getElementById('soilChartLabel').textContent = '⚠ ' + data.error
        return
      }
      const decoded = await Promise.all(data.windows.map(async w => {
        const v = await decodeSoilTsWindowPng_(w.img64)
        return v ? Object.assign({ date: w.date }, v) : null
      }))
      soilTsData = decoded.filter(Boolean)
      if (soilTsData.length === 0) {
        document.getElementById('soilChartLabel').textContent =
          '⚠ No valid bare-soil observations found in any window.'
        return
      }
      document.getElementById('soilIndexBtns').style.display = 'block'
      document.getElementById('soilViewBtns').style.display = 'block'
      document.getElementById('soilChartWrap').style.display = 'block'
      renderSoilTsChart_(soilCurIndex)
      const soilYears = Array.from(new Set(soilTsData.map(d => d.date.substring(0, 4)))).sort()
      buildSoilYearCheckboxes_(soilYears)
    })
    .withFailureHandler(function(err) {
      btn.disabled    = false
      btn.textContent = '📡 Fetch Soil Series'
      document.getElementById('soilChartLabel').textContent = '⚠ ' + err.message
    })
    .getSoilTimeSeries({ geojson: roi, yearStart, yearEnd })
}
function renderSoilTsChart_(indexKey) {
  if (!soilTsData || !soilTsData.length) return
  if (soilTsChart) { soilTsChart.destroy(); soilTsChart = null }
  if (soilTsViewMode === 'season') {
    renderSoilTsChartSeason_(indexKey)
  } else {
    renderSoilTsChartTimeline_(indexKey)
  }
}

// D1: Soil TS timeline mode
function renderSoilTsChartTimeline_(indexKey) {
  const labelMap = { sab: 'SAB (Brightness)', claysi: 'ClaySI', ri2: 'RI2 (Redness)', smi: 'SMI (Moisture)' }
  const labels   = soilTsData.map(d => d.date)
  const rawVals  = soilTsData.map(d => (d[indexKey] != null ? d[indexKey] : null))
  const dense    = rawVals.slice()
  for (let i = 0; i < dense.length; i++) {
    if (dense[i] === null) {
      const prev = dense.slice(0, i).reverse().find(v => v !== null) ?? null
      const next = dense.slice(i + 1).find(v => v !== null) ?? null
      dense[i] = prev !== null && next !== null ? (prev + next) / 2 : (prev ?? next ?? null)
    }
  }
  const smoothed = gaussianSmooth_(dense, 1.2)
  const ctx = document.getElementById('soilTsChart').getContext('2d')
  soilTsChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: labelMap[indexKey] || indexKey,
          data: rawVals,
          borderColor: 'rgba(205,133,63,0.65)',
          borderWidth: 1.2,
          pointBackgroundColor: 'rgba(205,133,63,0.45)',
          pointRadius: 2,
          pointHoverRadius: 6,
          fill: false,
          tension: 0.3,
          spanGaps: true
        },
        {
          label: 'Smoothed',
          data: smoothed.map(v => v !== null ? Math.round(v * 1000) / 1000 : null),
          borderColor: '#cd853f',
          borderWidth: 1.8,
          pointRadius: 0,
          fill: false,
          tension: 0.4,
          spanGaps: true
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            title: items => items[0].label,
            label: item => (item.datasetIndex === 0
              ? (labelMap[indexKey] || indexKey) + ': ' + item.raw
              : 'Smoothed: ' + item.raw)
          }
        }
      },
      scales: {
        x: { ticks: { color: '#9FE1CB', font: { size: 7 }, maxRotation: 45, minRotation: 30, maxTicksLimit: 10 }, grid: { color: 'rgba(255,255,255,0.07)' } },
        y: { ticks: { color: '#9FE1CB', font: { size: 8 } }, grid: { color: 'rgba(255,255,255,0.07)' } }
      }
    }
  })
  document.getElementById('soilChartLabel').textContent =
    (labelMap[indexKey] || indexKey) + ' — ' + soilTsData.length + ' bare-soil windows'
}

// D1: Soil TS season (DOY overlay) mode
function renderSoilTsChartSeason_(indexKey) {
  const labelMap = { sab: 'SAB', claysi: 'ClaySI', ri2: 'RI2', smi: 'SMI' }
  const allYears = Array.from(new Set(soilTsData.map(d => d.date.substring(0, 4)))).sort()
  const years = soilSelectedYears && soilSelectedYears.size > 0
    ? allYears.filter(y => soilSelectedYears.has(y))
    : allYears
  const yearPalette = ['#cd853f','#d4a56a','#b8860b','#daa520','#c68e3a','#e8b96a','#a0522d','#8b6914']

  const byYear = {}
  soilTsData.forEach(function(d) {
    const yr = d.date.substring(0, 4)
    if (!byYear[yr]) byYear[yr] = []
    byYear[yr].push({ doy: dateToDoy_(d.date), val: d[indexKey] })
  })

  const datasets = years.map(function(yr, i) {
    const col = yearPalette[i % yearPalette.length]
    const pts = (byYear[yr] || [])
      .filter(p => p.val != null)
      .sort((a, b) => a.doy - b.doy)
      .map(p => ({ x: p.doy, y: Math.round(p.val * 1000) / 1000 }))
    return {
      type: 'scatter', label: yr, data: pts,
      borderColor: col, backgroundColor: col,
      pointRadius: 3, pointHoverRadius: 6,
      showLine: true, borderWidth: 1.4,
      fill: false, tension: 0.3, spanGaps: false
    }
  })

  // Mean line
  const buckets = {}
  years.forEach(function(yr) {
    ;(byYear[yr] || []).forEach(function(p) {
      if (p.val == null) return
      const bkt = Math.round(p.doy / 14) * 14
      if (!buckets[bkt]) buckets[bkt] = []
      buckets[bkt].push(p.val)
    })
  })
  const meanPts = Object.keys(buckets).map(Number).sort((a, b) => a - b)
    .map(doy => {
      const vals = buckets[doy]
      return { x: doy, y: Math.round(vals.reduce((a, b) => a + b, 0) / vals.length * 1000) / 1000 }
    })
  datasets.push({
    type: 'line', label: 'Mean', data: meanPts,
    borderColor: '#cd853f', backgroundColor: 'transparent',
    borderWidth: 2.5, pointRadius: 0, fill: false, tension: 0.4, spanGaps: true
  })

  const MONTH_DOYS   = [1, 32, 60, 91, 121, 152, 182, 213, 244, 274, 305, 335]
  const MONTH_LABELS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']

  const ctx = document.getElementById('soilTsChart').getContext('2d')
  soilTsChart = new Chart(ctx, {
    data: { datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: true, position: 'bottom', labels: { color: '#9FE1CB', font: { size: 8 }, boxWidth: 8, padding: 4 } },
        tooltip: {
          callbacks: {
            title: items => {
              const doy = items[0].raw.x
              const ref = new Date(new Date(2001, 0, 1).getTime() + (doy - 1) * 86400000)
              return 'DOY ' + doy + ' (~' + ref.toLocaleDateString('en', { month: 'short', day: 'numeric' }) + ')'
            },
            label: item => item.dataset.label + ':  ' + (labelMap[indexKey] || indexKey) + ' = ' + item.raw.y
          }
        }
      },
      scales: {
        x: {
          type: 'linear', min: 1, max: 365,
          title: { display: true, text: 'Day of year', color: '#9FE1CB', font: { size: 8 } },
          afterBuildTicks: axis => { axis.ticks = MONTH_DOYS.map(v => ({ value: v })) },
          ticks: {
            color: '#9FE1CB', font: { size: 7 }, maxRotation: 0, minRotation: 0,
            callback: val => { const i = MONTH_DOYS.indexOf(val); return i >= 0 ? MONTH_LABELS[i] : '' }
          },
          grid: { color: 'rgba(255,255,255,0.07)' }
        },
        y: { ticks: { color: '#9FE1CB', font: { size: 8 } }, grid: { color: 'rgba(255,255,255,0.07)' } }
      }
    }
  })
  document.getElementById('soilChartLabel').textContent =
    'Bare-soil seasons overlaid — ' + years.length + ' year' + (years.length > 1 ? 's' : '') +
    ' (' + years.join(', ') + ')  |  brown line = mean'
}

