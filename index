  // Chart
  if (chart) chart.destroy()
  const ctx = document.getElementById('cpiChart').getContext('2d')
  chart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels:   z.map(zs => 'Z' + zs.zone),
