function runAnalysis() {
  if (!roi) { alert('Draw or upload an ROI first.'); return }

  const yearStart    = parseInt(document.getElementById('yearStart').value, 10)
  const yearEnd      = parseInt(document.getElementById('yearEnd').value, 10)
  const resolution   = parseInt(document.getElementById('resolution').value, 10)
    const currentYear = new Date().getFullYear()
  if (isNaN(yearStart) || isNaN(yearEnd)) { alert('Year start and end must be valid numbers.'); return }
  if (yearStart < 2015 || yearEnd > currentYear) { alert('Years must be between 2015 and ' + currentYear + '.'); return }
  if (yearEnd <= yearStart) { alert('Year end must be after year start.'); return }
  if (isNaN(resolution) || resolution < 10 || resolution > 1000) { alert('Resolution must be between 10 and 1000 metres.'); return }

  showOverlay(true, 'Fetching satellite archive (all months, all years)...')
  setProgress(true, 10, 'Fetching satellite archive (all months, all years)...')
  document.getElementById('runBtn').disabled = true
  document.getElementById('results').classList.remove('show')

  const params = { geojson: roi, yearStart, yearEnd, resolution }

  // Progress animation
  let pct = 10
  const timer = setInterval(() => {
    pct = Math.min(pct + 4, 88)
    const msgs = [
      'Fetching satellite archive (all months, all years)...',
      'Computing bare soil composite per pixel...',
      'Computing crop performance per pixel...',
      'Decoding SHPI and CPI raster...',
      'Classifying zones and computing statistics...',
      'Running validation...',
    ]
    const idx = Math.min(Math.floor((pct - 10) / 13), msgs.length - 1)
    setProgress(true, pct, msgs[idx])
    showOverlay(true, msgs[idx])
  }, 3000)

  // Call Apps Script server function
  google.script.run
    .withSuccessHandler(data => {
      clearInterval(timer)
      setProgress(true, 95, 'Decoding SHPI and CPI raster...')
      showOverlay(true, 'Decoding SHPI and CPI raster...')
      document.getElementById('runBtn').disabled = false
      if (data.success) {
        decodeRasterAndAnalyse_(data)
      } else {
        setProgress(false)
        showOverlay(false)
        alert('Analysis failed: ' + data.error)
      }
    })
    .withFailureHandler(err => {
      clearInterval(timer)
      showOverlay(false)
      setProgress(false)
      document.getElementById('runBtn').disabled = false
      alert('Error: ' + err.message)
    })
    .runAnalysis(params)
}

// K-means clustering (1D, sorted centroids) — used for supplementary SHPI zoning analytics.
// vals: array of numbers; k: number of clusters; maxIter: iteration limit.
// Returns { assignments: number[], centroids: number[] } with clusters sorted by mean (0=lowest).
function kMeans_(vals, k, maxIter) {
  var n = vals.length
  if (n < k) return { assignments: vals.map(function(_, i) { return i % k }), centroids: [] }
  maxIter = maxIter || 50
  // Initialise centroids evenly across sorted range
  var sorted = vals.slice().sort(function(a, b) { return a - b })
  var step = Math.floor(n / k)
  var centroids = []
  for (var ci = 0; ci < k; ci++) {
    centroids.push(sorted[Math.min(Math.round((ci + 0.5) * step), n - 1)])
  }
  var assignments = new Array(n).fill(0)
  for (var iter = 0; iter < maxIter; iter++) {
    var changed = false
    // Assignment step: each value goes to nearest centroid
    for (var i = 0; i < n; i++) {
      var best = 0, bestD = Math.abs(vals[i] - centroids[0])
      for (var c = 1; c < k; c++) {
        var d = Math.abs(vals[i] - centroids[c])
        if (d < bestD) { bestD = d; best = c }
      }
      if (assignments[i] !== best) { assignments[i] = best; changed = true }
    }
    if (!changed) break
    // Update step: recompute centroid means
    var sums = new Array(k).fill(0), counts = new Array(k).fill(0)
    for (var i = 0; i < n; i++) { sums[assignments[i]] += vals[i]; counts[assignments[i]]++ }
    for (var c = 0; c < k; c++) { if (counts[c] > 0) centroids[c] = sums[c] / counts[c] }
  }
  // Remap cluster labels so cluster 0 = lowest mean SHPI
  var order = centroids.map(function(v, i) { return [v, i] })
    .sort(function(a, b) { return a[0] - b[0] })
  var remap = new Array(k)
  order.forEach(function(pair, newIdx) { remap[pair[1]] = newIdx })
  return {
    assignments: assignments.map(function(c) { return remap[c] }),
    centroids:   order.map(function(pair) { return Math.round(pair[0] * 1000) / 1000 })
  }
}

// Shared pixel-decoding helper — calls callback(result) when done, callback(null) on error.
// Does NOT update any UI. Used by both single-run and batch-run paths.
function decodeRasterToResult_(rawData, callback) {
  var img = new Image()
  img.onerror = function(e) { console.error('decodeRasterToResult_: image load error', e); callback(null) }
  img.onload = function() {
    var W = img.naturalWidth, H = img.naturalHeight
    var canvas = document.createElement('canvas')
    canvas.width = W; canvas.height = H
    var ctx = canvas.getContext('2d')
    ctx.drawImage(img, 0, 0)
    var pixels = ctx.getImageData(0, 0, W, H).data

    // Build a per-pixel polygon mask if bbox + geojson are available.
    // The Process API returns a bbox-clipped rectangle; pixels outside the
    // actual ROI polygon boundary are excluded to avoid contamination.
    var polyMask = null
    var bb = rawData.bbox  // [minLng, minLat, maxLng, maxLat]
    var roiGeom = rawData.geojson  // polygon geometry passed through from caller
    if (bb && roiGeom) {
      var lngRange = bb[2] - bb[0], latRange = bb[3] - bb[1]
      if (lngRange > 0 && latRange > 0) {
        polyMask = new Uint8Array(W * H)  // 1=inside polygon, 0=outside
        for (var mi = 0; mi < W * H; mi++) {
          var col = mi % W, row = Math.floor(mi / W)
          var lng = bb[0] + (col + 0.5) / W * lngRange
          var lat = bb[3] - (row + 0.5) / H * latRange  // row 0 = north (maxLat)
          polyMask[mi] = pointInPolygon_(lng, lat, roiGeom) ? 1 : 0
        }
      }
    }

    var shpiPixels = [], cpiPixels = [], pixelPairs = []
    var zoneMap = new Array(W * H).fill(0)  // zone assignment per pixel (0=invalid)

    // D4: pixel count tracking for ROI clip verification
    var bboxCount  = W * H
    var polyCount  = 0  // pixels inside polygon (or bbox if no mask)

    for (var i = 0; i < W * H; i++) {
      if (polyMask && !polyMask[i]) continue  // outside ROI polygon
      polyCount++
      var R = pixels[i * 4]     // SHPI × 254  (valid when B > 0)
      var G = pixels[i * 4 + 1] // CPI  × 254  (valid when A > 0)
      var B = pixels[i * 4 + 2] // soil observation count  (0 = no bare-soil obs)
      var A = pixels[i * 4 + 3] // crop observation count  (0 = no crop obs)
      if (B === 0 && A === 0) continue  // completely invalid / nodata pixel
      var shpi = B > 0 ? R / 254 : null  // SHPI valid only if soil obs present
      var cpi  = A > 0 ? G / 254 : null  // CPI  valid only if crop obs present
      if (shpi !== null) shpiPixels.push({ idx: i, val: shpi })
      if (cpi  !== null) cpiPixels.push({ idx: i, val: cpi })
      if (shpi !== null && cpi !== null) pixelPairs.push({ idx: i, shpi: shpi, cpi: cpi })
    }
    // If no polyMask was built (no valid bbox/geojson), all bbox pixels are inside
    if (!polyMask) polyCount = bboxCount

    // Compute SHPI percentile thresholds from ALL valid SHPI pixels
    var shpiSorted = shpiPixels.map(function(p) { return p.val }).sort(function(a,b) { return a-b })
    var thresholds
    if (shpiSorted.length >= 10) {
      thresholds = [10,20,30,40,50,60,70,80,90].map(function(pct) { return percentile_(shpiSorted, pct) })
    } else {
      thresholds = [0.10,0.20,0.30,0.40,0.50,0.60,0.70,0.80,0.90]
    }
    var p10=thresholds[0], p20=thresholds[1], p30=thresholds[2], p40=thresholds[3],
        p50=thresholds[4], p60=thresholds[5], p70=thresholds[6], p80=thresholds[7], p90=thresholds[8]

    function assignZone_(v) {
      if (v < p10) return 1; if (v < p20) return 2; if (v < p30) return 3
      if (v < p40) return 4; if (v < p50) return 5; if (v < p60) return 6
      if (v < p70) return 7; if (v < p80) return 8; if (v < p90) return 9
      return 10
    }

    // Assign zones to ALL valid SHPI pixels (for display raster)
    shpiPixels.forEach(function(p) {
      zoneMap[p.idx] = assignZone_(p.val)
    })

    // Zone stats from pixelPairs (pixels with BOTH SHPI and CPI)
    var zones = [[],[],[],[],[],[],[],[],[],[]]
    pixelPairs.forEach(function(p) {
      zones[assignZone_(p.shpi) - 1].push(p)
    })

    function mean_(arr, key) {
      if (!arr.length) return 0
      return arr.reduce(function(s, p) { return s + p[key] }, 0) / arr.length
    }
    function std_(arr, key, m) {
      if (arr.length < 2) return 0
      var variance = arr.reduce(function(s, p) { return s + (p[key] - m) * (p[key] - m) }, 0) / arr.length
      return Math.sqrt(variance)
    }

    var zoneStats = zones.map(function(zPairs, idx) {
      var ms = mean_(zPairs, 'shpi'), mn = mean_(zPairs, 'cpi')
      var ss = std_(zPairs, 'shpi', ms), sn = std_(zPairs, 'cpi', mn)
      return {
        zone:        idx + 1,
        label:       'Zone ' + (idx + 1),
        pixel_count: zPairs.length,
        mean_shpi:   Math.round(ms * 1000) / 1000,
        std_shpi:    Math.round(ss * 1000) / 1000,
        cv_shpi:     Math.round((ms > 0 ? ss / ms : 0) * 1000) / 1000,
        mean_cpi:    Math.round(mn * 1000) / 1000,
        std_cpi:     Math.round(sn * 1000) / 1000,
        cv_cpi:      Math.round((mn > 0 ? sn / mn : 0) * 1000) / 1000,
        data_source: 'real'
      }
    })

    // Build a pixel-level sample (up to 2000 pts) for the scatter plot
    var MAX_SCATTER_PX = 2000
    var pixelSample = []
    if (pixelPairs.length > 0) {
      var step = Math.max(1, Math.floor(pixelPairs.length / MAX_SCATTER_PX))
      for (var ki = 0; ki < pixelPairs.length; ki += step) {
        var pp = pixelPairs[ki]
        var pz = assignZone_(pp.shpi) - 1
        pixelSample.push({ x: pp.shpi, y: pp.cpi, z: pz })
      }
    }

    // Build a sampled SHPI-pixel array (with pixel index) for season CPI pairing (Stage 2).
    // Samples ALL valid SHPI pixels (not just those with CPI) so that season scatter can
    // pair each SHPI position with its season-specific CPI from the season raster.
    var shpiSample = []
    if (shpiPixels.length > 0) {
      var shpiStep = Math.max(1, Math.floor(shpiPixels.length / MAX_SCATTER_PX))
      for (var si = 0; si < shpiPixels.length; si += shpiStep) {
        var sp = shpiPixels[si]
        shpiSample.push({ idx: sp.idx, x: sp.val, z: assignZone_(sp.val) - 1 })
      }
    }

    // Spearman ρ on zone means — the meaningful signal (matches scatter plot logic)
    var zoneMeanShpi = zoneStats.map(function(zs) { return zs.mean_shpi })
    var zoneMeanCpi  = zoneStats.map(function(zs) { return zs.mean_cpi })
    function rankAvgVal_(arr) {
      var sorted = arr.slice().sort(function(a, b) { return a - b })
      return arr.map(function(v) {
        var idx = []
        sorted.forEach(function(s, i) { if (s === v) idx.push(i + 1) })
        return idx.reduce(function(a, b) { return a + b }, 0) / idx.length
      })
    }
    var rxz = rankAvgVal_(zoneMeanShpi), ryz = rankAvgVal_(zoneMeanCpi)
    var nz  = rxz.length
    var rmxz = rxz.reduce(function(a, b) { return a + b }, 0) / nz
    var rmyz = ryz.reduce(function(a, b) { return a + b }, 0) / nz
    var rNumZ = rxz.reduce(function(a, v, i) { return a + (v - rmxz) * (ryz[i] - rmyz) }, 0)
    var rdxZ  = Math.sqrt(rxz.reduce(function(a, v) { return a + (v - rmxz) * (v - rmxz) }, 0))
    var rdyZ  = Math.sqrt(ryz.reduce(function(a, v) { return a + (v - rmyz) * (v - rmyz) }, 0))
    var rho = (rdxZ * rdyZ > 0) ? rNumZ / (rdxZ * rdyZ) : 0
    rho = Math.round(rho * 1000) / 1000
    var rho_r2 = Math.round(rho * rho * 1000) / 1000

    // mono / ratio describe the ordinal zone pattern
    var mono  = zoneMeanCpi.every(function(v, i) { return i === 0 || v >= zoneMeanCpi[i - 1] })
    var ratio = zoneMeanCpi[0] > 0.01 ? Math.round(zoneMeanCpi[9] / zoneMeanCpi[0] * 100) / 100 : null

    // K-means k=5 clustering on SHPI pixel values (supplementary analytics)
    var kmeans5 = null
    if (shpiPixels.length >= 5) {
      var shpiVals = shpiPixels.map(function(p) { return p.val })
      var km = kMeans_(shpiVals, 5, 50)
      var km5bins = [[],[],[],[],[]]
      shpiPixels.forEach(function(p, i) { km5bins[km.assignments[i]].push(p.val) })
      kmeans5 = {
        centroids: km.centroids,
        zones: km5bins.map(function(vals, ci) {
          var m = vals.length ? vals.reduce(function(s, v) { return s + v }, 0) / vals.length : 0
          var sd2 = vals.length > 1 ? Math.sqrt(vals.reduce(function(s, v) { return s + (v-m)*(v-m) }, 0) / vals.length) : 0
          return { cluster: ci + 1, count: vals.length,
            mean_shpi: Math.round(m * 1000) / 1000,
            std_shpi:  Math.round(sd2 * 1000) / 1000,
            cv_shpi:   Math.round((m > 0 ? sd2 / m : 0) * 1000) / 1000 }
        })
      }
    }

    // Generate display rasters using offscreen canvases
    var dispCanvas = document.createElement('canvas')
    dispCanvas.width = W; dispCanvas.height = H
    var dctx = dispCanvas.getContext('2d')
    var dispData = dctx.createImageData(W, H)
    var dd = dispData.data

    var shpiCanvas = document.createElement('canvas')
    shpiCanvas.width = W; shpiCanvas.height = H
    var sctx = shpiCanvas.getContext('2d')
    var shpiImgData = sctx.createImageData(W, H)
    var sd = shpiImgData.data
    var shpiStops = [[215,48,39],[252,141,89],[254,224,139],[145,207,96],[26,152,80]]

    var cpiCanvas = document.createElement('canvas')
    cpiCanvas.width = W; cpiCanvas.height = H
    var cctx = cpiCanvas.getContext('2d')
    var cpiImgData = cctx.createImageData(W, H)
    var cd = cpiImgData.data
    var cpiStops = [[63,0,125],[116,43,164],[153,112,171],[211,189,213],[217,240,211],[127,191,123],[27,120,55]]

    function hexToRgbArr_(hex) {
      var r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16)
      return [r,g,b]
    }

    for (var j = 0; j < W * H; j++) {
      var R2 = pixels[j * 4], G2 = pixels[j * 4 + 1], B2 = pixels[j * 4 + 2], A2 = pixels[j * 4 + 3]
      var base = j * 4

      // Zone display raster
      var zn = zoneMap[j]
      if (zn > 0) {
        var zc = hexToRgbArr_(ZONE_COLORS[zn - 1])
        dd[base] = zc[0]; dd[base+1] = zc[1]; dd[base+2] = zc[2]; dd[base+3] = 180
      } else {
        dd[base] = 0; dd[base+1] = 0; dd[base+2] = 0; dd[base+3] = 0
      }

      // SHPI gradient raster: valid when soilCount (B channel) > 0 AND inside polygon
      if (B2 > 0 && (!polyMask || polyMask[j])) {
        var sv = R2 / 254, st = sv * 4
        var si = Math.min(3, Math.floor(st)), sf = st - si
        sd[base]   = Math.round(shpiStops[si][0] + (shpiStops[si+1][0] - shpiStops[si][0]) * sf)
        sd[base+1] = Math.round(shpiStops[si][1] + (shpiStops[si+1][1] - shpiStops[si][1]) * sf)
        sd[base+2] = Math.round(shpiStops[si][2] + (shpiStops[si+1][2] - shpiStops[si][2]) * sf)
        sd[base+3] = 200
      } else {
        sd[base] = 0; sd[base+1] = 0; sd[base+2] = 0; sd[base+3] = 0
      }

      // CPI gradient raster: valid when cropCount (A channel) > 0 AND inside polygon
      // CPI is already normalised to [0,1] by the evalscript composite formula,
      // so no sub-range rescaling (unlike old raw-NDVI 0.4→1.0 mapping).
      if (A2 > 0 && (!polyMask || polyMask[j])) {
        var cv = G2 / 254, cn = Math.max(0, Math.min(1, cv))
        var cseg = cn * (cpiStops.length - 1)
        var ci = Math.min(cpiStops.length - 2, Math.floor(cseg)), cf = cseg - ci
        cd[base]   = Math.round(cpiStops[ci][0] + (cpiStops[ci+1][0] - cpiStops[ci][0]) * cf)
        cd[base+1] = Math.round(cpiStops[ci][1] + (cpiStops[ci+1][1] - cpiStops[ci][1]) * cf)
        cd[base+2] = Math.round(cpiStops[ci][2] + (cpiStops[ci+1][2] - cpiStops[ci][2]) * cf)
        cd[base+3] = 200
      } else {
        cd[base] = 0; cd[base+1] = 0; cd[base+2] = 0; cd[base+3] = 0
      }
    }

    dctx.putImageData(dispData, 0, 0)
    sctx.putImageData(shpiImgData, 0, 0)
    cctx.putImageData(cpiImgData, 0, 0)

    function canvasToB64_(c) {
      var dataUrl = c.toDataURL('image/png')
      return dataUrl.replace(/^data:image\/png;base64,/, '')
    }

    callback({
      success:        true,
      bbox:           rawData.bbox,
      zone_stats:     zoneStats,
      pixel_sample:   pixelSample,
      shpi_sample:    shpiSample,
      kmeans5:        kmeans5,
      clip_stats: {
        bbox_pixels:       bboxCount,
        polygon_pixels:    polyCount,
        valid_soil_pixels: shpiPixels.length,
        valid_crop_pixels: cpiPixels.length
      },
      validation: {
        spearman_r:      rho,
        r_squared:       rho_r2,
        is_monotonic:    mono,
        cpi_ratio:       ratio,
        confirmed:       rho > 0.60 && mono,
        n_zones:         10,
        data_source:     'real',
        shpi_thresholds: thresholds
      },
      raster_png_b64: canvasToB64_(dispCanvas),
      shpi_png_b64:   canvasToB64_(shpiCanvas),
      cpi_png_b64:    canvasToB64_(cpiCanvas),
      meta: Object.assign({}, rawData.meta, { width: W, height: H })
    })
  }
  img.src = 'data:image/png;base64,' + rawData.raster_png_b64
}

// Single-run path: decode PNG and render results in the UI
function decodeRasterAndAnalyse_(rawData) {
  // Attach current ROI polygon so the decoder can clip to its exact boundary
  if (roi && !rawData.geojson) rawData.geojson = roi
  decodeRasterToResult_(rawData, function(result) {
    if (!result) {
      showOverlay(false)
      setProgress(false)
      alert('Failed to decode raster image. Please try again.')
      return
    }
    lastResult = result
    // Clear season CPI cache so stale season data from a previous ROI is not shown
    seasonCpiCache = {}
    scatterSeasonMode = 'all'
    if (currentRoiId) {
      var cache = loadResultsCache_()
      cache[currentRoiId] = result
      saveResultsCache_(cache)
      renderLibraryPanel_()
      maybeShowCompareSection_()
    }
    renderResults(result)
    setProgress(true, 100, 'Complete!')
    setTimeout(function() { showOverlay(false); setProgress(false) }, 500)
  })
}

// ── Render results ────────────────────────────────────────────
function renderResults(data) {
  const v = data.validation
  const z = data.zone_stats

  // Banner
  const banner = document.getElementById('banner')
  if (v.confirmed) {
    banner.textContent = '✓ Hypothesis confirmed — CPI increases Zone 1→10'
    banner.className   = 'banner banner-yes'
  } else {
    banner.textContent = '⚠ Hypothesis not confirmed — check data coverage'
    banner.className   = 'banner banner-no'
  }

  // Data source badge
  var badge = document.getElementById('dataSourceBadge')
  if (v.data_source === 'real') {
    badge.textContent = '✓ Real Sentinel-2 data'
    badge.style.background = '#1a3d1a'
    badge.style.color = '#7FE07F'
    badge.style.border = '1px solid #3a6d3a'
  } else {
    badge.textContent = '⚠ Synthetic fallback data — API not returning bins'
    badge.style.background = '#3d2a1a'
    badge.style.color = '#f0a070'
    badge.style.border = '1px solid #6d4a2a'
  }
  badge.style.display = 'block'

  // D4: ROI clip verification — bbox/polygon/valid-obs pixel counts
  var clipEl = document.getElementById('clipStats')
  if (clipEl && data.clip_stats) {
    var cs = data.clip_stats
    var polyPct  = cs.bbox_pixels > 0 ? Math.round(cs.polygon_pixels / cs.bbox_pixels * 100) : 100
    var soilPct  = cs.polygon_pixels > 0 ? Math.round(cs.valid_soil_pixels / cs.polygon_pixels * 100) : 0
    var cropPct  = cs.polygon_pixels > 0 ? Math.round(cs.valid_crop_pixels / cs.polygon_pixels * 100) : 0
    clipEl.innerHTML =
      '📐 <b>Pixel coverage</b>&nbsp;—&nbsp;' +
      'bbox: ' + formatPixelCount(cs.bbox_pixels) + 'px&nbsp;│&nbsp;' +
      'polygon: ' + formatPixelCount(cs.polygon_pixels) + 'px (' + polyPct + '%)&nbsp;│&nbsp;' +
      '🟤 soil: ' + formatPixelCount(cs.valid_soil_pixels) + ' (' + soilPct + '%)&nbsp;│&nbsp;' +
      '🌿 crop: ' + formatPixelCount(cs.valid_crop_pixels) + ' (' + cropPct + '%)'
    clipEl.style.display = 'block'
  } else if (clipEl) {
    clipEl.style.display = 'none'
  }

  // Stat cards — use Spearman ρ (zone-level, consistent with scatter) with fallback for old cached results
  const statGrid = document.getElementById('statGrid')
  statGrid.innerHTML = ''
  var isNew  = v.spearman_r !== undefined
  var rhoVal = isNew ? v.spearman_r : v.pearson_r
  var rhoLbl = isNew ? 'Spearman ρ (zones)' : 'Pearson r'
  var r2Lbl  = isNew ? 'R² (zones)' : 'R²'
  const stats = [
    { val: rhoVal,  lbl: rhoLbl },
    { val: v.r_squared,  lbl: r2Lbl },
    { val: v.cpi_ratio ? v.cpi_ratio + '×' : '—', lbl: 'CPI Z10/Z1 ratio' },
    { val: v.confirmed ? 'YES' : 'NO', lbl: 'Hypothesis' },
  ]
  stats.forEach(s => {
    const card = document.createElement('div')
    card.className = 'stat-card'
    const val = document.createElement('div')
    val.className = 'stat-val'
    val.textContent = s.val
    const lbl = document.createElement('div')
    lbl.className = 'stat-lbl'
    lbl.textContent = s.lbl
    card.appendChild(val)
    card.appendChild(lbl)
    statGrid.appendChild(card)
  })

  // CPI bar chart removed
  if (chart) { chart.destroy(); chart = null }

  // Zone table
  const tbody = document.getElementById('zoneTbody')
  tbody.innerHTML = ''
  z.forEach((zs, i) => {
    const tr = document.createElement('tr')

    const tdZone = document.createElement('td')
    const zdot = document.createElement('span')
    zdot.className = 'zdot'
    zdot.style.background = ZONE_COLORS[i]
    tdZone.appendChild(zdot)
    tdZone.appendChild(document.createTextNode('Zone ' + zs.zone))

    const tdPx = document.createElement('td')
    tdPx.textContent = zs.pixel_count === 0 ? '—' : formatPixelCount(zs.pixel_count)
    if (zs.pixel_count === 0) tdPx.title = 'No bare-soil pixels — fallback SHPI value used'

    const tdShpi = document.createElement('td')
    tdShpi.textContent = zs.mean_shpi

    const tdCpi = document.createElement('td')
    const strong = document.createElement('strong')
    strong.textContent = zs.mean_cpi
    tdCpi.appendChild(strong)

    tr.appendChild(tdZone)
    tr.appendChild(tdPx)
    tr.appendChild(tdShpi)
    tr.appendChild(tdCpi)
    tbody.appendChild(tr)
  })

  // ── SHPI vs CPI scatter plot — delegated to renderScatterPlot_() ──────────
  renderScatterPlot_(data)

  document.getElementById('results').classList.add('show')
  document.getElementById('results-map-ctrls').style.display = 'flex'

  // Zone map — rendered after 'show' so the container has layout
  setTimeout(function() { renderResultsMap_(data) }, 50)
}

// ── Results Map ───────────────────────────────────────────────
function geomBbox_(geom) {
  var coords = geom.type === 'MultiPolygon'
    ? geom.coordinates.reduce(function(a, poly) { return a.concat(poly[0]) }, [])
    : geom.coordinates[0]
  return coords.reduce(function(b, c) {
    return [Math.min(b[0], c[0]), Math.min(b[1], c[1]), Math.max(b[2], c[0]), Math.max(b[3], c[1])]
  }, [Infinity, Infinity, -Infinity, -Infinity])
}

// Ray-casting point-in-polygon test for a single ring [[lng,lat], ...]
function pointInRing_(lng, lat, ring) {
  var inside = false
  var n = ring.length
  for (var i = 0, j = n - 1; i < n; j = i++) {
    var xi = ring[i][0], yi = ring[i][1]
    var xj = ring[j][0], yj = ring[j][1]
    if (((yi > lat) !== (yj > lat)) &&
        (lng < (xj - xi) * (lat - yi) / (yj - yi) + xi)) {
      inside = !inside
    }
  }
  return inside
}

// Returns true if [lng, lat] is inside the GeoJSON Polygon or MultiPolygon (respects holes).
function pointInPolygon_(lng, lat, geom) {
  var polys = geom.type === 'MultiPolygon' ? geom.coordinates : [geom.coordinates]
  for (var p = 0; p < polys.length; p++) {
    var rings = polys[p]
    if (!pointInRing_(lng, lat, rings[0])) continue  // outside outer ring
    var inHole = false
    for (var h = 1; h < rings.length; h++) {
      if (pointInRing_(lng, lat, rings[h])) { inHole = true; break }
    }
    if (!inHole) return true
  }
  return false
}

function hexToRgb_(hex) {
  var r = parseInt(hex.slice(1, 3), 16)
  var g = parseInt(hex.slice(3, 5), 16)
  var b = parseInt(hex.slice(5, 7), 16)
  return [r, g, b]
}

// Inverse-distance weighted colour from zone SHPI centroids
function idwColor_(px, py, centroids) {
  var eps = 1e-10
  var wSum = 0, rW = 0, gW = 0, bW = 0
  for (var k = 0; k < centroids.length; k++) {
    var dx = px - centroids[k].x, dy = py - centroids[k].y
    var d2 = dx * dx + dy * dy
    var w = 1 / (d2 + eps)
    wSum += w
    rW += w * centroids[k].r
    gW += w * centroids[k].g
    bW += w * centroids[k].b
  }
  return [Math.round(rW / wSum), Math.round(gW / wSum), Math.round(bW / wSum)]
}

// Convert a single outer ring (array of [lng,lat]) to canvas pixel coords
function ringToPixels_(ring, minLng, minLat, lngScale, latScale, W, H) {
  return ring.map(function(c) {
    return [(c[0] - minLng) * lngScale, H - (c[1] - minLat) * latScale]
  })
}

// ── Render results map: real Process API raster or IDW fallback ───────────────
function renderResultsMap_(data) {
  if (!roi) return
  var zoneStat   = data.zone_stats
  var rasterB64  = data.raster_png_b64 || null
  var container  = document.getElementById('results-map')

  if (!resultsMap) {
    resultsMap = L.map(container, { zoomControl: true, attributionControl: false })
    var mainBaseLayers0 = [esriSatellite, esriTopo, esriStreet, osmStandard]
    var activeBase0 = mainBaseLayers0.find(function(l) { return map.hasLayer(l) }) || esriSatellite
    L.tileLayer(activeBase0._url, Object.assign({}, activeBase0.options)).addTo(resultsMap)
    if (monthlyLayer && map.hasLayer(monthlyLayer)) {
      L.tileLayer(monthlyLayer._url, Object.assign({}, monthlyLayer.options)).addTo(resultsMap)
    }
  } else {
    resultsMap.eachLayer(function(lyr) {
      if (!(lyr instanceof L.TileLayer)) resultsMap.removeLayer(lyr)
    })
    resultsRasterLayer = null
  }

  var bb     = geomBbox_(roi)
  var minLng = bb[0], minLat = bb[1], maxLng = bb[2], maxLat = bb[3]
  var bounds = [[minLat, minLng], [maxLat, maxLng]]

  if (rasterB64) {
    // Real zone-coloured raster from the Sentinel Hub Process API
    var opacity = (document.getElementById('rasterOpacity').value || 80) / 100
    resultsRasterLayer = L.imageOverlay(
      'data:image/png;base64,' + rasterB64,
      bounds,
      { opacity: opacity }
    ).addTo(resultsMap)
  } else {
    // Fallback: IDW canvas heatmap (geometric approximation)
    renderIdwHeatmap_(resultsMap, zoneStat, minLng, minLat, maxLng, maxLat)
  }

  // ROI polygon outline on top
  L.geoJSON(roi, {
    style: { color: '#F5A623', weight: 2, fillOpacity: 0, dashArray: '4 3' }
  }).addTo(resultsMap)

  resultsMap.fitBounds(bounds, { padding: [6, 6] })
}

// ── IDW canvas heatmap (fallback when Process API raster is unavailable) ──────
function renderIdwHeatmap_(mapInst, zoneStat, minLng, minLat, maxLng, maxLat) {
  var W = 200, H = Math.max(1, Math.round(200 * (maxLat - minLat) / (maxLng - minLng)))
  var lngScale = W / (maxLng - minLng)
  var latScale = H / (maxLat - minLat)

  var latStep = (maxLat - minLat) / zoneStat.length
  var centroids = zoneStat.map(function(zs, i) {
    var rgb = hexToRgb_(ZONE_COLORS[i])
    return { x: W / 2, y: H - (i + 0.5) * latStep * latScale, r: rgb[0], g: rgb[1], b: rgb[2] }
  })

  var rings = roi.type === 'MultiPolygon'
    ? roi.coordinates.map(function(p) { return p[0] })
    : [roi.coordinates[0]]

  var canvas = document.createElement('canvas')
  canvas.width = W; canvas.height = H
  var ctx = canvas.getContext('2d')

  var offscreen = document.createElement('canvas')
  offscreen.width = W; offscreen.height = H
  var octx = offscreen.getContext('2d')
  var imgData = octx.createImageData(W, H)
  var d = imgData.data
  for (var py = 0; py < H; py++) {
    for (var px = 0; px < W; px++) {
      var rgb = idwColor_(px, py, centroids)
      var idx = (py * W + px) * 4
      d[idx] = rgb[0]; d[idx+1] = rgb[1]; d[idx+2] = rgb[2]; d[idx+3] = Math.round(0.65*255)
    }
  }
  octx.putImageData(imgData, 0, 0)

  ctx.save()
  rings.forEach(function(ring) {
    var pts = ringToPixels_(ring, minLng, minLat, lngScale, latScale, W, H)
    ctx.beginPath(); ctx.moveTo(pts[0][0], pts[0][1])
    for (var j = 1; j < pts.length; j++) ctx.lineTo(pts[j][0], pts[j][1])
    ctx.closePath()
  })
  ctx.clip(); ctx.drawImage(offscreen, 0, 0); ctx.restore()

  L.imageOverlay(canvas.toDataURL(), [[minLat, minLng], [maxLat, maxLng]]).addTo(mapInst)
}

