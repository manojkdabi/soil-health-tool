      <button id="scatterTabBins-fs" class="cmp-tab active" onclick="setScatterViewMode_('bins')" style="font-size:11px;padding:3px 10px">Zone means</button>
      <button id="scatterTabPx-fs"   class="cmp-tab"        onclick="setScatterViewMode_('pixels')" style="font-size:11px;padding:3px 10px">All pixels</button>
      <label id="outlierToggleWrap-fs" style="display:flex;align-items:center;gap:4px;font-size:11px;color:#9FE1CB;cursor:pointer;margin-left:6px">
        <input type="checkbox" id="outlierToggleFs" checked onchange="renderScatterFsActive_()" style="cursor:pointer">Filter outliers (IQR)</label>
      <span style="color:#3e7a6a;margin:0 4px">|</span>
      <span style="font-size:10px;color:#9FE1CB;white-space:nowrap">Season CPI:</span>
      <button id="scatterSeasonTab-all-fs"    class="cmp-tab active" onclick="setScatterSeasonMode_('all')"    style="font-size:11px;padding:3px 8px">All</button>
      <button id="scatterSeasonTab-kharif-fs" class="cmp-tab"        onclick="setScatterSeasonMode_('kharif')" style="font-size:11px;padding:3px 8px">🌾 Kharif</button>
      <button id="scatterSeasonTab-rabi-fs"   class="cmp-tab"        onclick="setScatterSeasonMode_('rabi')"   style="font-size:11px;padding:3px 8px">🌿 Rabi</button>
    </div>
    <button class="rm-ctrl-btn" onclick="closeChartFs_('shpiCpiScatter')">✕ Close</button>
  </div>
  <div id="seasonFetchStatus-fs" style="text-align:center;font-size:11px;color:#F5A623;padding:4px 0;display:none"></div>
  <div class="chart-fs-body"><canvas id="shpiCpiScatter-fs"></canvas></div>
  <div id="scatterEq-fs" style="text-align:center;font-size:11px;color:#9FE1CB;padding-top:4px"></div>
  <div id="corrSummary-fs" style="margin:3px 0 2px;font-size:11px;color:#9FE1CB;text-align:center"></div>
  <div id="scatterOutlierNote-fs" style="text-align:center;font-size:10px;color:#6FA898;padding-bottom:16px"></div>
</div>
<div id="chartFs-cmpScatterChart" class="chart-fs-overlay">
  <div class="chart-fs-topbar">
    <span class="chart-fs-title">SHPI vs CPI — all ROIs</span>
    <div class="cmp-tabs" style="margin:0">
      <div class="cmp-tab active" id="cmpTabZones-fs" onclick="setCmpScatterMode_('zones');syncChartFs_('cmpScatterChart')">Per-zone</div>
      <div class="cmp-tab" id="cmpTabSummary-fs" onclick="setCmpScatterMode_('summary');syncChartFs_('cmpScatterChart')">Per-ROI summary</div>
    </div>
    <label style="display:flex;align-items:center;gap:4px;font-size:11px;color:#9FE1CB;cursor:pointer;margin-left:6px">
      <input type="checkbox" id="cmpOutlierToggleFs" checked onchange="syncChartFs_('cmpScatterChart')" style="cursor:pointer">Filter outliers (IQR)</label>
    <button class="rm-ctrl-btn" onclick="closeChartFs_('cmpScatterChart')">✕ Close</button>
  </div>
  <div class="chart-fs-body"><canvas id="cmpScatterChart-fs"></canvas></div>
  <div id="cmpScatterLabel-fs" style="text-align:center;font-size:11px;color:#9FE1CB;padding-top:4px"></div>
  <div id="cmpScatterOutlierNote-fs" style="text-align:center;font-size:10px;color:#6FA898;padding-bottom:16px"></div>
</div>
<div id="libTableFs" class="chart-fs-overlay" style="display:none;flex-direction:column" onclick="if(event.target===this)closeLibTableFs_()">
  <div class="chart-fs-topbar">
    <span class="chart-fs-title">ROI Library</span>
    <button class="rm-ctrl-btn" onclick="closeLibTableFs_()">✕ Close</button>
  </div>
  <div style="padding:16px;overflow:auto;flex:1">
    <table class="cmp-table" id="roiMergedTableFs"><thead><tr><th>ROI</th><th>Area</th><th>Date</th><th>SHPI</th><th>ρ</th><th>R²</th><th>Z10/Z1</th><th>Actions</th></tr></thead><tbody id="roiMergedBodyFs"></tbody></table>
  </div>
</div>
