// Compute geodesic area in hectares from a GeoJSON geometry
function computeAreaHa_(geom) {
  var R = 6371000  // Earth's mean radius in metres
  var rings = geom.type === 'MultiPolygon'
    ? geom.coordinates.map(function (p) { return p[0] })
    : [geom.coordinates[0]]
  var total = 0
  rings.forEach(function (ring) {
    var a = 0
    for (var i = 0; i < ring.length - 1; i++) {
      var p1 = ring[i], p2 = ring[i + 1]
      a += (p2[0] - p1[0]) * Math.PI / 180 *
           (2 + Math.sin(p1[1] * Math.PI / 180) + Math.sin(p2[1] * Math.PI / 180))
    }
    total += Math.abs(a) * R * R / 2
  })
  return total / 10000  // m² → ha
}

