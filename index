// ── Time Series — decode one window PNG (RGBA → index means) ────────
// Decodes a base64-encoded RGBA PNG returned by getTimeSeries().
// Channel mapping: R=EVI2×254, G=NDRE×254, B=NIRv×254, A=NDMI×254.
// Pixels with [0,0,0,0] are nodata (no valid crop observations) and skipped.
// Returns Promise<{evi2,ndre,nirv,ndmi,n}|null>.
function decodeTsWindowPng_(img64) {
  return new Promise(function(resolve) {
    const img = new Image()
    img.onload = function() {
      const canvas = document.createElement('canvas')
      canvas.width = img.width
      canvas.height = img.height
      const ctx = canvas.getContext('2d')
      ctx.drawImage(img, 0, 0)
      const px = ctx.getImageData(0, 0, img.width, img.height).data
      let rS=0, gS=0, bS=0, aS=0, n=0
      for (let i=0; i<px.length; i+=4) {
        if (px[i]===0 && px[i+1]===0 && px[i+2]===0 && px[i+3]===0) continue
        rS += px[i]; gS += px[i+1]; bS += px[i+2]; aS += px[i+3]
        n++
      }
      if (n === 0) { resolve(null); return }
      const sc = v => Math.round(v / 254 * 1000) / 1000
      resolve({ evi2: sc(rS/n), ndre: sc(gS/n), nirv: sc(bS/n), ndmi: sc(aS/n), n })
    }
    img.onerror = function() { resolve(null) }
    img.src = 'data:image/png;base64,' + img64
  })
}

// ── Time Series — fetch from Process API (biweekly loop) ─────
function fetchTimeSeries_() {
  if (!roi) { alert('Draw or upload an ROI first.'); return }
  const yearStart = parseInt(document.getElementById('yearStart').value, 10)
  const yearEnd   = parseInt(document.getElementById('yearEnd').value, 10)
  if (isNaN(yearStart) || isNaN(yearEnd)) { alert('Set a valid year range first.'); return }
  const btn = document.getElementById('tsFetchBtn')
  btn.disabled    = true
  btn.textContent = '⏳ Fetching...'
  document.getElementById('tsChartLabel').textContent = ''
  google.script.run
    .withSuccessHandler(async function(data) {
      btn.disabled    = false
      btn.textContent = '📡 Fetch Time Series'
      if (!data.success) {
        document.getElementById('tsChartLabel').textContent = '⚠ ' + data.error
        return
      }
      // Decode each window PNG using Canvas pixel reads
      const decoded = await Promise.all(data.windows.map(async w => {
        const v = await decodeTsWindowPng_(w.img64)
        return v ? Object.assign({ date: w.date }, v) : null
      }))
      tsData = decoded.filter(Boolean)
      if (tsData.length === 0) {
        document.getElementById('tsChartLabel').textContent =
          '⚠ No valid crop observations found in any window.'
        return
      }
      // Extract unique years and build year checkboxes
      const years = Array.from(new Set(tsData.map(d => d.date.substring(0, 4)))).sort()
      buildYearCheckboxes_(years)
      document.getElementById('tsIndexBtns').style.display = 'block'
      document.getElementById('tsViewBtns').style.display = 'block'
      document.getElementById('tsChartWrap').style.display = 'block'
      renderTsChart_(tsCurIndex)
    })
    .withFailureHandler(function(err) {
      btn.disabled    = false
      btn.textContent = '📡 Fetch Time Series'
      document.getElementById('tsChartLabel').textContent = '⚠ ' + err.message
    })
    .getTimeSeries({ geojson: roi, yearStart, yearEnd })
}

