function fmtWaybackDate_(dateStr) {
  // Parse a YYYY-MM-DD (or ISO datetime) string and return "07 Nov 2023 (Wk 45)"
  if (!dateStr) return ''
  // Strip time component if present (e.g. "2024-01-10T21:44:30.000Z" → "2024-01-10")
  var datePart = dateStr.length > 10 ? dateStr.substring(0, 10) : dateStr
  var d = new Date(datePart + 'T00:00:00Z') // parse as UTC to avoid timezone shift
  if (isNaN(d.getTime())) return dateStr
  var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
  var jan1 = new Date(Date.UTC(d.getUTCFullYear(), 0, 1))
  var wk = Math.ceil(((d - jan1) / 86400000 + jan1.getUTCDay() + 1) / 7)
  return d.getUTCDate() + ' ' + months[d.getUTCMonth()] + ' ' + d.getUTCFullYear() +
         ' (Wk ' + wk + ')'
}

function esriExtractDate_(entry) {
  if (!entry) return ''
  // Handle case where entry is a primitive string (e.g. a GUID — scan for date pattern)
  if (typeof entry === 'string') {
    var ms = entry.match(/(\d{4}-\d{2}-\d{2})/)
    return ms ? ms[1] : ''
  }
  if (typeof entry !== 'object') return ''
  // Check known ESRI Wayback date field names first
  var raw = entry.releaseDatetime || entry.releaseDate || entry.imageDate || entry.itemDate || ''
  if (raw) return raw
  // Scan ALL string-valued fields for a YYYY-MM-DD pattern
  // (covers itemTitle: "World Imagery (Wayback 2024-01-10T...)", releaseDateLabel, etc.)
  for (var key in entry) {
    if (typeof entry[key] === 'string') {
      var m = entry[key].match(/(\d{4}-\d{2}-\d{2})/)
      if (m) return m[1]
    }
  }
  return ''
}

function loadEsriReleases_() {
  var sel = document.getElementById('esriReleaseSelect')
  var msg = document.getElementById('monLoading')
  msg.style.display = 'block'
  fetch('https://s3-us-west-2.amazonaws.com/config.maptiles.arcgis.com/waybackconfig.json')
    .then(function (r) { return r.json() })
    .then(function (cfg) {
      esriWaybackReleases = cfg
      // Log a sample entry so we can inspect the actual field names in the browser console
      var sampleIds = Object.keys(cfg)
      if (sampleIds.length) {
        var sample = cfg[sampleIds[0]]
        console.log('[Wayback] config sample entry:', sampleIds[0], sample)
        console.log('[Wayback] sample type:', typeof sample, '| keys:', typeof sample === 'object' ? Object.keys(sample).join(', ') : '(primitive)')
        console.log('[Wayback] extracted date from sample:', esriExtractDate_(sample))
      }
      // sort by release date descending; fall back to numeric id descending when no date
      var releases = Object.keys(cfg).sort(function (a, b) {
        var da = esriExtractDate_(cfg[a])
        var db = esriExtractDate_(cfg[b])
        if (da && db) return new Date(db) - new Date(da)
        if (da) return -1
        if (db) return 1
        return Number(b) - Number(a)
      })
      sel.innerHTML = '<option value="">— choose a release date —</option>'
      releases.forEach(function (id) {
        var entry = cfg[id]
        var rawDate = esriExtractDate_(entry)
        var datePart = ''
        if (rawDate) {
          datePart = fmtWaybackDate_(rawDate)
        } else if (entry && typeof entry === 'object' && entry.releaseDateLabel) {
          // releaseDateLabel is already human-readable (e.g. "Jan 10, 2024")
          datePart = entry.releaseDateLabel
        }
        // Always show the date alongside the numeric ID so users can correlate
        var label = datePart ? (datePart + ' · #' + id) : ('#' + id)
        var opt = document.createElement('option')
        opt.value = id
        opt.textContent = label
        sel.appendChild(opt)
      })
      msg.style.display = 'none'
      document.getElementById('esriReleaseMsg').textContent = releases.length + ' releases loaded.'
    })
    .catch(function (err) {
      msg.textContent = 'Could not load releases.'
      console.error('ESRI Wayback config error:', err)
    })
}

function loadEsriRelease_() {
  var releaseId = document.getElementById('esriReleaseSelect').value
  if (!releaseId) { alert('Please select a date first.'); return }
  // Build new layer before removing old one to avoid blank-map flash
  var newLayer = L.tileLayer(
    'https://wayback.maptiles.arcgis.com/arcgis/rest/services/World_Imagery/MapServer/tile/' +
    releaseId + '/{z}/{y}/{x}',
    { attribution: 'ESRI Wayback', maxZoom: 19, opacity: 0.9, keepBuffer: 0 }
  )
  if (monthlyLayer) { map.removeLayer(monthlyLayer) }
  monthlyLayer = newLayer
  monthlyLayer.addTo(map)
  monthlyLayer.redraw()  // force fresh tile requests for the selected release
  // bring drawn layer & results raster to front
  drawn.bringToFront()
  if (resultsRasterLayer) resultsRasterLayer.bringToFront()
  var selEl = document.getElementById('esriReleaseSelect')
  document.getElementById('esriReleaseMsg').textContent =
    selEl.selectedOptions && selEl.selectedOptions.length
      ? '✓ Showing imagery from: ' + selEl.selectedOptions[0].text
      : '✓ Layer loaded.'
}

function applyShWms_() {
  var instanceId = document.getElementById('shInstanceId').value.trim()
  if (!instanceId) { alert('Please enter your Sentinel Hub / CDS Instance ID.'); return }
  var month = document.getElementById('shMonth').value
  var year  = document.getElementById('shYear').value
  // date range: first to last day of month
  var daysInMonth = new Date(year, parseInt(month), 0).getDate()
  var timeParam = year + '-' + month + '-01/' + year + '-' + month + '-' + daysInMonth
  clearMonthlyLayer_()
  var wmsUrl = 'https://sh.dataspace.copernicus.eu/ogc/wms/' + instanceId
  monthlyLayer = L.tileLayer.wms(wmsUrl, {
    layers:      'TRUE-COLOR',
    format:      'image/png',
    transparent: true,
    version:     '1.3.0',
    time:        timeParam,
    attribution: 'Sentinel-2 © ESA / Copernicus Data Space',
    opacity:     0.9
  })
  monthlyLayer.addTo(map)
  drawn.bringToFront()
  if (resultsRasterLayer) resultsRasterLayer.bringToFront()
}

function clearMonthlyLayer_() {
  if (monthlyLayer) { map.removeLayer(monthlyLayer); monthlyLayer = null }
  document.getElementById('esriReleaseMsg').textContent = ''
}

