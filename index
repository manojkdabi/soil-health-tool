document.getElementById('shpInput').addEventListener('change', function (e) {
  var file = e.target.files[0]
  if (!file) return
  var reader = new FileReader()
  reader.onload = function (ev) {
    JSZip.loadAsync(ev.target.result).then(function (zip) {
      var shpName = Object.keys(zip.files).find(function (n) { return n.toLowerCase().endsWith('.shp') })
      if (!shpName) { alert('No .shp file found in the ZIP.'); return }
      zip.file(shpName).async('arraybuffer').then(function (buf) {
        var gj = shpToGeoJSON_(buf)
        if (!gj) { alert('Could not parse shapefile — only Polygon shapes are supported.'); return }
        drawn.clearLayers()
        var group = L.geoJSON(gj, { style: { color: '#F5A623', weight: 2, fillOpacity: 0.12 } })
        var bounds = group.getBounds()
        group.eachLayer(function(l) { drawn.addLayer(l) })
        map.fitBounds(bounds)
        var feat = gj.features[0]
        roi = feat ? feat.geometry : gj
        var extraMsg = gj.features.length > 1 ? ' (first of ' + gj.features.length + ' features used)' : ''
        setROIStatus('✓ Shapefile loaded: ' + file.name + extraMsg)
        currentRoiId = null
        document.getElementById('runBtn').disabled = false
        updateAreaDisplay_()
      })
    }).catch(function (err) { alert('Could not read ZIP: ' + err.message) })
  }
  reader.readAsArrayBuffer(file)
  e.target.value = ''
})

// Parse a minimal Shapefile (.shp) ArrayBuffer → GeoJSON FeatureCollection
// Supports shape type 5 (Polygon) only.
function shpToGeoJSON_(buf) {
  var v = new DataView(buf)
  if (v.getInt32(0, false) !== 9994) return null        // not a shapefile
  var shapeType = v.getInt32(32, true)
  if (shapeType !== 5) return null                      // only Polygon supported
  var features = []
  var offset = 100
  while (offset + 8 <= buf.byteLength) {
    var contentLen = v.getInt32(offset + 4, false) * 2  // 16-bit words → bytes
    offset += 8
    if (offset + contentLen > buf.byteLength) break
    var recType = v.getInt32(offset, true)
    if (recType === 5) {
      var numParts  = v.getInt32(offset + 36, true)
      var numPoints = v.getInt32(offset + 40, true)
      var partsStart  = offset + 44
      var pointsStart = partsStart + numParts * 4
      var parts = []
      for (var i = 0; i < numParts; i++) parts.push(v.getInt32(partsStart + i * 4, true))
      parts.push(numPoints)
      var rings = []
      for (var i = 0; i < numParts; i++) {
        var ring = []
        for (var j = parts[i]; j < parts[i + 1]; j++) {
          ring.push([v.getFloat64(pointsStart + j * 16, true), v.getFloat64(pointsStart + j * 16 + 8, true)])
        }
        rings.push(ring)
      }
      features.push({ type: 'Feature', geometry: { type: 'Polygon', coordinates: rings }, properties: {} })
    }
    offset += contentLen
  }
  return features.length ? { type: 'FeatureCollection', features: features } : null
}

// ── ROI Library (Phase A+B) ───────────────────────────────────
function uuid4_() {
  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
    var r = Math.random() * 16 | 0
    return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16)
  })
}

function escHtml_(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')
}

function loadLibrary_() {
  try { return JSON.parse(localStorage.getItem('shpRoiLibrary') || '[]') } catch(e) { return [] }
}

function saveLibrary_(lib) {
  localStorage.setItem('shpRoiLibrary', JSON.stringify(lib))
}

function loadResultsCache_() {
  try { return JSON.parse(localStorage.getItem('shpResultsCache') || '{}') } catch(e) { return {} }
}

function saveResultsCache_(cache) {
  localStorage.setItem('shpResultsCache', JSON.stringify(cache))
}

function getROICentroid_(geom) {
  var bb = geomBbox_(geom)
  return [(bb[0] + bb[2]) / 2, (bb[1] + bb[3]) / 2]
}

function saveCurrentROI_() {
  if (!roi) { alert('Draw or upload an ROI first.'); return }
  var lib = loadLibrary_()
  var n   = lib.length + 1
  var centroid = getROICentroid_(roi)
  var lat = centroid[1], lng = centroid[0]
  fetch('https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lng + '&format=json&zoom=8', {
    headers: { 'Accept-Language': 'en', 'User-Agent': 'SoilHealthTool/1.0' }
  }).then(function(r) { return r.json() }).then(function(addr) {
    var state    = (addr.address && addr.address.state) || ''
    var district = (addr.address && (addr.address.county || addr.address.state_district)) || ''
    var raw  = state && district ? state + '_' + district + '_' + n
             : state ? state + '_' + n
             : 'ROI_' + n
    var name = sanitizeName_(raw)
    doSave_(name, false)
  }).catch(function(err) {
    console.warn('Nominatim geocoding failed:', err)
    doSave_('ROI_' + n, true)
  })
  function doSave_(name, geoFailed) {
    var id = uuid4_()
    lib.push({ id: id, name: name, geojson: roi, savedAt: Date.now(), areaHa: Math.round(computeAreaHa_(roi)) })
    saveLibrary_(lib)
    currentRoiId = id
    renderLibraryPanel_()
    maybeShowCompareSection_()
    setROIStatus('✓ Saved: ' + name + (geoFailed ? ' (geocoding unavailable)' : ''))
  }
}

function renderLibraryPanel_() {
  var lib   = loadLibrary_()
  var cache = loadResultsCache_()
  var cnt   = document.getElementById('libCount')
  if (cnt) cnt.textContent = lib.length > 0 ? '(' + lib.length + ')' : ''

  var rows = lib.map(function(item, idx) {
    var d         = cache[item.id]
    var hasResult = !!(d && Array.isArray(d.zone_stats) && d.validation)
    var date      = new Date(item.savedAt).toLocaleDateString()
    var active    = currentRoiId === item.id ? ' style="background:#1c3828"' : ''
    var dotColor  = hasResult ? ROI_COLORS[idx % ROI_COLORS.length] : '#555'
    var dot       = '<span class="roi-color-dot" style="background:' + dotColor + '"></span>'
    var nameCell  = dot + '<span style="cursor:pointer;color:#9FE1CB" onclick="zoomToROI_(\'' + item.id + '\')" title="Zoom to ROI">' + escHtml_(item.name) + '</span>'

    var shpiCell = '—', rCell = '—', r2Cell = '—', ratioCell = '—'
    if (hasResult) {
      var v  = d.validation
      var z  = d.zone_stats
      var sMin = Math.min.apply(null, z.map(function(zs) { return zs.mean_shpi }))
      var sMax = Math.max.apply(null, z.map(function(zs) { return zs.mean_shpi }))
      shpiCell  = sMin.toFixed(2) + '–' + sMax.toFixed(2)
      rCell     = (v.spearman_r !== undefined ? v.spearman_r : v.pearson_r !== undefined ? v.pearson_r : '—')
      r2Cell    = v.r_squared  !== undefined ? v.r_squared  : '—'
      ratioCell = v.cpi_ratio  !== undefined ? v.cpi_ratio + '×' : '—'
    }
    var actions =
      '<button class="lib-btn lib-btn-load" onclick="loadROIFromLibrary_(\'' + item.id + '\')">🗺 Load</button>' +
      (hasResult ? '<button class="lib-btn lib-btn-cached" onclick="viewCachedResult_(\'' + item.id + '\')">📊 Results</button>' : '') +
      '<button class="lib-btn lib-btn-del" onclick="deleteROIFromLibrary_(\'' + item.id + '\')">🗑</button>'

    return '<tr' + active + '><td>' + nameCell + '</td><td>' + item.areaHa + ' ha</td><td>' + date + '</td><td>' + shpiCell + '</td><td>' + rCell + '</td><td>' + r2Cell + '</td><td>' + ratioCell + '</td><td>' + actions + '</td></tr>'
  }).join('')

  var emptyMsg = lib.length === 0 ? '<tr><td colspan="8" style="text-align:center;color:#5a8a6a">No saved ROIs yet</td></tr>' : ''
  var bodyHtml = rows || emptyMsg

  var body = document.getElementById('roiMergedBody')
  if (body) body.innerHTML = bodyHtml
  var bodyFs = document.getElementById('roiMergedBodyFs')
  if (bodyFs) bodyFs.innerHTML = bodyHtml
}

function zoomToROI_(id) {
  var lib  = loadLibrary_()
  var item = lib.find(function(r) { return r.id === id })
  if (!item) return
  var group = L.geoJSON(item.geojson)
  map.fitBounds(group.getBounds())
}

function openLibTableFs_() {
  var el = document.getElementById('libTableFs')
  if (el) { el.style.display = 'flex'; el.classList.add('open') }
}

function closeLibTableFs_() {
  var el = document.getElementById('libTableFs')
  if (el) { el.style.display = 'none'; el.classList.remove('open') }
}

function toggleLibrary_() {
  var el   = document.getElementById('libList')
  var icon = document.getElementById('libToggleIcon')
  var vis  = el.style.display !== 'none'
  el.style.display  = vis ? 'none' : 'block'
  icon.textContent  = vis ? '▶' : '▼'
}

function loadROIFromLibrary_(id) {
  var lib  = loadLibrary_()
  var item = lib.find(function(r) { return r.id === id })
  if (!item) return
  drawn.clearLayers()
  var group = L.geoJSON(item.geojson, { style: { color: '#F5A623', weight: 2, fillOpacity: 0.12 } })
  var bounds = group.getBounds()
  group.eachLayer(function(l) { drawn.addLayer(l) })
  map.fitBounds(bounds)
  roi          = item.geojson
  currentRoiId = id
  setROIStatus('✓ Loaded: ' + item.name)
  document.getElementById('runBtn').disabled = false
  updateAreaDisplay_()
  renderLibraryPanel_()
  var cache = loadResultsCache_()
  if (cache[id]) {
    if (confirm('Cached results available for "' + item.name + '". View them now?')) {
      viewCachedResult_(id)
    }
  }
}

function viewCachedResult_(id) {
  var cache = loadResultsCache_()
  if (!cache[id]) return
  var lib  = loadLibrary_()
  var item = lib.find(function(r) { return r.id === id })
  if (item) {
    roi          = item.geojson
    currentRoiId = id
    drawn.clearLayers()
    var group = L.geoJSON(item.geojson, { style: { color: '#F5A623', weight: 2, fillOpacity: 0.12 } })
    var bounds = group.getBounds()
    group.eachLayer(function(l) { drawn.addLayer(l) })
    map.fitBounds(bounds)
    updateAreaDisplay_()
    renderLibraryPanel_()
  }
  lastResult = cache[id]
  renderResults(cache[id])
}

function deleteROIFromLibrary_(id) {
  if (!confirm('Delete this ROI from the library? Cached results will also be removed.')) return
  var lib = loadLibrary_().filter(function(r) { return r.id !== id })
  saveLibrary_(lib)
  var cache = loadResultsCache_()
  delete cache[id]
  saveResultsCache_(cache)
  if (currentRoiId === id) currentRoiId = null
  renderLibraryPanel_()
  maybeShowCompareSection_()
}

// ── Batch run (Phase C) ───────────────────────────────────────
function runAllROIs_() {
  var lib = loadLibrary_()
  if (lib.length === 0) { alert('No saved ROIs in the library. Save at least one ROI first.'); return }

  var yearStart    = parseInt(document.getElementById('yearStart').value, 10)
  var yearEnd      = parseInt(document.getElementById('yearEnd').value, 10)
  var resolution   = parseInt(document.getElementById('resolution').value, 10)

  var batchDiv = document.getElementById('batchProgress')
  batchDiv.classList.add('show')
  var batchItems = document.getElementById('batchItems')
  batchItems.innerHTML = lib.map(function(item) {
    return '<div class="batch-prog-item" id="bpItem_' + item.id + '">' +
      '<span class="batch-prog-dot" id="bpDot_' + item.id + '"></span>' +
      '<span style="flex:1">' + escHtml_(item.name) + '</span>' +
      '<span id="bpStat_' + item.id + '" style="font-size:10px;color:#5a8a6a">Queued</span>' +
    '</div>'
  }).join('')

  document.getElementById('runAllBtn').disabled = true
  document.getElementById('runBtn').disabled    = true

  var i = 0
  function runNext() {
    if (i >= lib.length) {
      document.getElementById('runAllBtn').disabled = false
      document.getElementById('runBtn').disabled    = (roi === null)
      renderLibraryPanel_()
      maybeShowCompareSection_()
      return
    }
    var item = lib[i]
    var dot  = document.getElementById('bpDot_' + item.id)
    var stat = document.getElementById('bpStat_' + item.id)
    if (dot)  dot.className = 'batch-prog-dot running'
    if (stat) { stat.textContent = 'Running…'; stat.style.color = '#F5A623' }

    google.script.run
      .withSuccessHandler(function(data) {
        if (data.success) {
          // Attach ROI polygon so decoder can clip to exact boundary, then decode
          if (item.geojson && !data.geojson) data.geojson = item.geojson
          decodeRasterToResult_(data, function(result) {
            if (result) {
              var cache = loadResultsCache_()
              cache[item.id] = result
              saveResultsCache_(cache)
              if (dot)  dot.className = 'batch-prog-dot done'
              if (stat) { stat.textContent = '✓ Done'; stat.style.color = '#7FE07F' }
            } else {
              if (dot)  dot.className = 'batch-prog-dot failed'
              if (stat) { stat.textContent = '✗ Decode error'; stat.style.color = '#f07070' }
            }
            i++
            setTimeout(runNext, BATCH_DELAY_MS)
          })
        } else {
          if (dot)  dot.className = 'batch-prog-dot failed'
          if (stat) { stat.textContent = '✗ Failed'; stat.style.color = '#f07070' }
          i++
          setTimeout(runNext, BATCH_DELAY_MS)
        }
      })
      .withFailureHandler(function() {
        if (dot)  dot.className = 'batch-prog-dot failed'
        if (stat) { stat.textContent = '✗ Error'; stat.style.color = '#f07070' }
        i++
        setTimeout(runNext, BATCH_DELAY_MS)
      })
      .runAnalysis({ geojson: item.geojson, yearStart: yearStart, yearEnd: yearEnd,
                     resolution: resolution })
  }
  runNext()
}

// ── Compare view (Phase D+E) ──────────────────────────────────
function loadROIsWithResults_() {
  var lib   = loadLibrary_()
  var cache = loadResultsCache_()
  return lib.filter(function(item) {
    var entry = cache[item.id]
    return !!entry && Array.isArray(entry.zone_stats) && entry.zone_stats.length > 0
  })
}

function maybeShowCompareSection_() {
