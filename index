// ── D3: Render year×season paired scatter ─────────────────────
function renderPairedScatter_(season) {
  var statusEl = document.getElementById('d3PairedStatus')
  var eqEl     = document.getElementById('d3PairedEq')
  var corrEl   = document.getElementById('d3PairedCorr')
  var wrapEl   = document.getElementById('d3PairedChartWrap')

  if (!tsData || !soilTsData) {
    if (statusEl) statusEl.textContent = '⚠ Fetch both Crop Series and Soil Series first.'
    if (wrapEl)   wrapEl.style.display = 'none'
    return
  }

  var pairs = computeYearSeasonPairs_(season)
  if (pairs.length < 2) {
    if (statusEl) statusEl.textContent = '⚠ Need ≥2 years with both fallow SHPI and season CPI data.'
    if (wrapEl)   wrapEl.style.display = 'none'
    return
  }
  if (statusEl) statusEl.textContent = ''
  if (wrapEl)   wrapEl.style.display = 'block'

  var pts = pairs.map(function(p) { return { x: p.shpi, y: p.cpi } })
  var reg = olsLine_(pts)
  var n   = pts.length

  var intSign = reg.intercept >= 0 ? ' + ' : ' - '
  var seasonLabel = season === 'kharif' ? 'Kharif' : 'Rabi'
  var shpiWindow  = season === 'kharif' ? 'Feb–May' : 'Oct–Nov'
  var cpiWindow   = season === 'kharif' ? 'Jun–Oct' : 'Nov–Mar'
  if (eqEl) eqEl.textContent =
    seasonLabel + ' · y = ' + reg.slope.toFixed(3) + 'x' + intSign +
    Math.abs(reg.intercept).toFixed(3) + '   R² = ' + reg.r2.toFixed(3) + '  n=' + n + ' yrs'

  // Spearman ρ
  ;(function() {
    if (n < 3) { if (corrEl) corrEl.textContent = 'n < 3 — ρ not computed'; return }
    var xs = pts.map(function(p){ return p.x }), ys = pts.map(function(p){ return p.y })
    function rankAvg_(arr) {
      var sorted = arr.slice().sort(function(a,b){return a-b})
      return arr.map(function(v) {
        var idx=[]; sorted.forEach(function(s,i){if(s===v)idx.push(i+1)})
        return idx.reduce(function(a,b){return a+b},0)/idx.length
      })
    }
    var rx = rankAvg_(xs), ry = rankAvg_(ys)
    var rmx = rx.reduce(function(a,b){return a+b},0)/n
    var rmy = ry.reduce(function(a,b){return a+b},0)/n
    var rNum = rx.reduce(function(a,v,i){return a+(v-rmx)*(ry[i]-rmy)},0)
    var rdx = Math.sqrt(rx.reduce(function(a,v){return a+(v-rmx)*(v-rmx)},0))
    var rdy = Math.sqrt(ry.reduce(function(a,v){return a+(v-rmy)*(v-rmy)},0))
    var rho = (rdx*rdy>0) ? rNum/(rdx*rdy) : 0
    var tStat = rho * Math.sqrt(n-2) / Math.sqrt(Math.max(1e-15, 1-rho*rho))
    function normCdf_(x) {
      var t2=1/(1+0.2316419*Math.abs(x)), d=0.3989423*Math.exp(-x*x/2)
      var p=d*t2*(0.3193815+t2*(-0.3565638+t2*(1.7814779+t2*(-1.8212560+t2*1.3302744))))
      return x>0?1-p:p
    }
    var pVal = 2*normCdf_(-Math.abs(tStat))
    var pStr = pVal<0.001 ? 'p < 0.001' : 'p = '+pVal.toFixed(3)
    if (corrEl) corrEl.textContent =
      'Spearman ρ = '+rho.toFixed(3)+'  '+pStr+'  R² = '+reg.r2.toFixed(3)
  })()

  // Build chart datasets
  var YEAR_COLORS = ['#4ecdc4','#ff6b6b','#f9ca24','#6c5ce7','#a29bfe','#fd79a8','#00b894','#e17055','#0984e3','#00cec9']
  var scatterDataset = {
    type: 'scatter',
    label: seasonLabel + ' years',
    data: pairs.map(function(p, i) {
      return { x: p.shpi, y: p.cpi, year: p.year, nShpi: p.nShpi, nCpi: p.nCpi }
    }),
    backgroundColor: pairs.map(function(p, i) { return YEAR_COLORS[i % YEAR_COLORS.length] }),
    borderColor: '#fff',
    borderWidth: 1,
    pointRadius: 7,
    pointHoverRadius: 9,
    order: 0
  }

  var olsDataset = {
    type: 'line',
    label: 'OLS fit',
    data: reg.lineData,
    borderColor: '#F5A623',
    borderWidth: 2,
    pointRadius: 0,
    fill: false,
    order: 1
  }

  if (pairedScatterChart) { pairedScatterChart.destroy(); pairedScatterChart = null }
  var ctx = document.getElementById('pairedScatterCanvas').getContext('2d')
  pairedScatterChart = new Chart(ctx, {
    data: { datasets: [scatterDataset, olsDataset] },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: function(item) {
              var d = item.raw
              if (!d || d.year == null) return ''
              return d.year + ' · SHPI('+shpiWindow+')=' + d.x.toFixed(3) +
                     ' · CPI('+cpiWindow+')=' + d.y.toFixed(3) +
                     ' · n(soil)='+d.nShpi+' n(crop)='+d.nCpi
            }
          }
        },
        datalabels: false
      },
      scales: {
        x: {
          title: { display: true, text: 'SHPI ('+shpiWindow+' fallow)', color: '#9FE1CB', font: { size: 9 } },
          ticks: { color: '#9FE1CB', font: { size: 8 } }
        },
        y: {
          title: { display: true, text: 'CPI ('+cpiWindow+' season)', color: '#9FE1CB', font: { size: 9 } },
          ticks: { color: '#9FE1CB', font: { size: 8 } }
        }
      }
    },
    plugins: [{
      // Year label annotations drawn on each point
      id: 'yearLabels',
      afterDatasetsDraw: function(chart) {
        var meta = chart.getDatasetMeta(0)
        var ctx2 = chart.ctx
        ctx2.save()
        ctx2.font = 'bold 8px sans-serif'
        ctx2.textAlign = 'center'
        ctx2.fillStyle = '#fff'
        pairs.forEach(function(p, i) {
          var el = meta.data[i]
          if (!el) return
          ctx2.fillText(p.year, el.x, el.y - 9)
        })
        ctx2.restore()
      }
    }]
  })
}
function dateToDoy_(dateStr) {
  var d     = new Date(dateStr + 'T00:00:00')
  var start = new Date(d.getFullYear(), 0, 0)
  return Math.floor((d - start) / 86400000)
}


function gaussianSmooth_(values, sigma) {
  const r      = Math.max(1, Math.round(sigma * 2.5))
  const kernel = []
  let wsum = 0
  for (let i = -r; i <= r; i++) {
    const w = Math.exp(-0.5 * (i / sigma) ** 2)
    kernel.push(w); wsum += w
  }
  return values.map((_, idx) => {
    let acc = 0, wt = 0
    for (let k = -r; k <= r; k++) {
      const j = idx + k
      if (j >= 0 && j < values.length && values[j] !== null) {
        acc += values[j] * kernel[k + r]; wt += kernel[k + r]
      }
    }
    return wt > 0 ? acc / wt : null
  })
}

// ── Time Series — peak detection ──────────────────────────────
// Returns indices of local maxima with prominence > globalMean * minProminenceFrac
// and at least minDistancePts apart.
function detectPeaks_(smoothed, minProminenceFrac, minDistancePts) {
  const validVals = smoothed.filter(v => v !== null)
  if (!validVals.length) return []
  const globalMean = validVals.reduce((a, b) => a + b, 0) / validVals.length
  const threshold  = globalMean * (1 + minProminenceFrac)
  const peaks = []
  for (let i = 1; i < smoothed.length - 1; i++) {
    const v    = smoothed[i]
    const prev = smoothed[i - 1]
    const next = smoothed[i + 1]
    if (v === null || prev === null || next === null) continue
    if (v > prev && v > next && v > threshold) {
      if (!peaks.length || i - peaks[peaks.length - 1] >= minDistancePts) {
        peaks.push(i)
      }
    }
  }
  return peaks
}

// ── Time Series — render Chart.js line chart ──────────────────
// Delegates to timeline or season renderer based on tsViewMode.
