    pointStyle: 'circle',
    order: 0,
  }

  if (scatterChart) { scatterChart.destroy(); scatterChart = null }
  var sctx = document.getElementById('shpiCpiScatter').getContext('2d')
  scatterChart = new Chart(sctx, {
    data: {
      datasets: [
        zoneBinDataset,
        { type: 'line', label: 'Fit', data: reg.lineData,
          borderColor: '#F5A623', borderWidth: 1.5, pointRadius: 0, fill: false, tension: 0 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: function(ctx) {
          if (ctx.dataset.label === 'Zone means') {
            var zone = ctx.raw.zone || (ctx.dataIndex + 1)
            return 'Z' + zone + '  SHPI=' + ctx.raw.x.toFixed(3) + '  CPI=' + ctx.raw.y.toFixed(3)
          }
          return null
        }}}
      },
      scales: {
        x: { title: { display: true, text: 'SHPI', color: '#9FE1CB', font: { size: 9 } },
             ticks: { color: '#9FE1CB', font: { size: 9 } }, grid: { color: '#1e3d30' } },
        y: { title: { display: true, text: 'CPI',  color: '#9FE1CB', font: { size: 9 } },
             ticks: { color: '#9FE1CB', font: { size: 9 } }, grid: { color: '#1e3d30' } }
      }
    }
  });
}

