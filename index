  }

  if (lastResult && roi) {
    var data   = lastResult
    var bb     = geomBbox_(roi)
    var minLng = bb[0], minLat = bb[1], maxLng = bb[2], maxLat = bb[3]
    var bounds = [[minLat, minLng], [maxLat, maxLng]]

    // Disable unavailable radio options
    document.querySelector('input[name=fsLayer][value=shpi]').disabled = !data.shpi_png_b64
    document.querySelector('input[name=fsLayer][value=cpi]').disabled  = !data.cpi_png_b64

    if (data.raster_png_b64) {
      var opacityFs = (document.getElementById('rasterOpacityFs').value || 80) / 100
      resultsRasterLayerFs = L.imageOverlay(
