function renderCmpScatterZones_(rois, cache) {
  var datasets = []
  rois.forEach(function(item, idx) {
    var z     = cache[item.id] && cache[item.id].zone_stats
    if (!z) return
    // Only include zones with actual CPI data — empty zones have mean_shpi/cpi=0
    var zFiltered = z.filter(function(zs) { return zs.pixel_count > 0 })
    if (!zFiltered.length) return
    var roiColor = ROI_COLORS[idx % ROI_COLORS.length]
    // Colour each zone point by its zone index, use ROI colour as border
    datasets.push({
      type: 'scatter', label: item.name,
      data: zFiltered.map(function(zs) { return { x: zs.mean_shpi, y: zs.mean_cpi } }),
      backgroundColor: zFiltered.map(function(zs) {
        var hex = ZONE_COLORS[Math.min(zs.zone - 1, ZONE_COLORS.length - 1)]
        var c = hexToRgb_(hex)
        return 'rgba(' + c[0] + ',' + c[1] + ',' + c[2] + ',0.85)'
      }),
      borderColor: roiColor,
      borderWidth: 2,
      pointRadius: 6, pointHoverRadius: 8
    })
    var xs = zFiltered.map(function(zs) { return zs.mean_shpi })
    var ys = zFiltered.map(function(zs) { return zs.mean_cpi })
    var n = xs.length, sx = 0, sy = 0, sxy = 0, sxx = 0
    xs.forEach(function(x,i){ sx+=x; sy+=ys[i]; sxy+=x*ys[i]; sxx+=x*x })
    var denom = n*sxx-sx*sx
    var slope = Math.abs(denom)>EPSILON_DENOM ? (n*sxy-sx*sy)/denom : 0
    var icpt  = (sy-slope*sx)/n
    var xMin  = Math.min.apply(null,xs), xMax = Math.max.apply(null,xs)
    datasets.push({
      type: 'line', label: item.name+' fit',
      data: [{x:xMin,y:slope*xMin+icpt},{x:xMax,y:slope*xMax+icpt}],
      borderColor: roiColor, borderWidth: 1, pointRadius: 0, fill: false,
      tension: 0, borderDash: [3,3]
    })
  })
  _applyCmpScatter(datasets, 'SHPI', 'CPI')
  document.getElementById('cmpScatterLabel').textContent = ''
}

function renderCmpScatterSummary_(rois, cache) {
  var pts = rois.map(function(item,idx) {
    var z = cache[item.id] && cache[item.id].zone_stats
    if (!z) return null
    // Only average zones with actual data to avoid zero-valued empty zones skewing the mean
    var zf = z.filter(function(zs) { return zs.pixel_count > 0 })
    if (!zf.length) return null
    var meanShpi = zf.reduce(function(a,zs){return a+zs.mean_shpi},0)/zf.length
    var meanCpi  = zf.reduce(function(a,zs){return a+zs.mean_cpi},0)/zf.length
    return { x: meanShpi, y: meanCpi, label: item.name, color: ROI_COLORS[idx%ROI_COLORS.length] }
  }).filter(Boolean)
  if (pts.length < 2) {
    console.warn('renderCmpScatterSummary_: fewer than 2 valid ROIs with zone_stats — skipping summary scatter')
    return
  }
  var xs = pts.map(function(p){return p.x}), ys = pts.map(function(p){return p.y})
  var n = xs.length, sx=0,sy=0,sxy=0,sxx=0
  xs.forEach(function(x,i){sx+=x;sy+=ys[i];sxy+=x*ys[i];sxx+=x*x})
  var denom = n*sxx-sx*sx
  var slope = Math.abs(denom)>EPSILON_DENOM?(n*sxy-sx*sy)/denom:0
  var icpt  = (sy-slope*sx)/n
  var xMin  = Math.min.apply(null,xs), xMax = Math.max.apply(null,xs)
  var yMean = sy/n
  var ssTot = ys.reduce(function(a,y){return a+(y-yMean)*(y-yMean)},0)
  var ssRes = xs.reduce(function(a,x,i){return a+(ys[i]-(slope*x+icpt))*(ys[i]-(slope*x+icpt))},0)
  var r2    = ssTot>0?1-ssRes/ssTot:0
  var datasets = [
    {
      type: 'scatter', label: 'ROIs',
      data: pts.map(function(p){return{x:p.x,y:p.y}}),
      backgroundColor: pts.map(function(p){return p.color}),
      pointRadius: 7, pointHoverRadius: 9
    },
    {
      type: 'line', label: 'Global fit',
      data: [{x:xMin,y:slope*xMin+icpt},{x:xMax,y:slope*xMax+icpt}],
      borderColor: '#F5A623', borderWidth: 1.5, pointRadius: 0, fill: false, tension: 0
    }
  ]
  _applyCmpScatter(datasets, 'Mean SHPI', 'Mean CPI', pts)
  var interceptSign = icpt >= 0 ? ' + ' : ' − '
  document.getElementById('cmpScatterLabel').textContent =
    'Global: y = ' + slope.toFixed(3) + 'x' + interceptSign + Math.abs(icpt).toFixed(3) + '   R² = ' + r2.toFixed(3)
}

function _applyCmpScatter(datasets, xLabel, yLabel, tooltipPts) {
  if (cmpScatterChart) { cmpScatterChart.destroy(); cmpScatterChart = null }
  var ctx = document.getElementById('cmpScatterChart').getContext('2d')
  cmpScatterChart = new Chart(ctx, {
    data: { datasets: datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: function(ctx) {
              if (tooltipPts && ctx.datasetIndex === 0) {
                var p = tooltipPts[ctx.dataIndex]
                return p ? p.label + ' (' + ctx.raw.x.toFixed(3) + ', ' + ctx.raw.y.toFixed(3) + ')' : ''
              }
              // Per-zone mode: show "ROI — Z(n)"
              if (!tooltipPts && ctx.dataset.type === 'scatter') {
                return ctx.dataset.label + ' — Z' + (ctx.dataIndex + 1) +
                  '  (' + ctx.raw.x.toFixed(3) + ', ' + ctx.raw.y.toFixed(3) + ')'
              }
              return null
            }
          }
        }
      },
      scales: {
        x: { title: { display: true, text: xLabel, color: '#9FE1CB', font: { size: 9 } },
             ticks: { color: '#9FE1CB', font: { size: 9 } }, grid: { color: '#1e3d30' } },
        y: { title: { display: true, text: yLabel, color: '#9FE1CB', font: { size: 9 } },
             ticks: { color: '#9FE1CB', font: { size: 9 } }, grid: { color: '#1e3d30' } }
      }
    }
  })
}

