        : 'Outlier filter: Tukey 1.5×IQR on CPI within each zone (no outliers detected)')
    : 'No outlier filter applied'

  var zoneGroups = {}
    // Add a small deterministic jitter (±0.4×UINT8 step = ±0.0016) to the x values
  // to visually break the ~30 vertical SHPI stripes caused by UINT8 quantization.
  // Statistics are unaffected — jitter is purely cosmetic.
  var SHPI_JITTER = 0.4 / 254
  pts.forEach(function(p, idx) {
    var zi = p.z != null ? p.z : 0
