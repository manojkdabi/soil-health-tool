// Timeline mode — current linear multi-year view (unchanged behaviour)
function renderTsChartTimeline_(indexKey) {
  const labelMap  = { evi2: 'EVI2', ndre: 'NDRE', nirv: 'NIRv', ndmi: 'NDMI' }
  const labels    = tsData.map(d => d.date)
  const rawVals   = tsData.map(d => (d[indexKey] != null ? d[indexKey] : null))

  // Fill nulls for smoothing (nearest-neighbour interpolation)
  const dense = rawVals.slice()
  for (let i = 0; i < dense.length; i++) {
    if (dense[i] === null) {
      const prev = dense.slice(0, i).reverse().find(v => v !== null) ?? null
      const next = dense.slice(i + 1).find(v => v !== null) ?? null
      dense[i] = prev !== null && next !== null ? (prev + next) / 2 : (prev ?? next ?? null)
    }
  }

  const smoothed = gaussianSmooth_(dense, 1.2)
  const peaks    = detectPeaks_(smoothed, 0.15, 4)  // 15 % above mean, ≥ 56 days apart

  // Highlight peak points with orange markers
  const ptBg  = rawVals.map((_, i) => peaks.includes(i) ? '#F5A623' : 'rgba(159,225,203,0.45)')
  const ptRad = rawVals.map((_, i) => peaks.includes(i) ? 6 : 2)

  const ctx = document.getElementById('tsChart').getContext('2d')
  tsChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: labelMap[indexKey] || indexKey,
          data: rawVals,
          borderColor: 'rgba(159,225,203,0.65)',
          borderWidth: 1.2,
          pointBackgroundColor: ptBg,
          pointRadius: ptRad,
          pointHoverRadius: 7,
          fill: false,
          tension: 0.3,
          spanGaps: true
        },
        {
          label: 'Smoothed',
          data: smoothed.map(v => v !== null ? Math.round(v * 1000) / 1000 : null),
          borderColor: '#F5A623',
          borderWidth: 1.5,
          pointRadius: 0,
          fill: false,
          tension: 0.4,
          spanGaps: true
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            title: items => items[0].label,
            label: item => (item.datasetIndex === 0
              ? (labelMap[indexKey] || indexKey) + ': ' + item.raw
              : 'Smoothed: ' + item.raw)
          }
        }
      },
      scales: {
        x: {
          ticks: { color: '#9FE1CB', font: { size: 7 }, maxRotation: 45, minRotation: 30, maxTicksLimit: 10 },
          grid: { color: 'rgba(255,255,255,0.07)' }
        },
        y: {
          ticks: { color: '#9FE1CB', font: { size: 8 } },
          grid: { color: 'rgba(255,255,255,0.07)' }
        }
      }
    }
  });

  // Update label below chart with peak summary
  if (peaks.length) {
    const peakDates = peaks.map(i => labels[i]).join(', ')
    document.getElementById('tsChartLabel').textContent =
      peaks.length + ' season peak' + (peaks.length > 1 ? 's' : '') +
      ' detected (🟠) — ' + peakDates
  } else {
    document.getElementById('tsChartLabel').textContent =
      'No significant peaks detected — ' + tsData.length + ' intervals'
  }
}

// Season (DOY overlay) mode — fold all windows onto a Jan–Dec x-axis,
// one coloured line per selected year, plus a bold mean-year line.
function renderTsChartSeason_(indexKey) {
  const labelMap = { evi2: 'EVI2', ndre: 'NDRE', nirv: 'NIRv', ndmi: 'NDMI' }
  const selYears = tsSelectedYears ? Array.from(tsSelectedYears).sort() : []
  if (!selYears.length) {
    document.getElementById('tsChartLabel').textContent = 'No years selected — check at least one year below.'
    return
  }

  // Group tsData by year (skip years not in selection)
  const byYear = {}
  tsData.forEach(function(d) {
    const yr = d.date.substring(0, 4)
    if (!selYears.includes(yr)) return
    if (!byYear[yr]) byYear[yr] = []
    const doy = dateToDoy_(d.date)
    byYear[yr].push({ doy, val: d[indexKey] })
  })

  // Year colour palette (distinct from ZONE_COLORS)
  const yearPalette = ['#4ecdc4','#ff6b6b','#ffd166','#c3a6e0','#ff9f43','#54a0ff','#a8e6cf','#ee5a24']

  // Build one dataset per year
  const datasets = selYears.map(function(yr, i) {
    const col = yearPalette[i % yearPalette.length]
    const pts = (byYear[yr] || [])
      .filter(function(p) { return p.val != null })
      .sort(function(a, b) { return a.doy - b.doy })
      .map(function(p) { return { x: p.doy, y: Math.round(p.val * 1000) / 1000 } })
    return {
      type: 'scatter',
      label: yr,
      data: pts,
      borderColor: col,
      backgroundColor: col,
      pointRadius: 3,
      pointHoverRadius: 6,
      showLine: true,
      borderWidth: 1.4,
      fill: false,
      tension: 0.3,
      spanGaps: false
    }
  })

  // Mean-year line: average val at each biweekly DOY bucket (round to nearest 14)
  const buckets = {}
  selYears.forEach(function(yr) {
    ;(byYear[yr] || []).forEach(function(p) {
      if (p.val == null) return
      const bkt = Math.round(p.doy / 14) * 14
      if (!buckets[bkt]) buckets[bkt] = []
      buckets[bkt].push(p.val)
    })
  })
  const meanPts = Object.keys(buckets)
    .map(Number)
    .sort(function(a, b) { return a - b })
    .map(function(doy) {
      const vals = buckets[doy]
      return { x: doy, y: Math.round(vals.reduce(function(a, b) { return a + b }, 0) / vals.length * 1000) / 1000 }
    })
  datasets.push({
    type: 'line',
    label: 'Mean',
    data: meanPts,
    borderColor: '#F5A623',
    backgroundColor: 'transparent',
    borderWidth: 2.5,
    pointRadius: 0,
    fill: false,
    tension: 0.4,
    spanGaps: true
  })

  // Fixed month-start DOY tick positions
  const MONTH_DOYS   = [1, 32, 60, 91, 121, 152, 182, 213, 244, 274, 305, 335]
  const MONTH_LABELS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']

  const ctx = document.getElementById('tsChart').getContext('2d')
  tsChart = new Chart(ctx, {
    data: { datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: {
          display: true, position: 'bottom',
          labels: { color: '#9FE1CB', font: { size: 8 }, boxWidth: 8, padding: 4 }
        },
        tooltip: {
          callbacks: {
            title: function(items) {
              const doy = items[0].raw.x
              // Map DOY to approximate calendar date using a non-leap reference year (2001).
              // Add (doy - 1) days to Jan 1 of the reference year via millisecond arithmetic.
              const jan1 = new Date(2001, 0, 1)
              const ref  = new Date(jan1.getTime() + (doy - 1) * 86400000)
              return 'DOY ' + doy + ' (~' + ref.toLocaleDateString('en', { month: 'short', day: 'numeric' }) + ')'
            },
            label: function(item) {
              return item.dataset.label + ':  ' + (labelMap[indexKey] || indexKey) + ' = ' + item.raw.y
            }
          }
        }
      },
      scales: {
        x: {
          type: 'linear',
          min: 1, max: 365,
          title: { display: true, text: 'Day of year', color: '#9FE1CB', font: { size: 8 } },
          afterBuildTicks: function(axis) {
            axis.ticks = MONTH_DOYS.map(function(v) { return { value: v } })
          },
          ticks: {
            color: '#9FE1CB', font: { size: 7 }, maxRotation: 0, minRotation: 0,
            callback: function(val) {
              const idx = MONTH_DOYS.indexOf(val)
              return idx >= 0 ? MONTH_LABELS[idx] : ''
            }
          },
          grid: { color: 'rgba(255,255,255,0.07)' }
        },
        y: {
          ticks: { color: '#9FE1CB', font: { size: 8 } },
          grid: { color: 'rgba(255,255,255,0.07)' }
        }
      }
    }
  })

  document.getElementById('tsChartLabel').textContent =
    'Seasons overlaid — ' + selYears.length + ' year' + (selYears.length > 1 ? 's' : '') +
    ' (' + selYears.join(', ') + ')  |  orange line = mean'
}

// ── D1: Soil TS — decode one window PNG (RGBA → soil index means) ─
// Channel mapping: R=SAB×254, G=ClaySI×254 (rescaled), B=RI2×254 (rescaled), A=SMI×254 (rescaled).
// Pixels with [0,0,0,0] are nodata (no valid bare-soil observations) and skipped.
// Returns Promise<{sab, claysi, ri2, smi, n}|null>.
function decodeSoilTsWindowPng_(img64) {
  return new Promise(function(resolve) {
    const img = new Image()
    img.onload = function() {
      const canvas = document.createElement('canvas')
      canvas.width = img.width
      canvas.height = img.height
      const ctx = canvas.getContext('2d')
      ctx.drawImage(img, 0, 0)
      const px = ctx.getImageData(0, 0, img.width, img.height).data
      let rS=0, gS=0, bS=0, aS=0, n=0
      for (let i=0; i<px.length; i+=4) {
        if (px[i]===0 && px[i+1]===0 && px[i+2]===0 && px[i+3]===0) continue
        rS += px[i]; gS += px[i+1]; bS += px[i+2]; aS += px[i+3]
        n++
      }
      if (n === 0) { resolve(null); return }
      const sc = v => Math.round(v / 254 * 1000) / 1000
      resolve({ sab: sc(rS/n), claysi: sc(gS/n), ri2: sc(bS/n), smi: sc(aS/n), n })
    }
    img.onerror = function() { resolve(null) }
    img.src = 'data:image/png;base64,' + img64
  })
}

