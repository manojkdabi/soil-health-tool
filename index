        'data:image/png;base64,' + data.raster_png_b64,
        bounds,
        { opacity: opacityFs }
      ).addTo(resultsMapFs)
    } else {
      renderIdwHeatmap_(resultsMapFs, data.zone_stats, minLng, minLat, maxLng, maxLat)
    }

    L.geoJSON(roi, {
      style: { color: '#F5A623', weight: 2, fillOpacity: 0, dashArray: '4 3' }
    }).addTo(resultsMapFs)

    resultsMapFs.fitBounds(bounds, { padding: [20, 20] })

