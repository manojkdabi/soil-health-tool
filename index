).addTo(map)

// Load boundary GeoJSON when overlay is turned on
map.on('overlayadd', function (e) {
  var name = e.name
  if (name === '🏛 State Boundaries (India)')       loadBoundaryLayer_('state')
  if (name === '📍 District Boundaries (India)')    loadBoundaryLayer_('district')
  if (name === '🗺 Subdistrict Boundaries (India)') loadBoundaryLayer_('tehsil')
})

window.L = L  // make available for leaflet-draw

const drawn = new L.FeatureGroup().addTo(map)
const drawCtrl = new L.Control.Draw({
  draw: {
    polygon:  { shapeOptions: { color: '#F5A623', weight: 2, fillOpacity: 0.12 } },
    rectangle:{ shapeOptions: { color: '#F5A623', weight: 2, fillOpacity: 0.12 } },
