      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: '#9FE1CB', font: { size: 10 } }, grid: { color: '#1e3d30' } },
        y: { ticks: { color: '#9FE1CB', font: { size: 10 } }, grid: { color: '#1e3d30' }, max: 1 },
      }
    }
  })

  // Zone table
  const tbody = document.getElementById('zoneTbody')
  tbody.innerHTML = ''
  z.forEach((zs, i) => {
    const tr = document.createElement('tr')

    const tdZone = document.createElement('td')
    const zdot = document.createElement('span')
    zdot.className = 'zdot'
    zdot.style.background = ZONE_COLORS[i]
    tdZone.appendChild(zdot)
    tdZone.appendChild(document.createTextNode('Zone ' + zs.zone))

    const tdPx = document.createElement('td')
    tdPx.textContent = zs.pixel_count === 0 ? '—' : formatPixelCount(zs.pixel_count)
    if (zs.pixel_count === 0) tdPx.title = 'No bare-soil pixels — fallback SHPI value used'

    const tdShpi = document.createElement('td')
    tdShpi.textContent = zs.mean_shpi

    const tdCpi = document.createElement('td')
    const strong = document.createElement('strong')
    strong.textContent = zs.mean_cpi
    tdCpi.appendChild(strong)

    tr.appendChild(tdZone)
    tr.appendChild(tdPx)
    tr.appendChild(tdShpi)
    tr.appendChild(tdCpi)
    tbody.appendChild(tr)
  })

  // ── SHPI vs CPI scatter plot with linear regression ──────────
  // Use pixel-level sample when available, fall back to zone means
  const pxSample = (data.pixel_sample && data.pixel_sample.length >= 10) ? data.pixel_sample : null
  // For zone-fallback mode: only include zones with actual data
  const zWithData = z.filter(zs => zs.pixel_count > 0)
  const scatterPts = pxSample
    ? pxSample
    : zWithData.map(zs => ({ x: zs.mean_shpi, y: zs.mean_cpi, z: zs.zone - 1 }))

  const scatterX = scatterPts.map(p => p.x)
  const scatterY = scatterPts.map(p => p.y)
  const n = scatterX.length
  const sx = scatterX.reduce((a, b) => a + b, 0)
  const sy = scatterY.reduce((a, b) => a + b, 0)
  const sxy = scatterX.reduce((a, x, i) => a + x * scatterY[i], 0)
  const sxx = scatterX.reduce((a, x) => a + x * x, 0)
  const denom = n * sxx - sx * sx
  const slope = Math.abs(denom) > 1e-10 ? (n * sxy - sx * sy) / denom : 0
  const intercept = (sy - slope * sx) / n
  const yMean = sy / n
  const ssTot = scatterY.reduce((a, y) => a + (y - yMean) ** 2, 0)
  const ssRes = scatterX.reduce((a, x, i) => a + (scatterY[i] - (slope * x + intercept)) ** 2, 0)
  const r2 = ssTot > 0 ? 1 - ssRes / ssTot : 0
  const xMin = Math.min(...scatterX), xMax = Math.max(...scatterX)
  const lineData = [{ x: xMin, y: slope * xMin + intercept }, { x: xMax, y: slope * xMax + intercept }]
  const intSign = intercept >= 0 ? ' + ' : ' - '
  const nLabel = pxSample ? '  n=' + scatterPts.length + ' px' : '  n=' + scatterPts.length + ' zones'
  document.getElementById('scatterEq').textContent =
    'y = ' + slope.toFixed(3) + 'x' + intSign + Math.abs(intercept).toFixed(3) +
    '   R² = ' + r2.toFixed(3) + nLabel

  // Build per-zone colour arrays for pixel scatter
  const ptColors = scatterPts.map(p => {
    var zIdx = (p.z !== undefined) ? p.z : (p.zone !== undefined ? p.zone - 1 : 0)
    var hex = ZONE_COLORS[Math.max(0, Math.min(9, zIdx))]
    // Parse hex and return rgba with reduced alpha for dense pixel clouds
    var rr = parseInt(hex.slice(1,3),16), gg = parseInt(hex.slice(3,5),16), bb = parseInt(hex.slice(5,7),16)
    var alpha = pxSample ? 0.45 : 1
    return 'rgba(' + rr + ',' + gg + ',' + bb + ',' + alpha + ')'
  })

  // Zone-mean bin markers — only include zones with actual CPI data (pixel_count > 0)
  // Zones with no pixelPairs have mean_shpi=0 & mean_cpi=0, which fall outside the chart range
  const zoneBinDataset = {
    type: 'scatter',
    label: 'Zone means',
    data: zWithData.map(zs => ({ x: zs.mean_shpi, y: zs.mean_cpi, zone: zs.zone })),
    backgroundColor: zWithData.map(zs => {
      var c = hexToRgb_(ZONE_COLORS[Math.max(0, Math.min(ZONE_COLORS.length - 1, zs.zone - 1))])
      return 'rgba(' + c[0] + ',' + c[1] + ',' + c[2] + ',0.9)'
    }),
    borderColor: '#fff',
    borderWidth: 1,
    pointRadius: 7,
    pointHoverRadius: 9,
    pointStyle: 'circle',
    order: 0,  // render on top
  }

  if (scatterChart) scatterChart.destroy()
  const sctx = document.getElementById('shpiCpiScatter').getContext('2d')
  scatterChart = new Chart(sctx, {
    data: {
      datasets: [
        {
          type: 'scatter',
          label: pxSample ? 'Pixels' : 'Zones',
          data: scatterPts.map(p => ({ x: p.x, y: p.y })),
          backgroundColor: ptColors,
          borderColor: ptColors,
          pointRadius: pxSample ? 2 : 7,
          pointHoverRadius: pxSample ? 4 : 9,
        },
        ...(pxSample ? [zoneBinDataset] : []),
        {
          type: 'line',
          label: 'Fit',
          data: lineData,
          borderColor: '#F5A623',
          borderWidth: 1.5,
          pointRadius: 0,
          fill: false,
          tension: 0,
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: function(ctx) {
              if (ctx.dataset.label === 'Zone means') {
                var zone = ctx.raw.zone || (ctx.dataIndex + 1)
                return 'Z' + zone + ' mean  SHPI=' + ctx.raw.x.toFixed(3) + '  CPI=' + ctx.raw.y.toFixed(3)
              }
              return null
            }
          }
        }
      },
      scales: {
        x: {
          title: { display: true, text: 'SHPI', color: '#9FE1CB', font: { size: 9 } },
          ticks: { color: '#9FE1CB', font: { size: 9 } },
          grid: { color: '#1e3d30' }
        },
        y: {
          title: { display: true, text: 'CPI', color: '#9FE1CB', font: { size: 9 } },
          ticks: { color: '#9FE1CB', font: { size: 9 } },
          grid: { color: '#1e3d30' }
        }
      }
    }
  })

  document.getElementById('results').classList.add('show')
  document.getElementById('results-map-ctrls').style.display = 'flex'

  // Zone map — rendered after 'show' so the container has layout
  setTimeout(function() { renderResultsMap_(data) }, 50)
}

// ── Results Map ───────────────────────────────────────────────
function geomBbox_(geom) {
  var coords = geom.type === 'MultiPolygon'
    ? geom.coordinates.reduce(function(a, poly) { return a.concat(poly[0]) }, [])
    : geom.coordinates[0]
  return coords.reduce(function(b, c) {
    return [Math.min(b[0], c[0]), Math.min(b[1], c[1]), Math.max(b[2], c[0]), Math.max(b[3], c[1])]
  }, [Infinity, Infinity, -Infinity, -Infinity])
}

function hexToRgb_(hex) {
  var r = parseInt(hex.slice(1, 3), 16)
  var g = parseInt(hex.slice(3, 5), 16)
  var b = parseInt(hex.slice(5, 7), 16)
  return [r, g, b]
}

// Inverse-distance weighted colour from zone SHPI centroids
function idwColor_(px, py, centroids) {
  var eps = 1e-10
  var wSum = 0, rW = 0, gW = 0, bW = 0
  for (var k = 0; k < centroids.length; k++) {
    var dx = px - centroids[k].x, dy = py - centroids[k].y
    var d2 = dx * dx + dy * dy
    var w = 1 / (d2 + eps)
    wSum += w
    rW += w * centroids[k].r
    gW += w * centroids[k].g
    bW += w * centroids[k].b
  }
  return [Math.round(rW / wSum), Math.round(gW / wSum), Math.round(bW / wSum)]
}

// Convert a single outer ring (array of [lng,lat]) to canvas pixel coords
function ringToPixels_(ring, minLng, minLat, lngScale, latScale, W, H) {
  return ring.map(function(c) {
    return [(c[0] - minLng) * lngScale, H - (c[1] - minLat) * latScale]
  })
}

// ── Render results map: real Process API raster or IDW fallback ───────────────
function renderResultsMap_(data) {
  if (!roi) return
  var zoneStat   = data.zone_stats
  var rasterB64  = data.raster_png_b64 || null
  var container  = document.getElementById('results-map')

  if (!resultsMap) {
    resultsMap = L.map(container, { zoomControl: true, attributionControl: false })
    var mainBaseLayers0 = [esriSatellite, esriTopo, esriStreet, osmStandard]
    var activeBase0 = mainBaseLayers0.find(function(l) { return map.hasLayer(l) }) || esriSatellite
    L.tileLayer(activeBase0._url, Object.assign({}, activeBase0.options)).addTo(resultsMap)
    if (monthlyLayer && map.hasLayer(monthlyLayer)) {
      L.tileLayer(monthlyLayer._url, Object.assign({}, monthlyLayer.options)).addTo(resultsMap)
    }
  } else {
    resultsMap.eachLayer(function(lyr) {
      if (!(lyr instanceof L.TileLayer)) resultsMap.removeLayer(lyr)
    })
    resultsRasterLayer = null
  }

  var bb     = geomBbox_(roi)
  var minLng = bb[0], minLat = bb[1], maxLng = bb[2], maxLat = bb[3]
  var bounds = [[minLat, minLng], [maxLat, maxLng]]

  if (rasterB64) {
    // Real zone-coloured raster from the Sentinel Hub Process API
    var opacity = (document.getElementById('rasterOpacity').value || 80) / 100
    resultsRasterLayer = L.imageOverlay(
      'data:image/png;base64,' + rasterB64,
      bounds,
      { opacity: opacity }
    ).addTo(resultsMap)
  } else {
    // Fallback: IDW canvas heatmap (geometric approximation)
    renderIdwHeatmap_(resultsMap, zoneStat, minLng, minLat, maxLng, maxLat)
  }

  // ROI polygon outline on top
  L.geoJSON(roi, {
    style: { color: '#F5A623', weight: 2, fillOpacity: 0, dashArray: '4 3' }
  }).addTo(resultsMap)

  resultsMap.fitBounds(bounds, { padding: [6, 6] })
}

// ── IDW canvas heatmap (fallback when Process API raster is unavailable) ──────
function renderIdwHeatmap_(mapInst, zoneStat, minLng, minLat, maxLng, maxLat) {
  var W = 200, H = Math.max(1, Math.round(200 * (maxLat - minLat) / (maxLng - minLng)))
  var lngScale = W / (maxLng - minLng)
  var latScale = H / (maxLat - minLat)

  var latStep = (maxLat - minLat) / zoneStat.length
  var centroids = zoneStat.map(function(zs, i) {
    var rgb = hexToRgb_(ZONE_COLORS[i])
    return { x: W / 2, y: H - (i + 0.5) * latStep * latScale, r: rgb[0], g: rgb[1], b: rgb[2] }
  })

  var rings = roi.type === 'MultiPolygon'
    ? roi.coordinates.map(function(p) { return p[0] })
    : [roi.coordinates[0]]

  var canvas = document.createElement('canvas')
  canvas.width = W; canvas.height = H
  var ctx = canvas.getContext('2d')

  var offscreen = document.createElement('canvas')
  offscreen.width = W; offscreen.height = H
  var octx = offscreen.getContext('2d')
  var imgData = octx.createImageData(W, H)
  var d = imgData.data
  for (var py = 0; py < H; py++) {
    for (var px = 0; px < W; px++) {
      var rgb = idwColor_(px, py, centroids)
      var idx = (py * W + px) * 4
      d[idx] = rgb[0]; d[idx+1] = rgb[1]; d[idx+2] = rgb[2]; d[idx+3] = Math.round(0.65*255)
    }
  }
  octx.putImageData(imgData, 0, 0)

  ctx.save()
  rings.forEach(function(ring) {
    var pts = ringToPixels_(ring, minLng, minLat, lngScale, latScale, W, H)
    ctx.beginPath(); ctx.moveTo(pts[0][0], pts[0][1])
    for (var j = 1; j < pts.length; j++) ctx.lineTo(pts[j][0], pts[j][1])
    ctx.closePath()
  })
  ctx.clip(); ctx.drawImage(offscreen, 0, 0); ctx.restore()

  L.imageOverlay(canvas.toDataURL(), [[minLat, minLng], [maxLat, maxLng]]).addTo(mapInst)
}

// ── Update raster layer opacity ───────────────────────────────
function updateRasterOpacity_(val, labelId, isFullscreen) {
  document.getElementById(labelId).textContent = val + '%'
  var opacity = val / 100
  if (!isFullscreen && resultsRasterLayer)   resultsRasterLayer.setOpacity(opacity)
  if (isFullscreen  && resultsRasterLayerFs) resultsRasterLayerFs.setOpacity(opacity)
}

// ── Fullscreen results map toggle ──────────────────────────────────────────────
