// ── D3: Year×season paired scatter helpers ────────────────────
// Compute CPI composite from a tsData row (evi2/ndre/nirv/ndmi in [0,1]).
function computeCpiFromRow_(row) {
  function c01(v) { return v < 0 ? 0 : v > 1 ? 1 : v }
  return c01(row.evi2 / 0.80) * 0.35 +
         c01(row.ndre / 0.60) * 0.30 +
         c01(row.nirv / 0.40) * 0.20 +
         c01((row.ndmi + 0.10) / 0.60) * 0.15
}

// Compute SHPI composite from a soilTsData row (sab/claysi/ri2/smi in [0,1] rescaled from TS evalscript).
function computeShpiFromRow_(row) {
  function c01(v) { return v < 0 ? 0 : v > 1 ? 1 : v }
  // Recover raw sub-index values from TS evalscript rescaling
  var sab_r  = row.sab                    // raw brightness (already direct)
  var clay_r = row.claysi * 0.6 - 0.2    // raw ClaySI; TS encodes as (claySI+0.2)/0.6
  var ri2_r  = row.ri2 * 0.3 - 0.05      // raw RI2; TS encodes as (ri2+0.05)/0.3
  var smi_r  = row.smi - 0.5             // raw SMI; TS encodes as (smi+0.5)/1.0 = smi+0.5
  // Apply SHPI normalization (matches buildFallowShpiEvalscript_ in code_gs)
  var sabN    = c01((sab_r - 0.03) / 0.17)
  var claySIN = c01((clay_r + 0.10) / 0.20)
  var ri2N    = c01((ri2_r  + 0.05) / 0.20)
  var smiN    = c01((smi_r  + 0.20) / 0.50)
  return (1 - sabN) * 0.35 + claySIN * 0.30 + ri2N * 0.20 + smiN * 0.15
}

// Compute per-year SHPI(fallow) and CPI(season) means from tsData + soilTsData.
// Returns [{year, shpi, cpi, nShpi, nCpi}] sorted by year.
function computeYearSeasonPairs_(season) {
  if (!tsData || !soilTsData) return []
  var shpiByYear = {}  // year string → [shpi values]
  var cpiByYear  = {}  // year string (kharif-year) → [cpi values]

  if (season === 'kharif') {
    // Pre-Kharif SHPI: Feb–May of year Y
    soilTsData.forEach(function(d) {
      var mo = parseInt(d.date.substring(5, 7))
      if (mo >= 2 && mo <= 5) {
        var yr = d.date.substring(0, 4)
        if (!shpiByYear[yr]) shpiByYear[yr] = []
        shpiByYear[yr].push(computeShpiFromRow_(d))
      }
    })
    // Kharif CPI: Jun–Oct of year Y
    tsData.forEach(function(d) {
      var mo = parseInt(d.date.substring(5, 7))
      if (mo >= 6 && mo <= 10) {
        var yr = d.date.substring(0, 4)
        if (!cpiByYear[yr]) cpiByYear[yr] = []
        cpiByYear[yr].push(computeCpiFromRow_(d))
      }
    })
  } else { // rabi
    // Pre-Rabi SHPI: Oct–Nov of year Y
    soilTsData.forEach(function(d) {
      var mo = parseInt(d.date.substring(5, 7))
      if (mo >= 10 && mo <= 11) {
        var yr = d.date.substring(0, 4)
        if (!shpiByYear[yr]) shpiByYear[yr] = []
        shpiByYear[yr].push(computeShpiFromRow_(d))
      }
    })
    // Rabi CPI: Nov–Dec of year Y and Jan–Mar of year Y+1 → assigned to Rabi year Y
    tsData.forEach(function(d) {
      var yr = parseInt(d.date.substring(0, 4))
      var mo = parseInt(d.date.substring(5, 7))
      var rabiYr
      if (mo >= 11) rabiYr = String(yr)           // Nov/Dec → Rabi year Y
      else if (mo <= 3) rabiYr = String(yr - 1)   // Jan-Mar → Rabi year Y-1
      else return
      if (!cpiByYear[rabiYr]) cpiByYear[rabiYr] = []
      cpiByYear[rabiYr].push(computeCpiFromRow_(d))
    })
  }

  // Build paired array for years with both SHPI and CPI data
  var pairs = []
  Object.keys(shpiByYear).sort().forEach(function(yr) {
    if (!cpiByYear[yr] || cpiByYear[yr].length === 0) return
    var shpiMean = shpiByYear[yr].reduce(function(s,v){return s+v},0) / shpiByYear[yr].length
    var cpiMean  = cpiByYear[yr].reduce(function(s,v){return s+v},0)  / cpiByYear[yr].length
    pairs.push({ year: yr, shpi: shpiMean, cpi: cpiMean,
                 nShpi: shpiByYear[yr].length, nCpi: cpiByYear[yr].length })
  })
  return pairs
}

