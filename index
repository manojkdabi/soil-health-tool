document.getElementById('shpInput').addEventListener('change', function (e) {
  var file = e.target.files[0]
  if (!file) return
  var reader = new FileReader()
  reader.onload = function (ev) {
    JSZip.loadAsync(ev.target.result).then(function (zip) {
