// ── D2: Decode fallow SHPI PNG — R=SHPI×254, A=soil obs count ─────────────
// Returns Float32Array where -1 = no data (A channel === 0).
function decodeFallowShpiPng_(img64, callback) {
  var img = new Image()
  img.onerror = function() { callback(null) }
  img.onload = function() {
    var c = document.createElement('canvas')
    c.width = img.naturalWidth; c.height = img.naturalHeight
    var ctx = c.getContext('2d')
    ctx.drawImage(img, 0, 0)
    var px = ctx.getImageData(0, 0, c.width, c.height).data
    var total = c.width * c.height
    var shpiArr = new Float32Array(total)
    for (var i = 0; i < total; i++) {
      var A = px[i * 4 + 3]  // soil observation count (A channel)
      shpiArr[i] = A > 0 ? px[i * 4] / 254 : -1  // R channel = SHPI×254; -1 = no data
    }
    callback(shpiArr)
  }
  img.src = 'data:image/png;base64,' + img64
}

// ── D2: Fetch fallow SHPI raster and cache it ─────────────────
function fetchFallowShpi_(season, onReady) {
  if (!lastResult || !roi) {
    alert('Run analysis first before selecting a fallow SHPI scatter.')
    return
  }
  if (tsYearsForShpi.length === 0) {
    alert('Fetch Soil Series, select good bare-soil years, then click "🟤 Use selected years for SHPI" first.')
    return
  }
  var yearStart = tsYearsForShpi[0]
  var yearEnd   = tsYearsForShpi[tsYearsForShpi.length - 1]
  var statusEl  = document.getElementById('fallowShpiFetchStatus')
  if (statusEl) { statusEl.style.display = 'block'; statusEl.textContent = '⏳ Fetching ' + season + ' fallow SHPI raster…' }
  google.script.run
    .withSuccessHandler(function(data) {
      if (statusEl) statusEl.style.display = 'none'
      if (!data.success) {
        alert('Fallow SHPI fetch failed: ' + (data.error || 'unknown error'))
        return
      }
      decodeFallowShpiPng_(data.img64, function(shpiArr) {
        if (!shpiArr) { alert('Failed to decode fallow SHPI image.'); return }
        fallowShpiCache[season] = shpiArr
        if (onReady) onReady(shpiArr)
      })
    })
    .withFailureHandler(function(err) {
      if (statusEl) statusEl.style.display = 'none'
      alert('Fallow SHPI error: ' + err)
