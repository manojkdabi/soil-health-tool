// ── Season scatter helpers (Stage 2 / Stage 3) ────────────────────────────

// Active render dispatcher: renders FS scatter with season data if a season is selected,
// otherwise falls back to the standard all-season render with lastResult.
function renderScatterFsActive_() {
  if (scatterSeasonMode !== 'all' && seasonCpiCache[scatterSeasonMode]) {
    renderScatterWithSeasonPts_(seasonCpiCache[scatterSeasonMode], scatterSeasonMode)
  } else {
    if (lastResult) renderScatterPlotFs_(lastResult)
  }
}

// Decode a season CPI PNG (G=CPI×254, A=crop obs count) into a Float32Array indexed by pixel.
// Returns the array via callback, or null on error.
function decodeSeasCpiPng_(img64, callback) {
  var img = new Image()
  img.onerror = function() { callback(null) }
  img.onload = function() {
    var c = document.createElement('canvas')
    c.width = img.naturalWidth; c.height = img.naturalHeight
    var ctx = c.getContext('2d')
    ctx.drawImage(img, 0, 0)
    var px = ctx.getImageData(0, 0, c.width, c.height).data
    var total = c.width * c.height
    var cpiArr = new Float32Array(total)
    for (var i = 0; i < total; i++) {
      var A = px[i * 4 + 3]  // crop observation count (A channel)
      cpiArr[i] = A > 0 ? px[i * 4 + 1] / 254 : -1  // G channel = CPI×254; -1 = no data
    }
    callback(cpiArr)
  }
  img.src = 'data:image/png;base64,' + img64
}

// Pair shpi_sample pixel indices with a decoded season CPI array to build scatter points.
// shpiSample: [{idx, x, z}, ...]; cpiArr: Float32Array (−1 = nodata).
// Returns [{x: shpi, y: seasCpi, z: zone}, ...] for pixels where both SHPI and season CPI are valid.
function buildSeasonScatterData_(shpiSample, cpiArr) {
  var pts = []
  for (var i = 0; i < shpiSample.length; i++) {
    var sp = shpiSample[i]
    if (sp.idx >= cpiArr.length) continue
    var cpi = cpiArr[sp.idx]
    if (cpi < 0) continue  // no crop obs for this pixel in this season
    pts.push({ x: sp.x, y: cpi, z: sp.z })
  }
  return pts
}

// Set the scatter season mode and re-render (or fetch if not yet cached).
// season: 'all' | 'kharif' | 'rabi'
function setScatterSeasonMode_(season) {
  scatterSeasonMode = season
  var SEASONS = ['all', 'kharif', 'rabi']
  SEASONS.forEach(function(s) {
    var el = document.getElementById('scatterSeasonTab-' + s + '-fs')
    if (el) el.classList.toggle('active', s === season)
  })
  var titleEl = document.getElementById('scatterFsTitle')
  var SEASON_LABELS = { all: 'SHPI vs CPI correlation', kharif: 'SHPI vs Kharif CPI (Jun–Oct)', rabi: 'SHPI vs Rabi CPI (Nov–Mar)' }
  if (titleEl) titleEl.textContent = SEASON_LABELS[season] || 'SHPI vs CPI correlation'
  if (season === 'all') {
    if (lastResult) renderScatterPlotFs_(lastResult)
    return
  }
  // Use cached result if available
  if (seasonCpiCache[season]) {
    renderScatterWithSeasonPts_(seasonCpiCache[season], season)
    return
  }
  // Fetch season CPI raster from backend
  fetchSeasonCpi_(season)
}

// Fetch season-specific CPI raster from backend, decode, and render scatter.
function fetchSeasonCpi_(season) {
  if (!lastResult || !roi) {
    alert('Run analysis first before selecting a season CPI scatter.')
    return
  }
  var years = ((lastResult.meta && lastResult.meta.year_range) || '').split('-')
  var yearStart = years[0] ? parseInt(years[0]) : parseInt(document.getElementById('yearStart').value)
  var yearEnd   = years[1] ? parseInt(years[1]) : parseInt(document.getElementById('yearEnd').value)
  var statusEl = document.getElementById('seasonFetchStatus-fs')
  if (statusEl) { statusEl.style.display = 'block'; statusEl.textContent = '⏳ Fetching ' + season + ' CPI raster from Sentinel Hub…' }
  google.script.run
    .withSuccessHandler(function(data) {
      if (statusEl) statusEl.style.display = 'none'
      if (!data.success) {
        alert('Season CPI fetch failed: ' + (data.error || 'unknown error'))
        return
      }
      decodeSeasCpiPng_(data.img64, function(cpiArr) {
        if (!cpiArr) { alert('Failed to decode season CPI image.'); return }
        var shpiSample = lastResult.shpi_sample || []
        var pts = buildSeasonScatterData_(shpiSample, cpiArr)
        if (pts.length < 10) {
          alert('Not enough season crop pixels found for scatter (' + season + '). Try a wider year range or a region with denser crop cover in this season.')
          return
        }
        seasonCpiCache[season] = pts
        renderScatterWithSeasonPts_(pts, season)
      })
    })
    .withFailureHandler(function(err) {
      if (statusEl) statusEl.style.display = 'none'
      alert('Season CPI error: ' + err)
    })
    .getSeasonCpiRaster({ geojson: roi, season: season, yearStart: yearStart, yearEnd: yearEnd })
}

// Build season-specific zone stats from scatter points and render the FS scatter.
function renderScatterWithSeasonPts_(pts, season) {
  if (!lastResult) return
  // Compute zone stats from season scatter pts (not from main-raster zone_stats)
  var groups = {}
  pts.forEach(function(p) {
    var zi = p.z != null ? p.z : 0
    if (!groups[zi]) groups[zi] = []
    groups[zi].push(p)
  })
  var seasonZoneStats = Object.keys(groups).sort(function(a, b) { return +a - +b }).map(function(zi) {
    var g = groups[zi]
    var mx = g.reduce(function(s, p) { return s + p.x }, 0) / g.length
    var my = g.reduce(function(s, p) { return s + p.y }, 0) / g.length
    return { zone: +zi + 1, label: 'Zone ' + (+zi + 1),
             mean_shpi: mx, mean_cpi: my, pixel_count: g.length, data_source: 'real' }
  })
  // Build a synthetic result substituting season CPI data
  var seasonData = Object.assign({}, lastResult, { pixel_sample: pts, zone_stats: seasonZoneStats })
  renderScatterPlotFs_(seasonData)
}

// Shared OLS regression helper — works on arrays of {x, y} objects; returns slope, intercept, R², and line endpoints
function olsLine_(pts) {
  var n = pts.length
  if (n < 2) return { slope: 0, intercept: 0, r2: 0, lineData: [] }
  var sx = 0, sy = 0, sxy = 0, sxx = 0
  pts.forEach(function(p) { sx += p.x; sy += p.y; sxy += p.x * p.y; sxx += p.x * p.x })
  var denom = n * sxx - sx * sx
  var slope = Math.abs(denom) > EPSILON_DENOM ? (n * sxy - sx * sy) / denom : 0
  var intercept = (sy - slope * sx) / n
  var yMean = sy / n
  var ssTot = 0, ssRes = 0
  pts.forEach(function(p) { ssTot += (p.y - yMean) ** 2; ssRes += (p.y - (slope * p.x + intercept)) ** 2 })
  var r2 = ssTot > 0 ? 1 - ssRes / ssTot : 0
  var xVals = pts.map(function(p) { return p.x })
  var xMin = Math.min.apply(null, xVals), xMax = Math.max.apply(null, xVals)
  return { slope: slope, intercept: intercept, r2: r2,
           lineData: [{ x: xMin, y: slope * xMin + intercept }, { x: xMax, y: slope * xMax + intercept }] }
}

// Per-zone (bin-level) Tukey 1.5×IQR outlier filter on CPI (y-axis) within each zone
function binIqrFilter_(pts) {
  var groups = {}
  pts.forEach(function(p) {
    var zi = p.z != null ? p.z : 0
    if (!groups[zi]) groups[zi] = []
    groups[zi].push(p)
  })
  var kept = []
  Object.keys(groups).forEach(function(zi) {
    var g = groups[zi]
    if (g.length <= 4) { g.forEach(function(p) { kept.push(p) }); return }
    var ys = g.map(function(p) { return p.y }).sort(function(a, b) { return a - b })
    var q1 = ys[Math.floor(ys.length * 0.25)]
    var q3 = ys[Math.floor(ys.length * 0.75)]
    var iqr = q3 - q1
    var lo = q1 - 1.5 * iqr, hi = q3 + 1.5 * iqr
    g.forEach(function(p) { if (p.y >= lo && p.y <= hi) kept.push(p) })
  })
  return kept
}

// Zone-level Tukey 1.5×IQR filter — removes outlier zone-mean points from a zone_stats array
function zoneIqrFilter_(zWithData) {
  if (zWithData.length <= 4) return zWithData.slice()
  var ys = zWithData.map(function(zs) { return zs.mean_cpi }).sort(function(a, b) { return a - b })
  var q1 = ys[Math.floor(ys.length * 0.25)]
  var q3 = ys[Math.floor(ys.length * 0.75)]
  var iqr = q3 - q1
  var lo = q1 - 1.5 * iqr, hi = q3 + 1.5 * iqr
  return zWithData.filter(function(zs) { return zs.mean_cpi >= lo && zs.mean_cpi <= hi })
}

function zoneMeansFromSample_(pixelSample, applyBinFilter) {
  var pts = applyBinFilter ? binIqrFilter_(pixelSample) : pixelSample.slice()
  var groups = {}
  pts.forEach(function(p) {
    var zi = p.z != null ? p.z : 0
    if (!groups[zi]) groups[zi] = []
    groups[zi].push(p)
  })
  return Object.keys(groups).sort(function(a, b) { return +a - +b }).map(function(zi) {
    var g = groups[zi]
    var mx = g.reduce(function(s, p) { return s + p.x }, 0) / g.length
    var my = g.reduce(function(s, p) { return s + p.y }, 0) / g.length
    return { zone: +zi + 1, mean_shpi: mx, mean_cpi: my, pixel_count: g.length }
  })
}

function renderScatterPlot_(data) {
  if (!data) return
  var pixSample = data.pixel_sample || []
  var zWithData
  if (pixSample.length >= MIN_PIXEL_SAMPLE) {
    zWithData = zoneMeansFromSample_(pixSample, true).filter(function(zs) { return zs.pixel_count > 0 })
  } else {
    var z = data.zone_stats
    var zWithData0 = z.filter(function(zs) { return zs.pixel_count > 0 })
    zWithData = zoneIqrFilter_(zWithData0)
  }
  var removedZones = 0
  var bPts = zWithData.map(function(zs) { return { x: zs.mean_shpi, y: zs.mean_cpi } })
  var reg = olsLine_(bPts)
  var n = bPts.length
  var intSign = reg.intercept >= 0 ? ' + ' : ' - '
  document.getElementById('scatterEq').textContent =
    'y = ' + reg.slope.toFixed(3) + 'x' + intSign + Math.abs(reg.intercept).toFixed(3) +
    '   R² = ' + reg.r2.toFixed(3) + '  n=' + n + ' zones'

  // Spearman ρ across zone means
  ;(function() {
    if (n < 3) {
      document.getElementById('corrSummary').textContent = 'n < 3 zones — correlation not computed'
      return
    }
    var scatterX = bPts.map(function(p) { return p.x }), scatterY = bPts.map(function(p) { return p.y })
    function rankAvg_(arr) {
      var sorted = arr.slice().sort(function(a, b) { return a - b })
      return arr.map(function(v) {
        var idx = []
        sorted.forEach(function(s, i) { if (s === v) idx.push(i + 1) })
        return idx.reduce(function(a, b) { return a + b }, 0) / idx.length
      })
    }
    var rx = rankAvg_(scatterX), ry = rankAvg_(scatterY)
    var rmx = rx.reduce(function(a, b) { return a + b }, 0) / n
    var rmy = ry.reduce(function(a, b) { return a + b }, 0) / n
    var rNum = rx.reduce(function(a, v, i) { return a + (v - rmx) * (ry[i] - rmy) }, 0)
    var rdx = Math.sqrt(rx.reduce(function(a, v) { return a + (v - rmx) * (v - rmx) }, 0))
    var rdy = Math.sqrt(ry.reduce(function(a, v) { return a + (v - rmy) * (v - rmy) }, 0))
    var rho = (rdx * rdy > 0) ? rNum / (rdx * rdy) : 0
    var tStat = rho * Math.sqrt(n - 2) / Math.sqrt(Math.max(1e-15, 1 - rho * rho))
    function normCdf_(x) {
      var t2 = 1 / (1 + 0.2316419 * Math.abs(x))
      var d = 0.3989423 * Math.exp(-x * x / 2)
      var p = d * t2 * (0.3193815 + t2 * (-0.3565638 + t2 * (1.7814779 + t2 * (-1.8212560 + t2 * 1.3302744))))
      return x > 0 ? 1 - p : p
    }
    var pVal = 2 * normCdf_(-Math.abs(tStat))
    var pStr = pVal < 0.001 ? 'p < 0.001' : 'p = ' + pVal.toFixed(3)
    document.getElementById('corrSummary').textContent =
      'Spearman ρ = ' + rho.toFixed(3) + ',  ' + pStr + ',  R² = ' + reg.r2.toFixed(3)
  })()

  var noteEl = document.getElementById('scatterOutlierNote')
  if (noteEl) noteEl.textContent = pixSample.length >= MIN_PIXEL_SAMPLE
    ? 'Per-zone IQR outlier removal applied to pixel sample'
    : (removedZones > 0
        ? 'Outliers removed: Tukey 1.5×IQR on zone-mean CPI (' + removedZones + ' zone' + (removedZones > 1 ? 's' : '') + ' removed)'
        : 'Outlier filter: Tukey 1.5×IQR on zone-mean CPI (no outliers detected)')

  var zoneBinDataset = {
    type: 'scatter',
    label: 'Zone means',
    data: zWithData.map(function(zs) { return { x: zs.mean_shpi, y: zs.mean_cpi, zone: zs.zone } }),
    backgroundColor: zWithData.map(function(zs) {
      var c = hexToRgb_(ZONE_COLORS[Math.max(0, Math.min(ZONE_COLORS.length - 1, zs.zone - 1))])
      return 'rgba(' + c[0] + ',' + c[1] + ',' + c[2] + ',0.9)'
    }),
