function formatPixelCount(px) {
  return px >= 1000 ? (px / 1000).toFixed(1) + 'k' : String(Math.round(px))
}

function percentile_(arr, p) {
  // arr must be sorted ascending
  var idx = (p / 100) * (arr.length - 1)
  var lo  = Math.floor(idx)
  var hi  = Math.ceil(idx)
  if (lo === hi) return arr[lo]
  return arr[lo] + (arr[hi] - arr[lo]) * (idx - lo)
}

function pearson_(xs, ys) {
  var n  = xs.length
  var mx = xs.reduce(function(a, b) { return a + b }, 0) / n
  var my = ys.reduce(function(a, b) { return a + b }, 0) / n
  var cov = xs.reduce(function(s, x, i) { return s + (x - mx) * (ys[i] - my) }, 0)
  var sdx = Math.sqrt(xs.reduce(function(s, x) { return s + (x - mx) * (x - mx) }, 0))
  var sdy = Math.sqrt(ys.reduce(function(s, y) { return s + (y - my) * (y - my) }, 0))
  return (sdx > 0 && sdy > 0) ? cov / (sdx * sdy) : 0
}

