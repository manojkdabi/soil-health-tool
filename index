esriLabels.addTo(map)

// ── Admin boundary layers (loaded on-demand) ──────────────────
var boundaryLayers = {
  state:    L.layerGroup(),
  district: L.layerGroup(),
  tehsil:   L.layerGroup()
}
var boundaryLoaded = { state: false, district: false, tehsil: false }
var BOUNDARY_URLS = {
  state:    'https://raw.githubusercontent.com/datameet/maps/master/States/Admin2.geojson',
  district: 'https://raw.githubusercontent.com/datameet/maps/master/Districts/India_Districts-simplified.geojson',
  tehsil:   'https://raw.githubusercontent.com/datameet/maps/master/Tehsils/India_Tehsils-simplified.geojson'
}
var BOUNDARY_STYLE = {
  state:    { color: '#F5A623', weight: 1.5, fillOpacity: 0,  opacity: 0.8 },
  district: { color: '#9FE1CB', weight: 0.8, fillOpacity: 0,  opacity: 0.7 },
  tehsil:   { color: '#a0c0ff', weight: 0.5, fillOpacity: 0,  opacity: 0.6 }
}

function loadBoundaryLayer_(key) {
  if (boundaryLoaded[key]) return
  fetch(BOUNDARY_URLS[key])
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status)
      return r.json()
    })
    .then(function (gj) {
      boundaryLoaded[key] = true
      L.geoJSON(gj, {
        style: BOUNDARY_STYLE[key],
        onEachFeature: function (feature, layer) {
          var p = feature.properties || {}
          var name = p.NAME_2 || p.NAME_1 || p.DISTRICT || p.ST_NM || p.NAME || ''
          if (name) layer.bindTooltip(name, { sticky: true, className: 'bound-tooltip' })
        }
      }).addTo(boundaryLayers[key])
    })
    .catch(function (err) {
      console.warn('Boundary load failed (' + key + '):', err)
    })
}

// Layer control (with boundary overlays)
var layerCtrl = L.control.layers(
  {
    '🛰 Satellite (ESRI)': esriSatellite,
    '🗺 Topographic (ESRI)': esriTopo,
    '🏙 Street Map (ESRI)': esriStreet,
    '🌍 OpenStreetMap': osmStandard,
  },
  {
    '🏷 Place Labels': esriLabels,
    '🏛 State Boundaries (India)': boundaryLayers.state,
    '📍 District Boundaries (India)': boundaryLayers.district,
    '🗺 Subdistrict Boundaries (India)': boundaryLayers.tehsil
  },
