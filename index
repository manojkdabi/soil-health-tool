  // Mirror the main map's active base layer (whichever tile layer is currently on the map)
  var mainBaseLayers = [esriSatellite, esriTopo, esriStreet, osmStandard]
  var activeBase = mainBaseLayers.find(function(l) { return map.hasLayer(l) }) || esriSatellite
  L.tileLayer(activeBase._url, Object.assign({}, activeBase.options)).addTo(resultsMapFs)
