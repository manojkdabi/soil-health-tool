<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soil Health Stratification Tool · Treeconomy</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;background:#0f1a17;color:#e8f4ee;height:100vh;display:flex;flex-direction:column;overflow:hidden;font-size:13px}

/* Header */
.hdr{background:#1A3C34;padding:10px 18px;display:flex;align-items:center;gap:12px;border-bottom:1px solid #2E6B4F;flex-shrink:0}
.hdr-logo{width:28px;height:28px;background:#F5A623;border-radius:4px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:#3A1800}
.hdr h1{font-size:14px;font-weight:600;color:#fff}
.hdr p{font-size:11px;color:#9FE1CB;margin-left:auto}
.ver-pill{display:inline-block;padding:2px 7px;border-radius:10px;font-size:10px;font-weight:700;letter-spacing:.04em;line-height:1.6}
.ver-pill-be{background:#1e3d30;color:#F5A623;border:1px solid #F5A623}
.ver-pill-fe{background:#1e3d30;color:#9FE1CB;border:1px solid #9FE1CB}

/* Layout */
.main{display:flex;flex:1;overflow:hidden}
.sidebar{width:320px;background:#13241e;border-right:1px solid #1e3d30;display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0}
#map{flex:1;background:#e8e0d8;position:relative}

/* Sidebar sections */
.sb{padding:14px 16px;border-bottom:1px solid #1e3d30}
.sb h3{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#F5A623;margin-bottom:10px}
.sb p.hint{font-size:11px;color:#9FE1CB;opacity:.6;line-height:1.5;margin-bottom:10px}
label.field{font-size:11px;color:#9FE1CB;opacity:.7;display:block;margin-bottom:3px;margin-top:8px}
label.field:first-child{margin-top:0}
input,select{width:100%;background:#1e3d30;border:1px solid #2E6B4F;border-radius:5px;padding:6px 9px;color:#e8f4ee;font-size:12px;outline:none}
input:focus,select:focus{border-color:#F5A623}

/* ROI status */
.roi-ok{background:#1a3d1a;color:#7FE07F;border:1px solid #3a6d3a;border-radius:5px;padding:6px 9px;font-size:11px;margin-bottom:8px;display:none}
.roi-ok.show{display:block}

/* Upload zone */
.upload{border:1.5px dashed #2E6B4F;border-radius:6px;padding:10px;text-align:center;cursor:pointer;font-size:11.5px;color:#5a8a6a;transition:.15s;margin-bottom:6px}
.upload:hover{border-color:#F5A623;color:#F5A623}

/* Context menus */
.ctx-menu{position:absolute;background:#13241e;border:1px solid #2E6B4F;border-radius:6px;padding:4px 0;z-index:9999;min-width:200px;box-shadow:0 4px 14px rgba(0,0,0,.55);display:none}
.ctx-menu.open{display:block}
.ctx-menu-item{display:block;padding:8px 14px;font-size:12px;color:#9FE1CB;cursor:pointer;white-space:nowrap}
.ctx-menu-item:hover{background:#1e3d30;color:#F5A623}

/* Buttons */
.btn{width:100%;padding:10px;border:none;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;transition:.15s;margin-top:4px}
.btn-run{background:#F5A623;color:#3A1800}
.btn-run:hover{background:#ffb93d}
.btn-run:disabled{background:#5a4010;color:#9a7030;cursor:not-allowed}
.btn-sec{background:#1e3d30;border:1px solid #2E6B4F;color:#9FE1CB;font-size:12px}
.btn-sec:hover{background:#2E6B4F}

/* Progress */
.progress{margin-top:8px;display:none}
.progress.show{display:block}
.prog-bar{height:3px;background:#2E6B4F;border-radius:2px;overflow:hidden;margin-top:6px}
.prog-fill{height:100%;background:#F5A623;border-radius:2px;width:0%;transition:width .4s}
.prog-msg{font-size:11px;color:#9FE1CB;opacity:.7;margin-top:4px}

/* Results */
.results{display:none;padding:14px 16px;flex-direction:column;gap:10px}
.results.show{display:flex}
.banner{border-radius:6px;padding:9px 12px;font-size:12px;font-weight:600;text-align:center}
.banner-yes{background:#1a3d1a;color:#7FE07F;border:1px solid #3a6d3a}
.banner-no{background:#3d2a1a;color:#f0a070;border:1px solid #6d4a2a}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.stat-card{background:#1a3d30;border:1px solid #2E6B4F;border-radius:6px;padding:8px 10px;text-align:center}
.stat-val{font-size:16px;font-weight:700;color:#F5A623}
.stat-lbl{font-size:10px;color:#5a8a6a;margin-top:2px}
.ztbl{width:100%;border-collapse:collapse;font-size:11px}
.ztbl th{padding:5px 6px;background:#1a3d30;color:#9FE1CB;text-align:left;font-weight:600}
.ztbl td{padding:5px 6px;border-bottom:1px solid #1a3020}
#results-map{height:220px;border-radius:6px;overflow:hidden;border:1px solid #2E6B4F;margin-top:2px}
/* Results map controls (opacity + fullscreen toggle) */
#results-map-ctrls{display:none;align-items:center;gap:6px;margin-bottom:4px;padding:0 2px}
#rasterOpacity{flex:1;height:4px;accent-color:#F5A623;cursor:pointer}
.rm-ctrl-btn{background:#1e3d30;border:1px solid #2E6B4F;color:#9FE1CB;border-radius:4px;padding:2px 7px;cursor:pointer;font-size:13px;line-height:1.4}
.rm-ctrl-btn:hover{background:#2E6B4F;color:#F5A623}
/* Fullscreen results map overlay */
#results-fs-container{display:none;position:fixed;inset:0;z-index:20000;background:#0f1a17}
#results-fs-map{position:absolute;inset:0}
#results-fs-topbar{position:absolute;top:12px;left:12px;z-index:1001;display:flex;align-items:center;gap:8px;background:#13241ecc;border:1px solid #2E6B4F;border-radius:6px;padding:6px 10px}
#results-fs-panel{position:absolute;top:12px;right:12px;background:#13241e;border:1px solid #2E6B4F;border-radius:8px;padding:12px 14px;z-index:1001;min-width:230px;max-height:calc(100vh - 30px);overflow-y:auto}
/* Swipe / curtain handle */
#fs-swipe-handle{display:none;position:absolute;top:0;bottom:0;width:3px;background:#F5A623;cursor:ew-resize;z-index:1600;touch-action:none}
#fs-swipe-knob{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:32px;height:32px;background:#F5A623;color:#0f1a17;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;user-select:none;box-shadow:0 2px 8px #0007;pointer-events:none}
#fs-swipe-label-l{position:absolute;top:50%;transform:translateY(-50%);right:calc(100% + 8px);font-size:10px;font-weight:700;color:#fff;background:#0006;padding:2px 5px;border-radius:3px;white-space:nowrap;pointer-events:none}
#fs-swipe-label-r{position:absolute;top:50%;transform:translateY(-50%);left:calc(100% + 8px);font-size:10px;font-weight:700;color:#fff;background:#0006;padding:2px 5px;border-radius:3px;white-space:nowrap;pointer-events:none}
/* Radio toggle for Zones / SHPI / CPI in fullscreen map */
#fs-layer-toggle{display:flex;gap:4px;align-items:center}
#fs-layer-toggle label{display:flex;align-items:center;gap:3px;cursor:pointer;font-size:10px;color:#9FE1CB;padding:2px 6px;border-radius:4px;border:1px solid transparent;user-select:none;transition:background .15s,border-color .15s}
#fs-layer-toggle label:hover{background:#1a3d30}
#fs-layer-toggle input[type=radio]{display:none}
#fs-layer-toggle input[type=radio]:checked+span{color:#F5A623}
#fs-layer-toggle label:has(input:checked){border-color:#F5A623;background:#1e3d30}

.fs-tbl th{padding:4px 6px;background:#1a3d30;color:#9FE1CB;text-align:left;font-weight:600}
.fs-tbl td{padding:4px 6px;border-bottom:1px solid #1a3020}
.zdot{display:inline-block;width:8px;height:8px;border-radius:2px;margin-right:4px;vertical-align:middle}

/* Zone legend */
.legend{position:absolute;bottom:28px;right:10px;background:#13241e;border:1px solid #1e3d30;border-radius:8px;padding:10px;z-index:500}
.legend p{font-size:10px;font-weight:700;color:#F5A623;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px}
.leg-row{display:flex;align-items:center;gap:6px;margin-bottom:4px}
.leg-swatch{width:14px;height:10px;border-radius:2px;flex-shrink:0}
.leg-lbl{font-size:10px;color:#9FE1CB}

/* Loading overlay */
.overlay{position:absolute;inset:0;background:rgba(0,0,0,.6);display:none;align-items:center;justify-content:center;z-index:999;flex-direction:column;gap:12px}
.overlay.show{display:flex}
.spinner{width:40px;height:40px;border:3px solid #2E6B4F;border-top-color:#F5A623;border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.ov-msg{color:#9FE1CB;font-size:13px;font-weight:500;text-align:center;max-width:240px;line-height:1.5}

/* Monthly imagery section */
.mon-section{margin-top:4px}
.mon-row{display:flex;gap:4px;align-items:center;margin-top:4px}
.mon-row select,.mon-row input[type=number]{flex:1;background:#0f1a17;border:1px solid #2E6B4F;color:#9FE1CB;border-radius:4px;padding:3px 5px;font-size:11px}
.mon-row button{background:#1e3d30;border:1px solid #2E6B4F;color:#9FE1CB;border-radius:4px;padding:3px 7px;font-size:11px;cursor:pointer;white-space:nowrap}
.mon-row button:hover{background:#2E6B4F;color:#F5A623}
.mon-hint{font-size:9px;color:#5a8a6a;margin-top:3px;line-height:1.4}
.mon-loading{font-size:9px;color:#F5A623;margin-top:3px;display:none}
/* Boundary layer status */
.bound-badge{font-size:9px;color:#9FE1CB;background:#1a3d30;border:1px solid #2E6B4F;border-radius:3px;padding:1px 5px;margin-left:4px;display:none}

/* Leaflet overrides */
.leaflet-container{background:#e8e0d8!important}
.leaflet-draw-toolbar a{background-color:#1A3C34!important;border-color:#2E6B4F!important}
.leaflet-draw-toolbar a:hover{background-color:#2E6B4F!important}
.leaflet-control-layers{background:#13241e!important;border:1px solid #2E6B4F!important;color:#9FE1CB!important;font-size:11px}
.leaflet-control-layers label{color:#9FE1CB!important}
.leaflet-control-layers-separator{border-color:#2E6B4F!important}
.leaflet-bar a,.leaflet-bar a:hover{background-color:#ffffff!important;color:#1A3C34!important;border-color:#ccc!important}

/* Chart */
.chart-wrap{height:120px;margin-top:4px}
canvas{display:block}
/* Chart fullscreen overlay */
.chart-fs-overlay{display:none;position:fixed;inset:0;z-index:20200;background:#0f1a17;flex-direction:column}
.chart-fs-overlay.open{display:flex}
.chart-fs-topbar{display:flex;align-items:center;gap:8px;background:#13241e;border-bottom:1px solid #2E6B4F;padding:10px 16px;flex-shrink:0}
.chart-fs-title{font-size:13px;font-weight:700;color:#F5A623;text-transform:uppercase;letter-spacing:.06em;flex:1}
.chart-fs-body{flex:1;padding:24px 32px;position:relative;min-height:0}
/* Expand button next to chart headings */
.chart-heading-row{display:flex;align-items:center;justify-content:space-between;margin-top:4px}
.chart-heading-row h3{margin:0}
.chart-expand-btn{background:#1e3d30;border:1px solid #2E6B4F;color:#9FE1CB;border-radius:4px;padding:2px 7px;cursor:pointer;font-size:13px;line-height:1.4;flex-shrink:0}
.chart-expand-btn:hover{background:#2E6B4F;color:#F5A623}

/* Footer */
.footer{background:#0d1e18;border-top:1px solid #1e3d30;padding:4px 16px;font-size:10px;color:#3a6a4a;flex-shrink:0}

/* ROI Library */
.lib-empty{text-align:center;font-size:11px;color:#3a6a4a;padding:8px 0}
.lib-item{background:#1a3d30;border:1px solid #2E6B4F;border-radius:5px;padding:8px 10px;margin-bottom:6px}
.lib-item-name{font-size:12px;font-weight:600;color:#e8f4ee;margin-bottom:2px}
.lib-item-meta{font-size:10px;color:#5a8a6a;display:flex;gap:10px;margin-bottom:4px}
.lib-item-actions{display:flex;gap:5px}
.lib-btn{flex:1;padding:4px 6px;border:1px solid #2E6B4F;border-radius:4px;background:#0f1a17;color:#9FE1CB;font-size:10px;cursor:pointer;text-align:center}
.lib-btn:hover{background:#2E6B4F;color:#F5A623}
.lib-btn-load{border-color:#F5A623;color:#F5A623}.lib-btn-load:hover{background:#F5A623;color:#3A1800}
.lib-btn-del{border-color:#6d2a2a;color:#f07070}.lib-btn-del:hover{background:#6d2a2a}
.lib-btn-cached{border-color:#3a6d3a;color:#7FE07F}.lib-btn-cached:hover{background:#3a6d3a}

/* Batch run */
.batch-progress{display:none;margin-top:8px;padding:8px 10px;background:#1a3d30;border:1px solid #2E6B4F;border-radius:5px}
.batch-progress.show{display:block}
.batch-prog-item{display:flex;align-items:center;gap:6px;margin-bottom:4px;font-size:11px;color:#9FE1CB}
.batch-prog-dot{width:8px;height:8px;border-radius:50%;background:#2E6B4F;flex-shrink:0}
.batch-prog-dot.running{background:#F5A623;animation:pulse_ 1s infinite}
.batch-prog-dot.done{background:#7FE07F}.batch-prog-dot.failed{background:#f07070}
@keyframes pulse_{0%,100%{opacity:1}50%{opacity:.3}}

/* Compare section */
.compare-section{display:none;padding:14px 16px;border-top:2px solid #F5A623}
.compare-section.show{display:block}
.cmp-table{width:100%;border-collapse:collapse;font-size:10px;margin-bottom:6px}
.cmp-table th{padding:5px 5px;background:#1a3d30;color:#9FE1CB;text-align:left;font-weight:600}
.cmp-table td{padding:4px 5px;border-bottom:1px solid #1a3020}
.roi-color-dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:4px;vertical-align:middle}
.cmp-tabs{display:flex;gap:4px;margin-bottom:8px}
.cmp-tab{flex:1;padding:4px 6px;background:#1e3d30;border:1px solid #2E6B4F;border-radius:4px;color:#9FE1CB;font-size:10px;cursor:pointer;text-align:center}
.cmp-tab.active{background:#F5A623;color:#3A1800;border-color:#F5A623;font-weight:600}
.cmp-chart-wrap{height:130px;margin-top:4px}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-logo">SH</div>
  <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
    <h1>Soil Health Stratification Tool</h1>
    <span class="ver-pill ver-pill-be">BE1.1.0</span>
    <span class="ver-pill ver-pill-fe">FE1.1.0</span>
  </div>
  <p>Treeconomy · Phase 1 POC · Sentinel-2 SR</p>
</div>

<div class="main">
  <!-- SIDEBAR -->
  <div class="sidebar">

    <!-- Step 1: ROI -->
    <div class="sb">
      <h3>Step 1 · Study Area</h3>
      <p class="hint">Draw a polygon on the map or upload a GeoJSON file. Keep area under ~5,000 km².</p>
      <div id="roiStatus" class="roi-ok"></div>
      <input type="file" id="gjInput" accept=".geojson,.json" style="display:none">
      <input type="file" id="shpInput" accept=".zip" style="display:none">
      <div class="upload" id="uploadBtn" onclick="showUploadMenu_(event)">📁 Upload ROI</div>
      <div style="text-align:center;font-size:10px;color:#3a6a4a;margin:4px 0">— or draw on map —</div>
      <button class="btn btn-sec" onclick="clearROI()">✕ Clear ROI</button>
      <button class="btn btn-sec" style="margin-top:4px" onclick="saveCurrentROI_()">💾 Save ROI to Library</button>
    </div>

    <!-- ROI Library -->
    <div class="sb" id="libSection">
      <h3 style="cursor:pointer;user-select:none;display:flex;align-items:center;gap:6px" onclick="toggleLibrary_()">
        <span>📚 ROI Library</span>
        <span id="libCount" style="font-size:10px;color:#9FE1CB;font-weight:400;text-transform:none;letter-spacing:0;flex:1"></span>
        <span id="libToggleIcon" style="font-size:10px">▼</span>
      </h3>
      <div id="libList"></div>
    </div>

    <!-- Step 2: Config -->
    <div class="sb">
      <h3>Step 2 · Configure Analysis</h3>
      <label class="field">Year range start</label>
      <input type="number" id="yearStart" value="2021" min="2017" max="2024">
      <label class="field">Year range end</label>
      <input type="number" id="yearEnd" value="2023" min="2018" max="2024">
      <label class="field">Spatial resolution (metres)</label>
      <select id="resolution">
        <option value="100">100 m — fastest, large areas</option>
        <option value="60" selected>60 m — recommended for POC</option>
        <option value="30">30 m — precise, slower</option>
      </select>
    </div>

    <!-- Monthly Satellite Imagery -->
    <div class="sb mon-section">
      <h3 style="cursor:pointer;user-select:none;display:flex;align-items:center;gap:6px" onclick="toggleMonSection_()">
        <span>🛰 Monthly Imagery</span>
        <span id="monToggleIcon" style="font-size:10px;margin-left:auto">▶</span>
      </h3>
      <div id="monBody" style="display:none">
        <p class="hint" style="margin:0 0 6px">View satellite imagery for any month. Uses ESRI Wayback (no setup) or Sentinel-2 via your SH/CDS instance ID.</p>
        <label class="field">Source</label>
        <select id="monSource" onchange="onMonSourceChange_()">
          <option value="esri">🌍 ESRI Wayback (free, no login)</option>
          <option value="sh">🛰 Sentinel-2 WMS (requires Instance ID)</option>
        </select>

        <!-- ESRI Wayback controls -->
        <div id="esriWaybackCtrl">
          <label class="field">Select date</label>
          <div class="mon-row">
            <select id="esriReleaseSelect" style="flex:2">
              <option value="">— load dates —</option>
            </select>
            <button onclick="loadEsriRelease_()">▶ Apply</button>
          </div>
          <div class="mon-hint">Dates are ESRI's update cycles (not exact calendar months).</div>
          <div id="esriReleaseMsg" class="mon-hint" style="color:#9FE1CB"></div>
        </div>

        <!-- Sentinel Hub WMS controls -->
        <div id="shWmsCtrl" style="display:none">
          <label class="field">Instance ID (from CDS/SH dashboard)</label>
          <input type="text" id="shInstanceId" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" style="width:100%;background:#0f1a17;border:1px solid #2E6B4F;color:#9FE1CB;border-radius:4px;padding:4px 6px;font-size:10px;box-sizing:border-box">
          <label class="field" style="margin-top:6px">Month / Year</label>
          <div class="mon-row">
            <select id="shMonth">
              <option value="01">January</option><option value="02">February</option>
              <option value="03">March</option><option value="04">April</option>
              <option value="05">May</option><option value="06">June</option>
              <option value="07">July</option><option value="08">August</option>
              <option value="09">September</option><option value="10">October</option>
              <option value="11">November</option><option value="12">December</option>
            </select>
            <input type="number" id="shYear" value="2023" min="2017" max="2025" style="max-width:64px">
            <button onclick="applyShWms_()">▶ Apply</button>
          </div>
          <div class="mon-hint">Requires a WMS Configuration created in your Copernicus Browser account (sh.dataspace.copernicus.eu → Dashboard → Configurations). Paste the Configuration ID above.</div>
        </div>

        <button class="btn btn-sec" style="margin-top:6px;width:100%" onclick="clearMonthlyLayer_()">✕ Clear Monthly Imagery</button>
        <div id="monLoading" class="mon-loading">Loading release list…</div>
      </div>
    </div>

    <!-- Step 3: Run -->
    <div class="sb">
      <button class="btn btn-run" id="runBtn" onclick="runAnalysis()" disabled>
        ▶ Run Phase 1 Analysis
      </button>
      <button class="btn btn-sec" id="runAllBtn" style="margin-top:6px" onclick="runAllROIs_()">
        ▶▶ Run All Saved ROIs
      </button>
      <div class="progress" id="progress">
        <div class="prog-msg" id="progMsg">Initialising...</div>
        <div class="prog-bar"><div class="prog-fill" id="progFill"></div></div>
      </div>
      <div class="batch-progress" id="batchProgress">
        <div style="font-size:10px;font-weight:700;color:#F5A623;margin-bottom:6px">Batch Progress</div>
        <div id="batchItems"></div>
      </div>
    </div>

    <!-- Results -->
    <div class="results" id="results">
      <h3 style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#F5A623">Results</h3>
      <div class="banner" id="banner"></div>
      <div id="dataSourceBadge" style="text-align:center;font-size:10px;padding:3px 8px;border-radius:4px;display:none"></div>
      <div class="stat-grid" id="statGrid"></div>
      <div class="chart-heading-row"><h3 style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#F5A623;margin-top:4px">Mean CPI per zone</h3><button class="chart-expand-btn" onclick="openChartFs_('cpiChart')" title="Fullscreen">⛶</button></div>
      <div class="chart-wrap"><canvas id="cpiChart"></canvas></div>
      <table class="ztbl">
        <thead><tr><th>Zone</th><th>Pixels</th><th>SHPI</th><th>CPI</th></tr></thead>
        <tbody id="zoneTbody"></tbody>
      </table>
      <div class="chart-heading-row"><h3 style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#F5A623;margin-top:6px">SHPI vs CPI correlation</h3><button class="chart-expand-btn" onclick="openChartFs_('shpiCpiScatter')" title="Fullscreen">⛶</button></div>
      <div class="chart-wrap" style="height:160px"><canvas id="shpiCpiScatter"></canvas></div>
